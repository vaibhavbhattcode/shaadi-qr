# Copy this file to .env before running locally.
NODE_ENV=development
PORT=3000

# Public URL used inside QR codes. In production set this to your real HTTPS domain.
APP_URL=http://localhost:3000

# IMPORTANT: In production these must be long random strings.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-dev-jwt-secret-minimum-32-characters
COOKIE_SECRET=change-this-dev-cookie-secret-minimum-32-characters

# Data and uploaded media paths. Relative paths are resolved from the project root.
DATABASE_PATH=./data/app.db
STORAGE_DIR=./storage

# Keep true for MVP. Turn false after creating your first admin account.
REGISTRATION_ENABLED=true

# Security / upload limits
TRUST_PROXY=false
MAX_FILES_PER_UPLOAD=20
GLOBAL_MAX_FILE_SIZE_MB=200

# Cloud Storage Configuration (local | r2 | s3)
STORAGE_PROVIDER=local
S3_ENDPOINT=https://your-r2-account-id.r2.cloudflarestorage.com
S3_BUCKET_NAME=shaadishots-media
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_REGION=auto

# Razorpay Integration (optional, runs in sandbox mock mode if empty)
RAZORPAY_KEY_ID=rzp_test_yourkeyid
RAZORPAY_KEY_SECRET=yourkeysecret

