<section class="between">
  <div>
    <span class="badge">Approved gallery</span>
    <h1 style="margin:10px 0 4px; letter-spacing:-.04em;"><%= event.title %></h1>
    <p class="muted">Only couple/admin approved memories are visible here.</p>
  </div>
  <div class="row">
    <% if (event.public_download_enabled) { %>
      <a class="btn" href="/e/<%= event.slug %>/download.zip">Download ZIP</a>
    <% } %>
  </div>
</section>

<% if (!media.length) { %>
  <div class="empty" style="margin-top:24px;">
    <h2>Gallery empty hai</h2>
    <p class="muted">Admin approve karne ke baad photos/videos yahan show honge.</p>
  </div>
<% } else { %>
  <% folders.forEach((folder) => { const items = media.filter((m) => m.folder_id === folder.id); if (!items.length) return; %>
    <section style="margin-top:28px;">
      <div class="between" style="margin-bottom:12px;">
        <h2 style="margin:0;"><%= folder.name %></h2>
        <span class="badge"><%= items.length %> memories</span>
      </div>
      <div class="media-grid">
        <% items.forEach((item) => { %>
          <article class="media-card">
            <div class="thumb">
              <% if (item.media_type === 'image') { %>
                <a target="_blank" href="/e/<%= event.slug %>/media/<%= item.id %>"><img loading="lazy" src="/e/<%= event.slug %>/media/<%= item.id %>/thumbnail" alt="<%= item.original_name %>"></a>
              <% } else { %>
                <video src="/e/<%= event.slug %>/media/<%= item.id %>" controls preload="metadata"></video>
              <% } %>
            </div>
            <div class="body">
              <strong title="<%= item.original_name %>" style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= item.original_name %></strong>
              <span class="hint"><%= helpers.formatBytes(item.size_bytes) %> · By <%= item.uploader_name || 'Guest' %></span>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  <% }) %>
<% } %>
