<section class="max-w-3xl mx-auto py-8 space-y-8">
  <div class="glass-card text-center p-8 rounded-2xl border border-primary/10 bg-white/70 backdrop-blur-xl space-y-3">
    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary/10 rounded-full text-primary text-xs font-bold shadow-sm border border-primary/15">
      ✨ Guest Wedding Portal
    </span>
    <h1 class="font-headline text-4xl sm:text-5xl font-bold text-primary leading-none tracking-tight"><%= event.title %></h1>
    <p class="text-slate-500 text-sm leading-relaxed max-w-lg mx-auto">
      Upload your candid photos and videos here. Once approved by the host, they will appear in the shared live gallery.
    </p>
    <div class="max-w-md mx-auto pt-4">
      <div class="flex justify-between text-xs font-semibold text-slate-500 mb-1.5">
        <span>Album Storage</span>
        <span><%= storage.usedHuman %> / <%= storage.limitHuman %></span>
      </div>
      <div class="w-full bg-primary/10 h-2.5 rounded-full overflow-hidden">
        <div class="bg-gradient-wedding h-full rounded-full" style="width: <%= storage.percent %>%"></div>
      </div>
    </div>
  </div>

  <form id="uploadForm" class="glass-card p-8 rounded-2xl border border-primary/10 bg-white/70 backdrop-blur-xl space-y-6" method="post" enctype="multipart/form-data" action="/e/<%= event.slug %>/upload?token=<%= encodeURIComponent(uploadToken) %>">
    <input type="hidden" name="token" value="<%= uploadToken %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <!-- Upload Dropzone -->
    <div id="dropZone" class="group relative flex flex-col items-center justify-center border-2 border-dashed border-primary/20 rounded-xl p-10 bg-primary/5 hover:bg-primary/10 transition-all cursor-pointer active:scale-[0.99]">
      <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center text-primary shadow-md mb-4 group-hover:scale-115 transition-all">
        <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">add_a_photo</span>
      </div>
      <span class="bg-gradient-wedding text-white px-6 py-2.5 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all">
        Select Photos/Videos
      </span>
      <p class="mt-4 text-xs text-slate-400">Drag & drop here or click to browse</p>
      <p class="mt-1 text-[10px] text-slate-400 font-semibold uppercase tracking-wider">JPG, PNG, WEBP, HEIC, MP4, MOV supported</p>
      
      <input id="fileInput" type="file" name="media" multiple accept="image/jpeg,image/png,image/webp,image/heic,image/heif,video/mp4,video/quicktime,video/webm,.jpg,.jpeg,.png,.webp,.heic,.heif,.mp4,.mov,.webm" required class="hidden">
      <div id="fileList" class="mt-4 text-xs font-bold text-primary"></div>
    </div>

    <!-- Form Fields -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-1.5">
        <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Ceremony Folder</label>
        <select name="folder_id" required class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-3 focus:ring-primary focus:border-primary text-sm appearance-none">
          <% folders.forEach((folder) => { %>
            <option value="<%= folder.id %>"><%= folder.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="space-y-1.5">
        <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Guest Name <span class="text-slate-400 font-normal lowercase">(optional)</span></label>
        <input name="uploader_name" maxlength="80" placeholder="e.g. Priya Sharma" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-3 focus:ring-primary focus:border-primary text-sm">
      </div>

      <div class="space-y-1.5">
        <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Your Side <span class="text-slate-400 font-normal lowercase">(optional)</span></label>
        <select name="uploader_side" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-3 focus:ring-primary focus:border-primary text-sm appearance-none">
          <option value="">Not selected</option>
          <option value="bride">Bride's Side</option>
          <option value="groom">Groom's Side</option>
          <option value="family">Family</option>
          <option value="friend">Friend</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="space-y-1.5">
        <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Security Check: <%= captchaQuestion %></label>
        <input name="captcha" type="number" required placeholder="Answer" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-3 focus:ring-primary focus:border-primary text-sm">
      </div>
    </div>

    <!-- Upload Progress -->
    <div id="progressWrap" class="hidden space-y-1.5">
      <div class="flex justify-between text-xs font-semibold text-primary">
        <span>Uploading...</span>
        <span id="progressText">0%</span>
      </div>
      <div class="w-full bg-primary/10 h-2 rounded-full overflow-hidden">
        <div id="progressBar" class="bg-gradient-wedding h-full rounded-full" style="width: 0%"></div>
      </div>
    </div>

    <!-- Submit Button -->
    <button id="submitBtn" class="w-full bg-gradient-wedding text-white px-6 py-4 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all" type="submit">
      Upload Memories
    </button>
    
    <div id="resultBox" aria-live="polite" class="space-y-3"></div>
  </form>

  <p class="text-slate-400 text-center text-xs leading-relaxed max-w-sm mx-auto">
    Privacy Notice: Your uploads are private. They will only be displayed once approved by the host.
  </p>
</section>

<script>
  const form = document.getElementById('uploadForm');
  const fileInput = document.getElementById('fileInput');
  const fileList = document.getElementById('fileList');
  const resultBox = document.getElementById('resultBox');
  const submitBtn = document.getElementById('submitBtn');
  const progressWrap = document.getElementById('progressWrap');
  const progressBar = document.getElementById('progressBar');
  const progressText = document.getElementById('progressText');
  const dropZone = document.getElementById('dropZone');
  const csrf = document.querySelector('meta[name="csrf-token"]').content;

  function human(bytes) {
    if (bytes < 1024) return bytes + ' B';
    const units = ['KB','MB','GB']; let value = bytes / 1024; let unit = units[0];
    for (let i = 1; i < units.length && value >= 1024; i++) { value /= 1024; unit = units[i]; }
    return value.toFixed(value >= 10 ? 1 : 2) + ' ' + unit;
  }

  function renderFiles() {
    const files = Array.from(fileInput.files || []);
    if (!files.length) { fileList.textContent = ''; return; }
    const total = files.reduce((s, f) => s + f.size, 0);
    fileList.textContent = files.length + ' file(s) selected · ' + human(total);
  }

  fileInput.addEventListener('change', renderFiles);
  
  // Trigger file input click when drop zone is clicked
  dropZone.addEventListener('click', (e) => {
    if (e.target !== fileInput && !e.target.closest('button')) {
      fileInput.click();
    }
  });

  ['dragenter','dragover'].forEach(evt => dropZone.addEventListener(evt, (e) => { e.preventDefault(); dropZone.classList.add('bg-primary/10'); }));
  ['dragleave','drop'].forEach(evt => dropZone.addEventListener(evt, (e) => { e.preventDefault(); dropZone.classList.remove('bg-primary/10'); }));
  dropZone.addEventListener('drop', (e) => { fileInput.files = e.dataTransfer.files; renderFiles(); });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    resultBox.innerHTML = '';
    if (!fileInput.files.length) {
      resultBox.innerHTML = '<div class="p-4 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm font-semibold">Please select at least one photo/video.</div>';
      return;
    }

    const xhr = new XMLHttpRequest();
    xhr.open('POST', form.action);
    xhr.setRequestHeader('X-CSRF-Token', csrf);
    xhr.setRequestHeader('Accept', 'application/json');
    xhr.upload.onprogress = (event) => {
      if (event.lengthComputable) {
        const pct = Math.round((event.loaded / event.total) * 100);
        progressBar.style.width = pct + '%';
        progressText.textContent = pct + '%';
      }
    };
    xhr.onload = () => {
      submitBtn.disabled = false;
      progressWrap.style.display = 'none';
      let data = null;
      try { data = JSON.parse(xhr.responseText); } catch {}
      if (xhr.status >= 200 && xhr.status < 300 && data && data.ok) {
        const accepted = data.accepted || [];
        const skipped = data.skipped || [];
        const rejected = data.rejected || [];
        resultBox.innerHTML = '<div class="p-4 bg-green-50 text-green-700 border border-green-200 rounded-lg text-sm font-semibold">✅ Upload complete. ' + accepted.length + ' file(s) pending approval.</div>' +
          (skipped.length ? '<div class="p-4 bg-yellow-50 text-yellow-700 border border-yellow-200 rounded-lg text-sm">Skipped duplicates: ' + skipped.map(x => x.name).join(', ') + '</div>' : '') +
          (rejected.length ? '<div class="p-4 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm">Rejected: ' + rejected.map(x => x.name + ' (' + x.reason + ')').join(', ') + '</div>' : '');
        form.reset(); renderFiles(); progressBar.style.width = '0%'; progressText.textContent = '0%';
      } else {
        resultBox.innerHTML = '<div class="p-4 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm font-semibold">' + ((data && data.error) || 'Upload failed. Please try again.') + '</div>';
      }
    };
    xhr.onerror = () => {
      submitBtn.disabled = false;
      progressWrap.style.display = 'none';
      resultBox.innerHTML = '<div class="p-4 bg-red-50 text-red-700 border border-red-200 rounded-lg text-sm font-semibold">Network error. Please try again.</div>';
    };
    submitBtn.disabled = true;
    progressWrap.style.display = 'block';
    xhr.send(new FormData(form));
  });
  renderFiles();
</script>
