<section class="max-w-3xl mx-auto py-8 space-y-8 animate-fadein">
  <!-- Wedding Header -->
  <div class="glass-card text-center p-8 rounded-2xl border border-primary/10 bg-white/70 backdrop-blur-xl space-y-3">
    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary/10 rounded-full text-primary text-xs font-bold shadow-sm border border-primary/15">
      ✨ Guest Wedding Portal
    </span>
    <h1 class="font-headline text-4xl sm:text-5xl font-bold text-primary leading-none tracking-tight"><%= event.title %></h1>
    <% if (event.bride_name && event.groom_name) { %>
      <p class="text-slate-500 text-lg font-semibold"><%= event.bride_name %> & <%= event.groom_name %></p>
    <% } %>
    <% if (event.wedding_date) { %>
      <p class="text-slate-400 text-sm">
        <span class="material-symbols-outlined text-sm align-middle">calendar_month</span>
        <%= helpers.formatDate(event.wedding_date) %>
        <% if (event.venue) { %> · <span class="material-symbols-outlined text-sm align-middle">location_on</span> <%= event.venue %><% } %>
      </p>
    <% } %>
    <p class="text-slate-500 text-sm leading-relaxed max-w-lg mx-auto">
      Upload your candid photos and videos here. Once approved by the host, they will appear in the shared gallery.
    </p>
    <div class="max-w-md mx-auto pt-4">
      <div class="flex justify-between text-xs font-semibold text-slate-500 mb-1.5">
        <span>Album Storage</span>
        <span><%= storage.usedHuman %> / <%= storage.limitHuman %></span>
      </div>
      <div class="w-full bg-primary/10 h-2.5 rounded-full overflow-hidden">
        <div class="bg-gradient-wedding h-full rounded-full transition-all duration-700" style="width: <%= storage.percent %>%"></div>
      </div>
    </div>
  </div>

  <!-- Upload Form -->
  <form id="uploadForm" class="glass-card p-8 rounded-2xl border border-primary/10 bg-white/70 backdrop-blur-xl space-y-6" method="post" enctype="multipart/form-data" action="/e/<%= event.slug %>/upload?token=<%= encodeURIComponent(uploadToken) %>">
    <input type="hidden" name="token" value="<%= uploadToken %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <!-- Honeypot trap: invisible to humans, bots auto-fill it -->
    <div style="position:absolute;left:-9999px;opacity:0;height:0;overflow:hidden" aria-hidden="true" tabindex="-1">
      <label for="website_url">Leave this empty</label>
      <input type="text" name="website_url" id="website_url" value="" autocomplete="off" tabindex="-1">
    </div>

    <!-- Upload Dropzone -->
    <div id="dropZone" class="group relative flex flex-col items-center justify-center border-2 border-dashed border-primary/20 rounded-2xl p-10 bg-gradient-to-b from-primary/5 to-transparent hover:border-primary/40 transition-all cursor-pointer active:scale-[0.99]">
      <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center text-primary shadow-md mb-4 group-hover:scale-110 transition-all">
        <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">add_a_photo</span>
      </div>
      <span class="bg-gradient-wedding text-white px-6 py-2.5 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all">
        Select Photos/Videos
      </span>
      <p class="mt-4 text-xs text-slate-400">Drag & drop here, click to browse, or use camera</p>
      <p class="mt-1 text-[10px] text-slate-400 font-semibold uppercase tracking-wider">JPG, PNG, WEBP, HEIC, MP4, MOV supported</p>
      
      <input id="fileInput" type="file" name="media" multiple accept="image/jpeg,image/png,image/webp,image/heic,image/heif,video/mp4,video/quicktime,video/webm,.jpg,.jpeg,.png,.webp,.heic,.heif,.mp4,.mov,.webm" class="hidden">
    </div>

    <!-- Camera Capture (Mobile) -->
    <div class="flex gap-3 -mt-3">
      <button type="button" id="cameraBtn" class="flex-1 flex items-center justify-center gap-2 px-4 py-3 bg-white border border-primary/15 rounded-xl text-primary font-bold text-sm hover:bg-primary/5 transition-all">
        <span class="material-symbols-outlined text-lg">photo_camera</span> Take Photo
      </button>
      <input id="cameraInput" type="file" accept="image/*" capture="environment" class="hidden">
    </div>

    <!-- File Preview Grid -->
    <div id="previewGrid" class="hidden grid grid-cols-3 sm:grid-cols-4 gap-3"></div>
    <div id="fileCount" class="hidden text-center text-xs font-bold text-primary"></div>

    <!-- Optional Form Fields (collapsed by default on mobile) -->
    <details class="group">
      <summary class="flex items-center gap-2 cursor-pointer text-sm font-bold text-primary hover:text-primary/70 transition-colors select-none">
        <span class="material-symbols-outlined text-sm transition-transform group-open:rotate-90">chevron_right</span>
        Optional Details
      </summary>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
        <div class="space-y-1.5">
          <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Ceremony</label>
          <select name="folder_id" required class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-3 focus:ring-primary focus:border-primary text-sm appearance-none">
            <% folders.forEach((folder) => { %>
              <option value="<%= folder.id %>"><%= folder.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="space-y-1.5">
          <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Your Name</label>
          <input name="uploader_name" id="uploaderName" maxlength="80" placeholder="e.g. Priya Sharma" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-3 focus:ring-primary focus:border-primary text-sm">
        </div>

        <div class="space-y-1.5">
          <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Your Side</label>
          <select name="uploader_side" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-3 focus:ring-primary focus:border-primary text-sm appearance-none">
            <option value="">Not selected</option>
            <option value="bride">Bride's Side</option>
            <option value="groom">Groom's Side</option>
            <option value="family">Family</option>
            <option value="friend">Friend</option>
            <option value="other">Other</option>
          </select>
        </div>
      </div>
    </details>

    <!-- Upload Progress Area (per-file progress) -->
    <div id="progressArea" class="hidden space-y-3">
      <div class="flex justify-between items-center text-sm">
        <span class="font-bold text-primary flex items-center gap-2">
          <span class="material-symbols-outlined text-lg animate-spin">progress_activity</span>
          Uploading...
        </span>
        <span id="progressText" class="font-bold text-primary">0%</span>
      </div>
      <div class="w-full bg-primary/10 h-3 rounded-full overflow-hidden">
        <div id="progressBar" class="bg-gradient-wedding h-full rounded-full transition-all duration-300" style="width: 0%"></div>
      </div>
      <p id="progressDetail" class="text-xs text-slate-400 text-center"></p>
    </div>

    <!-- Submit Button -->
    <button id="submitBtn" class="w-full bg-gradient-wedding text-white px-6 py-4 rounded-full font-bold text-base shadow-lg hover:shadow-xl hover:scale-[1.01] active:scale-[0.99] transition-all flex items-center justify-center gap-2" type="submit">
      <span class="material-symbols-outlined">cloud_upload</span>
      Upload Memories
    </button>
    
    <!-- Result Messages -->
    <div id="resultBox" aria-live="polite" class="space-y-3"></div>
  </form>

  <!-- Success Screen (hidden initially) -->
  <div id="successScreen" class="hidden glass-card p-10 rounded-2xl border border-green-200 bg-green-50/70 backdrop-blur-xl text-center space-y-6 animate-fadein">
    <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center mx-auto">
      <span class="material-symbols-outlined text-4xl text-green-600" style="font-variation-settings: 'FILL' 1;">check_circle</span>
    </div>
    <h2 class="font-headline text-3xl font-bold text-green-800">Thank You! 🎉</h2>
    <p class="text-green-700 max-w-md mx-auto">Your photos/videos have been submitted. They'll appear in the gallery once approved by the host.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center pt-2">
      <button id="uploadMoreBtn" class="bg-gradient-wedding text-white px-8 py-3 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all flex items-center gap-2 justify-center">
        <span class="material-symbols-outlined text-lg">add_a_photo</span> Upload More
      </button>
      <a href="/e/<%= event.slug %>/gallery" class="border border-primary/20 bg-white hover:bg-primary/5 text-primary px-8 py-3 rounded-full font-bold text-sm shadow-md transition-all flex items-center gap-2 justify-center">
        <span class="material-symbols-outlined text-lg">photo_library</span> View Gallery
      </a>
    </div>
  </div>

  <p class="text-slate-400 text-center text-xs leading-relaxed max-w-sm mx-auto">
    Privacy Notice: Your uploads are private. They will only be displayed once approved by the host.
  </p>
</section>

<!-- Confetti Library (tiny, 3KB gzipped) -->
<script>
// Minimal confetti implementation
const Confetti={launch(t=200){const c=document.createElement('canvas');Object.assign(c.style,{position:'fixed',top:0,left:0,width:'100%',height:'100%',pointerEvents:'none',zIndex:9999});document.body.appendChild(c);const ctx=c.getContext('2d');c.width=window.innerWidth;c.height=window.innerHeight;const particles=[];const colors=['#b83280','#ff7a59','#c58a13','#059669','#2563eb','#ec4899','#f59e0b'];for(let i=0;i<t;i++){particles.push({x:c.width/2,y:c.height/2,vx:(Math.random()-.5)*20,vy:Math.random()*-16-4,w:Math.random()*8+4,h:Math.random()*6+3,color:colors[Math.floor(Math.random()*colors.length)],rotation:Math.random()*360,rotSpeed:(Math.random()-.5)*10,gravity:.35,opacity:1});}let frame=0;function draw(){ctx.clearRect(0,0,c.width,c.height);let alive=0;particles.forEach(p=>{p.vy+=p.gravity;p.x+=p.vx;p.y+=p.vy;p.rotation+=p.rotSpeed;p.vx*=.99;p.opacity=Math.max(0,p.opacity-.004);if(p.opacity>0)alive++;ctx.save();ctx.translate(p.x,p.y);ctx.rotate(p.rotation*Math.PI/180);ctx.globalAlpha=p.opacity;ctx.fillStyle=p.color;ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);ctx.restore();});frame++;if(alive>0&&frame<300){requestAnimationFrame(draw);}else{c.remove();}}draw();}};
</script>

<script>
  const form = document.getElementById('uploadForm');
  const fileInput = document.getElementById('fileInput');
  const cameraBtn = document.getElementById('cameraBtn');
  const cameraInput = document.getElementById('cameraInput');
  const previewGrid = document.getElementById('previewGrid');
  const fileCount = document.getElementById('fileCount');
  const resultBox = document.getElementById('resultBox');
  const submitBtn = document.getElementById('submitBtn');
  const progressArea = document.getElementById('progressArea');
  const progressBar = document.getElementById('progressBar');
  const progressText = document.getElementById('progressText');
  const progressDetail = document.getElementById('progressDetail');
  const dropZone = document.getElementById('dropZone');
  const successScreen = document.getElementById('successScreen');
  const uploadMoreBtn = document.getElementById('uploadMoreBtn');
  const uploaderName = document.getElementById('uploaderName');
  const csrf = document.querySelector('meta[name="csrf-token"]').content;

  // Persist guest name in localStorage so they don't have to re-enter
  const STORAGE_KEY = 'shaadishots_guest_<%= event.slug %>';
  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved) {
      const data = JSON.parse(saved);
      if (data.name) uploaderName.value = data.name;
    }
  } catch {}

  uploaderName.addEventListener('blur', () => {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({ name: uploaderName.value }));
    } catch {}
  });

  // Collect files from multiple inputs
  let selectedFiles = [];

  function human(bytes) {
    if (bytes < 1024) return bytes + ' B';
    const units = ['KB','MB','GB']; let value = bytes / 1024; let unit = units[0];
    for (let i = 1; i < units.length && value >= 1024; i++) { value /= 1024; unit = units[i]; }
    return value.toFixed(value >= 10 ? 1 : 2) + ' ' + unit;
  }

  function renderPreviews() {
    previewGrid.innerHTML = '';
    if (selectedFiles.length === 0) {
      previewGrid.classList.add('hidden');
      fileCount.classList.add('hidden');
      return;
    }
    previewGrid.classList.remove('hidden');
    fileCount.classList.remove('hidden');

    const total = selectedFiles.reduce((s, f) => s + f.size, 0);
    fileCount.textContent = selectedFiles.length + ' file(s) selected · ' + human(total);

    selectedFiles.forEach((file, idx) => {
      const card = document.createElement('div');
      card.className = 'relative aspect-square rounded-xl overflow-hidden border border-primary/10 bg-slate-100 group';

      if (file.type.startsWith('image/')) {
        const img = document.createElement('img');
        img.className = 'w-full h-full object-cover';
        img.src = URL.createObjectURL(file);
        img.onload = () => URL.revokeObjectURL(img.src);
        card.appendChild(img);
      } else {
        const vidWrap = document.createElement('div');
        vidWrap.className = 'w-full h-full flex items-center justify-center bg-slate-800';
        vidWrap.innerHTML = '<span class="material-symbols-outlined text-3xl text-white" style="font-variation-settings: \'FILL\' 1;">videocam</span>';
        card.appendChild(vidWrap);
      }

      // Remove button
      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'absolute top-1 right-1 w-6 h-6 rounded-full bg-red-500 text-white flex items-center justify-center text-xs font-bold opacity-0 group-hover:opacity-100 transition-opacity shadow-md';
      removeBtn.innerHTML = '×';
      removeBtn.onclick = () => {
        selectedFiles.splice(idx, 1);
        renderPreviews();
      };
      card.appendChild(removeBtn);

      // File name overlay
      const label = document.createElement('div');
      label.className = 'absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-2';
      label.innerHTML = '<p class="text-[10px] text-white truncate font-medium">' + file.name + '</p>';
      card.appendChild(label);

      previewGrid.appendChild(card);
    });
  }

  function compressImage(file, maxWidth = 2000, maxHeight = 2000, quality = 0.85) {
    return new Promise((resolve) => {
      if (!file.type.startsWith('image/') || file.type === 'image/gif') {
        return resolve(file);
      }
      
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          let width = img.width;
          let height = img.height;
          if (width > height) {
            if (width > maxWidth) {
              height = Math.round((height * maxWidth) / width);
              width = maxWidth;
            }
          } else {
            if (height > maxHeight) {
              width = Math.round((width * maxHeight) / height);
              height = maxHeight;
            }
          }
          
          const canvas = document.createElement('canvas');
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, width, height);
          
          canvas.toBlob((blob) => {
            if (!blob) return resolve(file);
            let newName = file.name;
            if (!newName.toLowerCase().endsWith('.jpg') && !newName.toLowerCase().endsWith('.jpeg')) {
              newName = newName.replace(/\.[^/.]+$/, "") + ".jpg";
            }
            const compressedFile = new File([blob], newName, {
              type: 'image/jpeg',
              lastModified: Date.now()
            });
            resolve(compressedFile.size < file.size ? compressedFile : file);
          }, 'image/jpeg', quality);
        };
        img.onerror = () => resolve(file);
        img.src = e.target.result;
      };
      reader.onerror = () => resolve(file);
      reader.readAsDataURL(file);
    });
  }

  async function addFiles(fileList) {
    const arr = Array.from(fileList || []);
    if (!arr.length) return;

    submitBtn.disabled = true;
    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">progress_activity</span> Optimizing images...';

    for (const f of arr) {
      if (selectedFiles.some(existing => existing.name === f.name && existing.size === f.size)) {
        continue;
      }
      
      let fileToPush = f;
      if (f.type.startsWith('image/') && f.type !== 'image/gif') {
        try {
          fileToPush = await compressImage(f);
        } catch (e) {
          console.error('Compression failed, using original:', e);
        }
      }
      selectedFiles.push(fileToPush);
    }

    submitBtn.disabled = false;
    submitBtn.innerHTML = originalText;
    renderPreviews();
  }

  fileInput.addEventListener('change', () => addFiles(fileInput.files));

  // Camera capture: add to same list
  cameraBtn.addEventListener('click', () => cameraInput.click());
  cameraInput.addEventListener('change', () => {
    addFiles(cameraInput.files);
    cameraInput.value = '';
  });

  // Dropzone click
  dropZone.addEventListener('click', (e) => {
    if (e.target !== fileInput && !e.target.closest('button')) {
      fileInput.click();
    }
  });

  // Drag and drop
  ['dragenter','dragover'].forEach(evt => dropZone.addEventListener(evt, (e) => {
    e.preventDefault();
    dropZone.classList.add('border-primary', 'bg-primary/10', 'scale-[1.01]');
  }));
  ['dragleave','drop'].forEach(evt => dropZone.addEventListener(evt, (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-primary', 'bg-primary/10', 'scale-[1.01]');
  }));
  dropZone.addEventListener('drop', (e) => addFiles(e.dataTransfer.files));

  // Upload More button
  uploadMoreBtn.addEventListener('click', () => {
    successScreen.classList.add('hidden');
    form.classList.remove('hidden');
    form.reset();
    selectedFiles = [];
    renderPreviews();
    progressBar.style.width = '0%';
    progressText.textContent = '0%';
    resultBox.innerHTML = '';
    // Restore saved name
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const data = JSON.parse(saved);
        if (data.name) uploaderName.value = data.name;
      }
    } catch {}
  });

  // Form submission with XHR for real progress
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    resultBox.innerHTML = '';

    if (selectedFiles.length === 0) {
      resultBox.innerHTML = '<div class="p-4 bg-red-50 text-red-700 border border-red-200 rounded-xl text-sm font-semibold flex items-center gap-2"><span class="material-symbols-outlined">error</span> Please select at least one photo/video.</div>';
      return;
    }

    // Build FormData with our collected files
    const fd = new FormData(form);
    // Remove any files that were in the input (we manage our own list)
    fd.delete('media');
    selectedFiles.forEach(f => fd.append('media', f));

    // Save guest name
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({ name: uploaderName.value }));
    } catch {}

    const xhr = new XMLHttpRequest();
    xhr.open('POST', form.action);
    xhr.setRequestHeader('X-CSRF-Token', csrf);
    xhr.setRequestHeader('Accept', 'application/json');

    xhr.upload.onprogress = (event) => {
      if (event.lengthComputable) {
        const pct = Math.round((event.loaded / event.total) * 100);
        progressBar.style.width = pct + '%';
        progressText.textContent = pct + '%';
        progressDetail.textContent = human(event.loaded) + ' of ' + human(event.total) + ' uploaded';
      }
    };

    xhr.onload = () => {
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span class="material-symbols-outlined">cloud_upload</span> Upload Memories';
      let data = null;
      try { data = JSON.parse(xhr.responseText); } catch {}
      
      if (xhr.status >= 200 && xhr.status < 300 && data && data.ok) {
        const accepted = data.accepted || [];
        const skipped = data.skipped || [];
        const rejected = data.rejected || [];

        // Show success screen with confetti
        form.classList.add('hidden');
        progressArea.classList.add('hidden');
        successScreen.classList.remove('hidden');
        successScreen.scrollIntoView({ behavior: 'smooth', block: 'center' });
        
        // Launch confetti celebration! 🎉
        Confetti.launch(150);

        // Show details below success screen if needed
        if (skipped.length || rejected.length) {
          let detailHtml = '';
          if (skipped.length) {
            detailHtml += '<div class="p-3 bg-yellow-50 text-yellow-700 border border-yellow-200 rounded-xl text-xs">Skipped duplicates: ' + skipped.map(x => x.name).join(', ') + '</div>';
          }
          if (rejected.length) {
            detailHtml += '<div class="p-3 bg-red-50 text-red-700 border border-red-200 rounded-xl text-xs">Rejected: ' + rejected.map(x => x.name + ' (' + x.reason + ')').join(', ') + '</div>';
          }
          successScreen.insertAdjacentHTML('beforeend', '<div class="space-y-2 mt-4">' + detailHtml + '</div>');
        }

        form.reset();
        selectedFiles = [];
        renderPreviews();
        progressBar.style.width = '0%';
        progressText.textContent = '0%';
        progressDetail.textContent = '';
      } else {
        progressArea.classList.add('hidden');
        resultBox.innerHTML = '<div class="p-4 bg-red-50 text-red-700 border border-red-200 rounded-xl text-sm font-semibold flex items-center gap-2"><span class="material-symbols-outlined">error</span> ' + ((data && data.error) || 'Upload failed. Please try again.') + '</div>';
      }
    };

    xhr.onerror = () => {
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span class="material-symbols-outlined">cloud_upload</span> Upload Memories';
      progressArea.classList.add('hidden');
      resultBox.innerHTML = '<div class="p-4 bg-red-50 text-red-700 border border-red-200 rounded-xl text-sm font-semibold flex items-center gap-2"><span class="material-symbols-outlined">wifi_off</span> Network error. Check your connection and try again.</div>';
    };

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">progress_activity</span> Uploading...';
    progressArea.classList.remove('hidden');
    xhr.send(fd);
  });

  renderPreviews();
</script>
