<!-- Modernized Contact & Support Page -->
<section class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start max-w-5xl mx-auto py-12 px-4 sm:px-6">
  
  <div class="space-y-6">
    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-primary/10 rounded-full text-primary text-xs font-bold shadow-sm border border-primary/20">
      ✉️ Support Center
    </span>
    <h1 class="font-headline text-4xl sm:text-5xl font-black text-slate-900 leading-tight">
      Get in touch with our team
    </h1>
    <p class="text-slate-600 text-sm sm:text-base leading-relaxed">
      Need help setting up your wedding QR code, have questions about our premium plans, or want to discuss enterprise white-label solutions? Send us a message and our support team will respond within a few hours.
    </p>

    <!-- Support Methods Bento Cards -->
    <div class="space-y-4 pt-4">
      <div class="glass-card p-5 rounded-2xl border border-primary/10 bg-white/60 flex items-center gap-4 hover:shadow-md transition-all">
        <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center text-xl font-bold">✉</div>
        <div>
          <span class="text-[10px] uppercase font-bold text-primary tracking-widest block">Email Support</span>
          <strong class="text-slate-800 text-sm sm:text-base"><a href="mailto:support@shaadishots.com" class="hover:underline">support@shaadishots.com</a></strong>
        </div>
      </div>
      
      <div class="glass-card p-5 rounded-2xl border border-primary/10 bg-white/60 flex items-center gap-4 hover:shadow-md transition-all">
        <div class="w-12 h-12 rounded-xl bg-green-50 text-green-600 flex items-center justify-center text-xl font-bold">💬</div>
        <div>
          <span class="text-[10px] uppercase font-bold text-green-600 tracking-widest block">Live WhatsApp Support</span>
          <strong class="text-slate-800 text-sm sm:text-base">Available in Owner Dashboard</strong>
        </div>
      </div>
    </div>
  </div>

  <!-- Contact Form -->
  <form class="glass-card p-8 rounded-3xl border border-primary/10 bg-white/70 backdrop-blur-xl space-y-5 shadow-lg" method="post" action="/contact" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    
    <div class="space-y-1">
      <h2 class="font-headline text-2xl font-bold text-slate-800">Send Message</h2>
      <p class="text-xs text-slate-400 font-semibold">Fill out the form below and we will get back to you.</p>
    </div>
    
    <div class="space-y-4">
      <div class="space-y-1.5">
        <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Your Name</label>
        <input type="text" name="name" value="<%= currentUser ? currentUser.name : (values.name || '') %>" required placeholder="E.g. Rohan Sharma" <%= currentUser ? 'readonly' : '' %> class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-2.5 focus:ring-primary focus:border-primary text-sm">
        <% if (errors.name) { %><span class="text-xs text-red-600 font-semibold"><%= errors.name[0] %></span><% } %>
      </div>

      <div class="space-y-1.5">
        <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Email Address</label>
        <input type="email" name="email" value="<%= currentUser ? currentUser.email : (values.email || '') %>" required placeholder="E.g. rohan@gmail.com" <%= currentUser ? 'readonly' : '' %> class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-2.5 focus:ring-primary focus:border-primary text-sm">
        <% if (errors.email) { %><span class="text-xs text-red-600 font-semibold"><%= errors.email[0] %></span><% } %>
      </div>

      <div class="space-y-1.5">
        <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Subject</label>
        <input type="text" name="subject" value="<%= values.subject || '' %>" required placeholder="E.g. Plan upgrade inquiry" maxlength="150" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-2.5 focus:ring-primary focus:border-primary text-sm">
        <% if (errors.subject) { %><span class="text-xs text-red-600 font-semibold"><%= errors.subject[0] %></span><% } %>
      </div>

      <div class="space-y-1.5">
        <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Message</label>
        <textarea name="message" rows="5" required placeholder="Describe your query in detail..." maxlength="1000" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-2.5 focus:ring-primary focus:border-primary text-sm"><%= values.message || '' %></textarea>
        <% if (errors.message) { %><span class="text-xs text-red-600 font-semibold"><%= errors.message[0] %></span><% } %>
      </div>

      <button class="w-full bg-gradient-wedding text-white px-6 py-3.5 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all" type="submit">Send Message</button>
    </div>
  </form>
</section>
