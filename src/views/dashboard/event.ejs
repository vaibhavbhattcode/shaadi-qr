<section class="between">
  <div>
    <span class="badge"><%= stats.planLabel %></span>
    <h1 style="margin:10px 0 4px; letter-spacing:-.04em;"><%= event.title %></h1>
    <p class="muted"><%= event.venue || 'Venue not set' %> <%= event.city ? `· ${event.city}` : '' %> <%= event.wedding_date ? `· ${event.wedding_date}` : '' %></p>
  </div>
  <div class="row">
    <a class="btn secondary" href="/dashboard">Dashboard</a>
    <a class="btn" href="/dashboard/events/<%= event.id %>/media">Review media</a>
  </div>
</section>

<section class="grid grid-4" style="margin-top:22px;">
  <div class="metric"><div class="num"><%= stats.counts.pending %></div><div class="muted">Pending</div></div>
  <div class="metric"><div class="num"><%= stats.counts.approved %></div><div class="muted">Approved</div></div>
  <div class="metric"><div class="num"><%= stats.counts.rejected %></div><div class="muted">Rejected</div></div>
  <div class="metric"><div class="num"><%= stats.counts.total %></div><div class="muted">Total uploads</div></div>
</section>

<section class="grid grid-2" style="margin-top:22px; align-items:start;">
  <div class="card">
    <div class="between">
      <div>
        <h2 style="margin:0 0 6px;">Upload QR</h2>
        <p class="muted">Is QR ko print karke venue par lagao ya WhatsApp group me share karo.</p>
      </div>
      <span class="badge <%= event.upload_enabled ? 'approved' : 'rejected' %>"><%= event.upload_enabled ? 'Uploads open' : 'Uploads closed' %></span>
    </div>
    <div style="display:grid; place-items:center; padding:16px;">
      <img src="<%= qrDataUrl %>" alt="Upload QR" style="max-width:280px; width:100%; border-radius:18px; border:1px solid var(--border); background:white; padding:10px;">
    </div>
    <div class="copy-box">
      <input readonly id="uploadLink" value="<%= uploadLink %>">
      <button class="btn secondary" type="button" onclick="copyValue('uploadLink')">Copy</button>
    </div>
    <div class="row" style="margin-top:12px;">
      <a class="btn small" href="/dashboard/events/<%= event.id %>/qr.png?download=1">Download QR PNG</a>
      <a class="btn small secondary" target="_blank" href="/dashboard/events/<%= event.id %>/poster">Printable poster</a>
      <a class="btn small secondary" target="_blank" href="/e/<%= event.slug %>/upload?token=<%= encodeURIComponent(event.upload_token) %>">Test upload</a>
    </div>
  </div>

  <div class="card">
    <h2 style="margin-top:0;">Storage</h2>
    <div class="between"><span class="hint">Used storage</span><span class="hint"><%= stats.usedHuman %> / <%= stats.limitHuman %></span></div>
    <div class="progress"><span style="width:<%= stats.percent %>%"></span></div>
    <div class="grid grid-2" style="margin-top:16px;">
      <div class="metric"><div class="num"><%= stats.percent %>%</div><div class="muted">Quota used</div></div>
      <div class="metric" style="display:flex; flex-direction:column; justify-content:space-between; align-items:start; min-height:100px;">
        <div>
          <div class="num" style="line-height:1.2;"><%= stats.planLabel %></div>
          <div class="muted">Current plan</div>
        </div>
        <a class="btn small" href="/dashboard/events/<%= event.id %>/upgrade" style="margin-top:10px; width:100%; text-align:center;">Upgrade Plan</a>
      </div>
    </div>
    <div class="divider"></div>
    <h3>Gallery link</h3>
    <div class="copy-box">
      <input readonly id="galleryLink" value="<%= galleryLink %>">
      <button class="btn secondary" type="button" onclick="copyValue('galleryLink')">Copy</button>
    </div>
    <div class="row" style="margin-top:12px;">
      <a class="btn small secondary" target="_blank" href="/e/<%= event.slug %>/gallery">Open gallery</a>
      <a class="btn small secondary" href="/dashboard/events/<%= event.id %>/download.zip?status=approved">Download approved ZIP</a>
    </div>
  </div>
</section>

<section class="grid grid-2" style="margin-top:22px; align-items:start;">
  <form class="card grid" method="post" action="/dashboard/events/<%= event.id %>/settings" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <h2 style="margin:0;">Event settings</h2>
    <label>Wedding title
      <input name="title" value="<%= event.title || '' %>" maxlength="120" required>
      <% if (errors.title) { %><span class="error-text"><%= errors.title[0] %></span><% } %>
    </label>
    <div class="grid grid-2">
      <label>Bride name
        <input name="bride_name" value="<%= event.bride_name || '' %>" maxlength="80">
      </label>
      <label>Groom name
        <input name="groom_name" value="<%= event.groom_name || '' %>" maxlength="80">
      </label>
    </div>
    <div class="grid grid-2">
      <label>Date
        <input type="date" name="wedding_date" value="<%= event.wedding_date || '' %>">
      </label>
      <label>City
        <input name="city" value="<%= event.city || '' %>" maxlength="80">
      </label>
    </div>
    <label>Venue
      <input name="venue" value="<%= event.venue || '' %>" maxlength="160">
    </label>
    <div class="grid grid-3">
      <label class="row" style="font-weight:800;"><input style="width:auto" type="checkbox" name="upload_enabled" <%= event.upload_enabled ? 'checked' : '' %>> Uploads open</label>
      <label class="row" style="font-weight:800;"><input style="width:auto" type="checkbox" name="gallery_enabled" <%= event.gallery_enabled ? 'checked' : '' %>> Gallery enabled</label>
      <label class="row" style="font-weight:800;"><input style="width:auto" type="checkbox" name="public_download_enabled" <%= event.public_download_enabled ? 'checked' : '' %>> Public ZIP download</label>
    </div>
    <label>Gallery PIN <span class="hint">optional</span>
      <input name="gallery_pin" inputmode="numeric" pattern="[0-9]{4,12}" maxlength="12" placeholder="Set new PIN, e.g. 1234">
      <span class="hint"><%= event.gallery_pin_hash ? 'PIN is currently enabled.' : 'No PIN set. Gallery can be opened by link if enabled.' %></span>
    </label>
    <% if (event.gallery_pin_hash) { %>
      <label class="row" style="font-weight:800;"><input style="width:auto" type="checkbox" name="clear_pin"> Clear existing PIN</label>
    <% } %>
    <button class="btn" type="submit">Save settings</button>
  </form>

  <div class="card">
    <div class="between">
      <div>
        <h2 style="margin:0;">Folders</h2>
        <p class="muted">Guests upload ke time folder choose karenge.</p>
      </div>
    </div>
    <div class="grid" style="margin-top:14px;">
      <% folders.forEach((folder) => { %>
        <div class="between metric">
          <strong><%= folder.name %></strong>
          <form method="post" action="/dashboard/events/<%= event.id %>/folders/<%= folder.id %>/delete" onsubmit="return confirm('Delete this folder? It must be empty.')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn small danger" type="submit">Delete</button>
          </form>
        </div>
      <% }) %>
    </div>
    <form method="post" action="/dashboard/events/<%= event.id %>/folders" class="row" style="margin-top:16px;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input name="name" maxlength="50" placeholder="New folder name" style="flex:1; min-width:200px;">
      <button class="btn secondary" type="submit">Add folder</button>
    </form>
  </div>
</section>

<section class="grid grid-2" style="margin-top:22px; align-items:start;">
  <div class="card">
    <h2 style="margin-top:0;">Storage Integrations</h2>
    <p class="muted" style="margin-bottom:20px;">Apne guest uploads ka storage location select karein. Basic plan users apna Google Drive connect karke free unlimited hosting enable kar sakte hain.</p>
    
    <div class="info-list">
      <div style="flex-direction: column; align-items: flex-start; gap: 8px; margin-bottom: 16px; display: flex;">
        <div class="between" style="width: 100%;">
          <strong>Platform Secure Cloud</strong>
          <% if (event.storage_provider === 'platform') { %>
            <span class="badge approved">Active</span>
          <% } else { %>
            <span class="badge secondary">Available</span>
          <% } %>
        </div>
        <p class="hint" style="margin: 0;">Wedding images are stored securely on ShaadiShots cloud servers. Isolation: <code class="mono" style="font-size: 0.85em;">events/<%= event.id %>/*</code></p>
      </div>

      <div style="flex-direction: column; align-items: flex-start; gap: 8px; border-top: 1px solid var(--border); padding-top: 16px; margin-bottom: 16px; display: flex;">
        <div class="between" style="width: 100%;">
          <strong>Google Drive</strong>
          <% if (event.storage_provider === 'google_drive') { %>
            <span class="badge approved">Active (Connected)</span>
          <% } else { %>
            <span class="badge secondary">Available</span>
          <% } %>
        </div>
        <p class="hint" style="margin: 0; margin-bottom: 10px;">Store wedding images directly in your own Google Drive. No premium subscription required.</p>
        
        <% if (event.storage_provider === 'google_drive') { %>
          <% const configData = JSON.parse(event.storage_config || '{}'); %>
          <div class="alert success" style="margin: 0; width: 100%; box-sizing: border-box;">
            <p class="hint" style="margin: 0; color: var(--green); font-weight: bold;">
              🟢 <%= configData.mock ? 'Sandbox Mock Drive Connected' : 'Google Drive Account Connected' %>
            </p>
            <p class="hint" style="margin: 4px 0 0;">
              Guest uploads are being saved to your Google Drive securely.
            </p>
          </div>
          <form method="post" action="/dashboard/events/<%= event.id %>/google-drive/disconnect" style="margin: 10px 0 0; width: 100%;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn danger small" type="submit" style="width: 100%; min-height: 32px;">Disconnect Google Drive</button>
          </form>
        <% } else { %>
          <a class="btn small" href="/dashboard/events/<%= event.id %>/google-drive/auth" style="display: block; width: 100%; text-align: center; text-decoration: none; line-height: 2;">
            🔗 Connect Google Drive
          </a>
        <% } %>
      </div>
    </div>
  </div>

  <div class="card">
    <h2 style="margin-top:0;">Storage Status</h2>
    <div style="display: flex; flex-direction: column; gap: 14px;">
      <label>Active Storage Provider
        <input type="text" readonly value="<%= event.storage_provider === 'google_drive' ? 'Google Drive' : 'ShaadiShots Cloud (Default)' %>" style="background: var(--border); cursor: not-allowed; width: 100%; box-sizing: border-box;">
      </label>
      <div class="alert" style="background: rgba(255,255,255,0.5); border-color: var(--border); margin-bottom: 0;">
        <% if (event.storage_provider === 'google_drive') { %>
          <p class="hint" style="margin: 0; font-weight: 500;">
            Photos will bypass platform limits and go directly to your linked Google Drive folder privately. Private streaming proxy protects your file links.
          </p>
        <% } else { %>
          <p class="hint" style="margin: 0; font-weight: 500;">
            Currently saving to ShaadiShots Secure S3. Connect Google Drive to redirect storage or upgrade plan to extend platform limits.
          </p>
        <% } %>
      </div>
    </div>
  </div>
</section>

<script>
  function copyValue(id) {
    const input = document.getElementById(id);
    input.select();
    input.setSelectionRange(0, 99999);
    navigator.clipboard && navigator.clipboard.writeText(input.value);
  }
</script>
