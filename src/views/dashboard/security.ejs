<!-- Modernized Security Settings Panel -->
<section class="max-w-2xl mx-auto py-8">
  <div class="glass-card p-6 rounded-2xl flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6 bg-white/70 backdrop-blur-xl border border-primary/10">
    <div class="space-y-1">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary/10 rounded-full text-primary text-xs font-bold shadow-sm border border-primary/15">
        🛡️ Account Protection
      </span>
      <h1 class="font-headline text-2xl sm:text-3xl font-bold text-primary tracking-tight mt-2">Security Settings</h1>
      <p class="text-slate-500 text-xs font-medium">Protect your account from unauthorized access by activating 2FA.</p>
    </div>
    <a class="border border-primary/20 bg-white hover:bg-slate-50 text-primary text-xs font-bold px-4 py-2.5 rounded-full shadow-sm transition-all" href="/dashboard">
      Back to Dashboard
    </a>
  </div>

  <div class="glass-card p-6 rounded-2xl border border-primary/10 bg-white/70 backdrop-blur-xl space-y-6">
    <% if (twoFactorEnabled) { %>
      <div class="alert success shadow-sm">
        <strong>🟢 Multi-Factor Authentication is Active:</strong> Your account is protected. Every time you log in, you will be prompted for a 6-digit authentication code.
      </div>
      <p class="text-sm text-slate-500 font-medium">Keep your account safe. If you need to switch authenticator apps, you can disable 2FA below and configure it again.</p>

      <form method="post" action="/dashboard/security/2fa/disable" class="m-0 pt-2">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="bg-red-50 text-red-600 hover:bg-red-100 text-xs font-bold px-5 py-2.5 rounded-full border border-red-200 shadow-sm transition-all" type="submit">Disable 2FA Protection</button>
      </form>
    <% } else { %>
      <div class="space-y-2">
        <h3 class="font-headline text-xl font-bold text-slate-800">Enable Two-Factor Authentication (2FA)</h3>
        <p class="text-xs text-slate-500 leading-relaxed font-semibold">Scan the QR code below using an authenticator app (such as Google Authenticator, Microsoft Authenticator, or Authy), or manually enter the key to pair your device.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-center p-4 bg-white/40 border border-primary/5 rounded-xl">
        <div class="md:col-span-4 bg-white p-3.5 border border-primary/15 rounded-xl flex items-center justify-center shadow-sm">
          <img src="<%= qrDataUrl %>" alt="Scan QR Code" class="w-full max-w-[120px]">
        </div>
        <div class="md:col-span-8 space-y-1.5">
          <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Manual Secret Key</label>
          <input readonly value="<%= secret %>" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-2.5 font-mono text-sm tracking-wider text-center cursor-pointer focus:ring-primary focus:border-primary" onclick="this.select(); navigator.clipboard.writeText(this.value); alert('Secret key copied!');">
          <span class="hint block text-[10px] text-slate-400 font-medium">Click on the box above to copy the key to your clipboard.</span>
        </div>
      </div>

      <form class="space-y-4 pt-2" method="post" action="/dashboard/security/2fa/enable">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="secret" value="<%= secret %>">

        <div class="space-y-1.5">
          <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">6-Digit Verification Code</label>
          <input name="code" type="text" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="000000" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-3 font-mono text-lg tracking-widest text-center focus:ring-primary focus:border-primary" required autocomplete="off">
          <span class="hint block text-[10px] text-slate-400 font-medium">Enter the 6-digit code shown in your authenticator app to complete pairing.</span>
        </div>

        <button class="w-full bg-gradient-wedding text-white px-5 py-3 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all" type="submit">Verify & Enable 2FA</button>
      </form>
    <% } %>
  </div>
</section>
