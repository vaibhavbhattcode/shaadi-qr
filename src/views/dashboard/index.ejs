<!-- Premium Dashboard Index View -->
<section class="glass-card p-6 rounded-2xl flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8 bg-white/70 backdrop-blur-xl border border-primary/10">
  <div class="space-y-1">
    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary/10 rounded-full text-primary text-xs font-bold shadow-sm border border-primary/15">
      👑 Couple Area
    </span>
    <h1 class="font-headline text-3xl font-bold text-primary tracking-tight mt-2">Your Wedding Albums</h1>
    <p class="text-slate-500 text-xs font-medium">Manage QR codes, track storage space, moderate guest uploads, and customize public galleries.</p>
  </div>
  <div class="flex flex-wrap gap-2.5 pt-2 sm:pt-0">
    <a class="bg-gradient-wedding text-white px-5 py-2.5 rounded-full font-bold text-xs shadow-md hover:shadow-xl transition-all" href="/dashboard/events/new">
      + Create Wedding Album
    </a>
  </div>
</section>

<% if (!events.length) { %>
  <div class="empty py-16 text-center glass-card rounded-2xl bg-white/60 border border-primary/10">
    <div class="text-5xl mb-4">📸</div>
    <h2 class="font-headline text-2xl font-bold text-slate-800 mb-2">No albums created yet</h2>
    <p class="text-slate-500 text-sm max-w-sm mx-auto mb-6">Create your first wedding event to generate a unique QR code and start collecting candid memories.</p>
    <a class="bg-gradient-wedding text-white px-8 py-3.5 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all inline-block" href="/dashboard/events/new">Create Wedding QR</a>
  </div>
<% } else { %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <% events.forEach((event) => { %>
      <article class="glass-card p-6 rounded-3xl border border-primary/10 bg-white/70 backdrop-blur-xl shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 flex flex-col justify-between space-y-6">
        
        <div class="space-y-4">
          <!-- Album Header info -->
          <div class="flex justify-between items-start gap-4">
            <div class="space-y-1">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[9px] font-extrabold uppercase tracking-wide border bg-primary/5 text-primary border-primary/15">
                <%= event.stats.planLabel %> Plan
              </span>
              <h3 class="font-headline text-xl sm:text-2xl font-bold text-slate-800 tracking-tight mt-1.5"><%= event.title %></h3>
              <p class="text-slate-400 text-xs font-semibold">
                <%= event.city || 'Location not set' %> <%= event.wedding_date ? `· ${helpers.formatDate(event.wedding_date)}` : '' %>
              </p>
            </div>
            
            <a class="border border-primary/20 bg-white hover:bg-slate-50 text-primary text-xs font-bold px-4 py-2 rounded-full shadow-sm transition-all" href="/dashboard/events/<%= event.id %>">
              Manage
            </a>
          </div>

          <!-- Quick Stats Bento Grid -->
          <div class="grid grid-cols-3 gap-3">
            <div class="bg-white/40 border border-primary/5 rounded-xl p-3 text-center">
              <div class="text-lg font-black text-amber-600"><%= event.stats.counts.pending %></div>
              <div class="text-[9px] text-slate-400 font-bold uppercase tracking-wider mt-1">Pending</div>
            </div>
            <div class="bg-white/40 border border-primary/5 rounded-xl p-3 text-center">
              <div class="text-lg font-black text-green-600"><%= event.stats.counts.approved %></div>
              <div class="text-[9px] text-slate-400 font-bold uppercase tracking-wider mt-1">Approved</div>
            </div>
            <div class="bg-white/40 border border-primary/5 rounded-xl p-3 text-center">
              <div class="text-lg font-black text-slate-700"><%= event.stats.counts.total %></div>
              <div class="text-[9px] text-slate-400 font-bold uppercase tracking-wider mt-1">Total</div>
            </div>
          </div>

          <!-- Storage Meter -->
          <div class="space-y-1.5">
            <div class="flex justify-between text-[11px] font-semibold text-slate-500">
              <span>Cloud Storage Used</span>
              <span><%= event.stats.usedHuman %> / <%= event.stats.limitHuman %></span>
            </div>
            <div class="w-full bg-primary/10 h-2 rounded-full overflow-hidden">
              <div class="bg-gradient-wedding h-full rounded-full" style="width: <%= event.stats.percent %>%"></div>
            </div>
          </div>
        </div>

        <!-- Quick actions buttons -->
        <div class="flex flex-wrap gap-2 pt-4 border-t border-primary/5">
          <a class="bg-gradient-wedding text-white text-xs font-bold px-4 py-2 rounded-full shadow-md hover:shadow-lg transition-all" href="/dashboard/events/<%= event.id %>/media">
            Review Uploads
          </a>
          <a class="border border-primary/15 bg-white hover:bg-slate-50 text-slate-700 text-xs font-bold px-4 py-2 rounded-full shadow-sm transition-all" target="_blank" href="/e/<%= event.slug %>/gallery">
            Open Gallery
          </a>
          <a class="border border-primary/15 bg-white hover:bg-slate-50 text-slate-700 text-xs font-bold px-4 py-2 rounded-full shadow-sm transition-all" href="/dashboard/events/<%= event.id %>/qr.png?download=1">
            Download QR
          </a>
        </div>

      </article>
    <% }) %>
  </div>
<% } %>
