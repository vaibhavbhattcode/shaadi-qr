      <button class="theme-btn" data-theme="theme-cherry-blossom">💮 Cherry Blossom</button>
      <button class="theme-btn" data-theme="theme-royal-emerald">👑 Royal Emerald</button>
      <button class="theme-btn" data-theme="theme-minimal-arch">🏛️ Sleek Arch</button>
      <button class="theme-btn" data-theme="theme-baroque-gold">⚜️ Baroque Gold</button>
      <button class="theme-btn" data-theme="theme-retro-70s">🕺 Retro 70s</button>
    </div>
  </div>

  <main class="page">
    <section class="poster theme-royal-rose">
      <!-- Premium Visual Decorations & Keyframe Animation Elements -->
      <div class="decorations">
        <!-- Floating emoji/symbols for specific theme styles -->
        <span class="deco-leaf deco-leaf-1">🍃</span>
        <span class="deco-leaf deco-leaf-2">🌿</span>
        <span class="deco-flower deco-flower-1">🌸</span>
        <span class="deco-flower deco-flower-2">💮</span>
        <span class="deco-sparkle deco-sparkle-1">✨</span>
        <span class="deco-sparkle deco-sparkle-2">✨</span>
        <span class="deco-heart deco-heart-1">💖</span>
        <span class="deco-star deco-star-1">⭐</span>
        <span class="deco-star deco-star-2">⭐</span>
        
        <!-- High-fidelity vector SVG decorations -->
        <!-- Botanical Vines -->
        <svg class="svg-decor svg-vine-left" viewBox="0 0 120 200" width="100%" height="100%"><path d="M10,10 Q40,80 15,140 T50,220" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M22,45 C35,40 40,55 25,60 C15,62 10,48 22,45 Z" fill="currentColor"/><path d="M12,95 C-2,90 -8,105 5,110 C15,112 18,98 12,95 Z" fill="currentColor"/><path d="M25,160 C38,150 48,165 30,175 C20,180 18,165 25,160 Z" fill="currentColor"/></svg>
        <svg class="svg-decor svg-vine-right" viewBox="0 0 120 200" width="100%" height="100%"><path d="M110,10 Q80,80 105,140 T70,220" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M98,45 C85,40 80,55 95,60 C105,62 110,48 98,45 Z" fill="currentColor"/><path d="M108,95 C122,90 128,105 115,110 C105,112 102,98 108,95 Z" fill="currentColor"/><path d="M95,160 C82,150 72,165 90,175 C100,180 102,165 95,160 Z" fill="currentColor"/></svg>
        
        <!-- Wedding Rings -->
        <svg class="svg-decor svg-rings" viewBox="0 0 100 60" width="100%" height="100%"><circle cx="38" cy="30" r="20" fill="none" stroke="currentColor" stroke-width="3"/><circle cx="62" cy="30" r="20" fill="none" stroke="currentColor" stroke-width="3"/></svg>
        
        <!-- Classical Ornate Corners -->
        <svg class="svg-decor svg-corner-tl" viewBox="0 0 100 100" width="100%" height="100%"><path d="M10,90 L10,10 L90,10 M20,80 L20,20 L80,20" fill="none" stroke="currentColor" stroke-width="2"/></svg>
        <svg class="svg-decor svg-corner-tr" viewBox="0 0 100 100" width="100%" height="100%"><path d="M90,90 L90,10 L10,10 M80,80 L80,20 L20,20" fill="none" stroke="currentColor" stroke-width="2"/></svg>
        <svg class="svg-decor svg-corner-bl" viewBox="0 0 100 100" width="100%" height="100%"><path d="M10,10 L10,90 L90,90 M20,20 L20,80 L80,80" fill="none" stroke="currentColor" stroke-width="2"/></svg>
        <svg class="svg-decor svg-corner-br" viewBox="0 0 100 100" width="100%" height="100%"><path d="M90,10 L90,90 L10,90 M80,20 L80,80 L20,80" fill="none" stroke="currentColor" stroke-width="2"/></svg>
        
        <!-- Architectural Arch Backdrop -->
        <svg class="svg-decor svg-arch" viewBox="0 0 100 150" preserveAspectRatio="none" width="100%" height="100%"><path d="M0,150 L0,50 A50,50 0 0,1 100,50 L100,150 Z" fill="currentColor"/></svg>
        
        <!-- Theme-specific Animated Overlays -->
        <div class="cyber-grid"></div>
        <div class="cyber-scanline"></div>
        <div class="news-halftone"></div>
        
        <div class="retro-waves">
          <div class="wave"></div>
        </div>

        <div class="sakura-container">
          <span class="sakura-petal petal-1">🌸</span>
          <span class="sakura-petal petal-2">🌸</span>
          <span class="sakura-petal petal-3">🌸</span>
          <span class="sakura-petal petal-4">🌸</span>
          <span class="sakura-petal petal-5">🌸</span>
        </div>
      </div>

      <h1>Share Your Memories</h1>
      <h2><%= event.title %></h2>
      <div class="qr-container">
        <img class="qr" src="<%= qrDataUrl %>" alt="Wedding upload QR">
      </div>
      <div class="scan">Scan QR & Upload Photos</div>
      <p>No login required. Photos/videos couple ke private approval dashboard me jayenge.</p>
      <p class="url"><%= uploadLink %></p>
    </section>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const poster = document.querySelector('.poster');
      const buttons = document.querySelectorAll('.theme-btn');
      
      const themeBackgrounds = {
        'theme-royal-rose': '#f8fafc',
        'theme-minimal-dark': '#090d16',
        'theme-botanical': '#fafdfb',
        'theme-sunset': '#fffbf0',
        'theme-vintage': '#faf6ee',
        'theme-starry': '#060818',
        'theme-lavender': '#faf7ff',
        'theme-marble': '#eceef2',
        'theme-bollywood': '#fffaf5',
        'theme-indigo': '#eef2ff',
        'theme-boho': '#fafaf9',
        'theme-ocean': '#e0f7fa',
        'theme-midnight-forest': '#030f0a',
        'theme-cyberpunk': '#090011',
        'theme-golden-hour': '#fff7ed',
        'theme-rose-gold': '#fff1f2',
        'theme-retro-gazette': '#f4ebd9',
        'theme-aurora': '#050811',
        'theme-boho-meadow': '#faf7f2',
        'theme-cherry-blossom': '#fff5f6',
        'theme-royal-emerald': '#021a14',
        'theme-minimal-arch': '#faf9f6',
        'theme-baroque-gold': '#3b0212',
        'theme-retro-70s': '#fef3c7'
      };

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          // Remove active class from all buttons
          buttons.forEach(b => b.classList.remove('active'));
          // Add active class to clicked button
          btn.classList.add('active');
          
          // Clear all theme classes from poster
          poster.className = 'poster';
          // Add selected theme class
          const theme = btn.getAttribute('data-theme');
          poster.classList.add(theme);
          
          // Dynamically change body background to match selected theme vibe
          document.body.style.background = themeBackgrounds[theme] || '#f8fafc';
        });
      });
    });
  </script>
</body>
</html>
