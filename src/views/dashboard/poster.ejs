<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  
  <!-- Import Google Fonts for unique theme typography -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700;900&family=DM+Serif+Display:ital@0;1&family=Great+Vibes&family=Lora:ital,wght@0,400..700;1,400..700&family=Marcellus&family=Montserrat:wght@400;700;900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=WindSong:wght@500&display=swap" rel="stylesheet">
  
  <style>
    /* Global Base Reset */
    * { box-sizing: border-box; }
    body { 
      margin: 0; 
      font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, sans-serif; 
      background: #f8fafc; 
      color: #1e293b; 
      transition: background 0.4s ease, color 0.4s ease;
    }
    
    .page { 
      min-height: 100vh; 
      display: grid; 
      place-items: center; 
      padding: 30px; 
    }
    
    /* Base Card Container */
    .poster { 
      width: min(780px, 100%); 
      aspect-ratio: 3 / 4; 
      border-radius: 40px; 
      padding: 48px; 
      text-align: center; 
      display: flex; 
      flex-direction: column; 
      justify-content: center; 
      align-items: center;
      transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
      border-width: 12px;
      border-style: solid;
    }

    .poster > * {
      position: relative;
      z-index: 10;
    }

    /* ==========================================================================
       DECORATIVE ASSETS LAYER
       ========================================================================== */
    .poster > .decorations {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      overflow: hidden;
      z-index: 1;
      display: block;
    }

    .deco-leaf, .deco-flower, .deco-sparkle, .deco-heart, .deco-star, .svg-decor {
      position: absolute;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.5s ease, transform 0.5s ease;
    }

    /* Theme-specific overlays */
    .cyber-grid, .cyber-scanline, .news-halftone, .retro-waves, .sakura-container {
      display: none;
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
    }

    /* ==========================================================================
       KEYFRAME ANIMATIONS (Unique per theme)
       ========================================================================== */
    @keyframes float {
      0% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(-8px) rotate(0.5deg); }
      100% { transform: translateY(0px) rotate(0deg); }
    }
    @keyframes neon-glow {
      0% { box-shadow: 0 0 15px rgba(0, 242, 254, 0.3), inset 0 0 10px rgba(0, 242, 254, 0.1); border-color: #00f2fe; }
      100% { box-shadow: 0 0 35px rgba(0, 242, 254, 0.6), inset 0 0 20px rgba(0, 242, 254, 0.3); border-color: #ff007f; }
    }
    @keyframes gentle-sway {
      0% { transform: rotate(-0.5deg) scale(1); }
      50% { transform: rotate(0.5deg) scale(1.01); }
      100% { transform: rotate(-0.5deg) scale(1); }
    }
    @keyframes warm-pulse {
      0% { transform: scale(1); filter: brightness(1); }
      50% { transform: scale(1.02); filter: brightness(1.03); }
      100% { transform: scale(1); filter: brightness(1); }
    }
    @keyframes gold-shimmer {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    @keyframes stars-twinkle {
      0%, 100% { opacity: 0.8; transform: scale(1); }
      50% { opacity: 0.3; transform: scale(0.8); }
    }
    @keyframes flower-drift {
      0% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-5px) rotate(2deg); }
      100% { transform: translateY(0) rotate(0deg); }
    }
    @keyframes metallic-shine {
      0% { background-position: -200% 0; }
      100% { background-position: 200% 0; }
    }
    @keyframes festive-spark {
      0% { border-color: #ff9100; box-shadow: 0 0 15px rgba(255,145,0,0.3); }
      50% { border-color: #d500f9; box-shadow: 0 0 30px rgba(213,0,249,0.5); }
      100% { border-color: #ff9100; box-shadow: 0 0 15px rgba(255,145,0,0.3); }
    }
    @keyframes geo-slide {
      0% { background-position: 0% 0%; }
      100% { background-position: 100% 100%; }
    }
    @keyframes boho-sway {
      0% { transform: skewX(-1deg); }
      50% { transform: skewX(1deg); }
      100% { transform: skewX(-1deg); }
    }
    @keyframes ocean-wave {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    /* Common elements */
    .qr-container {
      padding: 16px;
      background: white;
      border-radius: 28px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.06);
      display: flex;
      justify-content: center;
      align-items: center;
      transition: all 0.3s ease;
    }

    .qr {
      width: min(340px, 100%);
      height: auto;
      border-radius: 18px;
      display: block;
    }

    h1 { 
      font-size: clamp(1.8rem, 5.5vw, 3.2rem); 
      line-height: 1.05; 
      margin: 0; 
      letter-spacing: -0.04em; 
    }
    
    h2 { 
      font-size: clamp(1.1rem, 3.5vw, 1.6rem); 
      margin: 12px 0 20px; 
    }
    
    .scan { 
      margin: 20px 0 8px; 
      font-size: clamp(1.2rem, 3.5vw, 1.8rem); 
      font-weight: 800; 
    }
    
    p { 
      font-size: 1rem; 
      line-height: 1.5; 
      margin: 6px 0; 
    }
    
    .url { 
      font-family: ui-monospace, Menlo, Consolas, monospace; 
      word-break: break-all; 
      font-size: 0.82rem; 
      max-width: 90%; 
      margin-top: 14px;
      opacity: 0.85;
    }

    /* ==========================================================================
       THEME STYLING (24 Styles)
       ========================================================================== */

    /* Theme 1: Royal Rose (Pink & Gold) */
    .poster.theme-royal-rose {
      background: radial-gradient(circle at top left, #fff0f3, transparent 50%), 
                  radial-gradient(circle at bottom right, #fae0e4, transparent 50%), 
                  #ffffff; 
      border-color: #b83280;
      box-shadow: 0 25px 70px rgba(184, 50, 128, 0.15);
      font-family: 'Playfair Display', Georgia, serif;
      animation: gentle-sway 8s ease-in-out infinite;
    }
    .theme-royal-rose h1 { color: #4a0e2e; font-weight: 900; }
    .theme-royal-rose h2 { color: #b83280; font-style: italic; }
    .theme-royal-rose .scan { color: #b83280; }
    .theme-royal-rose .qr-container { border: 4px solid #f9bec7; animation: float 6s ease-in-out infinite; }
    .theme-royal-rose p { color: #6d5367; }
    .theme-royal-rose .url { color: #4a0e2e; }
    .theme-royal-rose .deco-flower-1 { display: block; opacity: 0.7; left: 10%; top: 12%; font-size: 1.5rem; animation: float 6s ease-in-out infinite; }
    .theme-royal-rose .deco-flower-2 { display: block; opacity: 0.7; right: 10%; bottom: 12%; font-size: 1.5rem; animation: float 5s ease-in-out infinite; }
    .theme-royal-rose .deco-heart-1 { display: block; opacity: 0.4; right: 15%; top: 18%; font-size: 1.2rem; animation: float 4s ease-in-out infinite; }
    .theme-royal-rose .svg-rings { display: block; opacity: 0.15; top: 8%; left: 50%; transform: translateX(-50%); width: 70px; color: #b83280; }

    /* Theme 2: Minimal Dark (Cyber Neon Glow) */
    .poster.theme-minimal-dark {
      background: linear-gradient(135deg, #0f172a, #1e293b);
      border-color: #00f2fe;
      color: #f8fafc;
      animation: neon-glow 4s infinite alternate;
    }
    .theme-minimal-dark h1 { color: #ffffff; text-shadow: 0 0 15px rgba(0, 242, 254, 0.4); font-weight: 900; }
    .theme-minimal-dark h2 { color: #38bdf8; }
    .theme-minimal-dark .scan { color: #00f2fe; text-shadow: 0 0 10px rgba(0,242,254,0.3); }
    .theme-minimal-dark .qr-container { border: 4px solid #38bdf8; background: #0f172a; }
    .theme-minimal-dark p { color: #94a3b8; }
    .theme-minimal-dark .url { color: #38bdf8; }
    .theme-minimal-dark .deco-sparkle-1 { display: block; opacity: 0.6; left: 8%; top: 12%; color: #00f2fe; font-size: 1.4rem; animation: float 5s ease-in-out infinite; }
    .theme-minimal-dark .deco-sparkle-2 { display: block; opacity: 0.6; right: 8%; bottom: 12%; color: #ff007f; font-size: 1.4rem; animation: float 7s ease-in-out infinite; }

    /* Theme 3: Botanical Garden (Natural Green & Ivory) */
    .poster.theme-botanical {
      background: radial-gradient(circle at top left, #f1f8f5, transparent 50%),
                  radial-gradient(circle at bottom right, #e8f5e9, transparent 50%),
                  #fafdfb;
      border-color: #2d6a4f;
      box-shadow: 0 25px 70px rgba(45, 106, 79, 0.12);
      font-family: 'Lora', Georgia, serif;
      animation: gentle-sway 10s ease-in-out infinite;
    }
    .theme-botanical h1 { color: #1b4332; font-weight: 800; }
    .theme-botanical h2 { color: #40916c; font-style: italic; }
    .theme-botanical .scan { color: #2d6a4f; }
    .theme-botanical .qr-container { border: 4px solid #b7e4c7; }
    .theme-botanical p { color: #52796f; }
    .theme-botanical .url { color: #1b4332; }
    .theme-botanical .svg-vine-left { display: block; opacity: 0.15; left: 4%; top: 5%; width: 120px; color: #2d6a4f; }
    .theme-botanical .svg-vine-right { display: block; opacity: 0.15; right: 4%; bottom: 5%; width: 120px; color: #2d6a4f; transform: scaleY(-1); }
    .theme-botanical .deco-leaf-1 { display: block; opacity: 0.6; left: 12%; bottom: 20%; font-size: 1.4rem; animation: gentle-sway 8s infinite ease-in-out; }
    .theme-botanical .deco-leaf-2 { display: block; opacity: 0.6; right: 12%; top: 20%; font-size: 1.4rem; animation: gentle-sway 7s infinite ease-in-out; }

    /* Theme 4: Sunset Bliss (Gold & Coral) */
    .poster.theme-sunset {
      background: linear-gradient(135deg, #fffcf5 0%, #fff5f5 100%);
      border-color: #ff7a59;
      box-shadow: 0 25px 70px rgba(255, 122, 89, 0.12);
      animation: warm-pulse 6s ease-in-out infinite;
    }
    .theme-sunset h1 { color: #bf360c; font-weight: 900; }
    .theme-sunset h2 { color: #e65100; }
    .theme-sunset .scan { color: #ff7a59; }
    .theme-sunset .qr-container { border: 4px solid #ffe0b2; animation: float 5.5s ease-in-out infinite; }
    .theme-sunset p { color: #7c6258; }
    .theme-sunset .url { color: #e65100; }
    .theme-sunset .deco-sparkle-1 { display: block; opacity: 0.4; left: 15%; top: 12%; color: #ff7a59; font-size: 1.4rem; animation: float 5s ease-in-out infinite; }

    /* Theme 5: Vintage Craft (Antique Parchment Style) */
    .poster.theme-vintage {
      background: radial-gradient(circle, #fcf4e8 0%, #f4e4cc 100%);
      border-color: #8c6a46;
      border-style: double;
      border-width: 16px;
      box-shadow: 0 20px 50px rgba(140, 106, 70, 0.2);
      font-family: 'DM Serif Display', Georgia, serif;
    }
    .theme-vintage h1 { color: #4e3629; font-weight: 700; letter-spacing: 0.02em; font-family: 'DM Serif Display', serif; }
    .theme-vintage h2 { color: #704c38; font-style: italic; }
    .theme-vintage .scan { color: #4e3629; text-transform: uppercase; font-size: 1.5rem; letter-spacing: 0.05em; }
    .theme-vintage .qr-container { border: 4px dashed #8c6a46; background: #faf4eb; }
    .theme-vintage p { color: #70584c; font-family: 'Lora', serif; }
    .theme-vintage .url { color: #4e3629; }
    .theme-vintage .svg-corner-tl { display: block; opacity: 0.15; top: 20px; left: 20px; width: 50px; color: #8c6a46; }
    .theme-vintage .svg-corner-tr { display: block; opacity: 0.15; top: 20px; right: 20px; width: 50px; color: #8c6a46; }
    .theme-vintage .svg-corner-bl { display: block; opacity: 0.15; bottom: 20px; left: 20px; width: 50px; color: #8c6a46; }
    .theme-vintage .svg-corner-br { display: block; opacity: 0.15; bottom: 20px; right: 20px; width: 50px; color: #8c6a46; }

    /* Theme 6: Starry Night (Glittering Navy & Gold) */
    .poster.theme-starry {
      background: radial-gradient(circle at center, #1e295d 0%, #0c1033 100%);
      border-color: #d4af37;
      box-shadow: 0 25px 60px rgba(212, 175, 55, 0.25);
      color: #ffffff;
      font-family: 'Cinzel', serif;
    }
    .theme-starry h1 { color: #ffffff; font-family: 'Cinzel', serif; font-weight: 900; text-shadow: 0 0 10px rgba(212, 175, 55, 0.3); }
    .theme-starry h2 { color: #f3e5ab; font-family: 'Great Vibes', cursive; font-size: 2.2rem; text-transform: none; margin: 4px 0 14px; }
    .theme-starry .scan { color: #d4af37; font-family: 'Cinzel', serif; text-shadow: 0 0 8px rgba(212,175,55,0.2); }
    .theme-starry .qr-container { border: 4px solid #d4af37; background: #0c1033; animation: float 7s ease-in-out infinite; }
    .theme-starry p { color: #cbd5e1; font-family: 'Lora', serif; }
    .theme-starry .url { color: #f3e5ab; }
    .theme-starry .deco-star-1 { display: block; opacity: 0.7; left: 10%; top: 15%; color: #d4af37; font-size: 1.2rem; animation: stars-twinkle 3s infinite; }
    .theme-starry .deco-star-2 { display: block; opacity: 0.7; right: 10%; bottom: 15%; color: #d4af37; font-size: 1.2rem; animation: stars-twinkle 4.2s infinite; }

    /* Theme 7: Lavender Fields (Romantic Violet Pastel) */
    .poster.theme-lavender {
      background: radial-gradient(circle at top left, #f3e8ff, transparent 55%),
                  radial-gradient(circle at bottom right, #fae8ff, transparent 50%),
                  #faf5ff;
      border-color: #8b5cf6;
      box-shadow: 0 25px 60px rgba(139, 92, 246, 0.12);
      font-family: 'Lora', Georgia, serif;
      animation: flower-drift 8s infinite ease-in-out;
    }
    .theme-lavender h1 { color: #4c1d95; font-family: 'Great Vibes', cursive; font-size: 4rem; font-weight: normal; letter-spacing: 0; }
    .theme-lavender h2 { color: #7c3aed; font-family: 'Lora', serif; margin-top: 2px; }
    .theme-lavender .scan { color: #6d28d9; }
    .theme-lavender .qr-container { border: 4px solid #ddd6fe; animation: float 5s ease-in-out infinite; }
    .theme-lavender p { color: #6b21a8; }
    .theme-lavender .url { color: #4c1d95; }
    .theme-lavender .deco-flower-1 { display: block; opacity: 0.6; left: 12%; top: 12%; font-size: 1.4rem; color: #8b5cf6; animation: float 6s infinite; }
    .theme-lavender .deco-flower-2 { display: block; opacity: 0.6; right: 12%; bottom: 12%; font-size: 1.4rem; color: #8b5cf6; animation: float 5s infinite; }

    /* Theme 8: Ethereal Marble (Luxury Gold Veins) */
    .poster.theme-marble {
      background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
      border-color: #c5a880;
      box-shadow: 0 25px 70px rgba(197, 168, 128, 0.2);
      font-family: 'Marcellus', serif;
    }
    .theme-marble h1 { color: #1e293b; font-family: 'Marcellus', serif; letter-spacing: 0.1em; text-transform: uppercase; font-size: 2.5rem; }
    .theme-marble h2 { color: #c5a880; font-family: 'Marcellus', serif; text-transform: uppercase; letter-spacing: 0.05em; }
    .theme-marble .scan { color: #1e293b; font-family: 'Marcellus', serif; text-transform: uppercase; letter-spacing: 0.08em; }
    .theme-marble .qr-container { border: 4px solid #c5a880; background: #ffffff; }
    .theme-marble p { color: #475569; font-family: 'Lora', serif; }
    .theme-marble .url { color: #c5a880; }
    .theme-marble .svg-corner-tl { display: block; opacity: 0.2; top: 15px; left: 15px; width: 45px; color: #c5a880; }
    .theme-marble .svg-corner-tr { display: block; opacity: 0.2; top: 15px; right: 15px; width: 45px; color: #c5a880; }
    .theme-marble .svg-corner-bl { display: block; opacity: 0.2; bottom: 15px; left: 15px; width: 45px; color: #c5a880; }
    .theme-marble .svg-corner-br { display: block; opacity: 0.2; bottom: 15px; right: 15px; width: 45px; color: #c5a880; }

    /* Theme 9: Bollywood Glam (Crimson & Marigold Gold) */
    .poster.theme-bollywood {
      background: radial-gradient(circle at top left, #fff5f5 0%, #fffaf0 100%);
      border-color: #ff9100;
      box-shadow: 0 25px 60px rgba(255, 145, 0, 0.2);
      animation: festive-spark 5s infinite ease-in-out;
    }
    .theme-bollywood h1 { color: #900c3f; font-family: 'DM Serif Display', serif; font-size: 3.5rem; font-weight: 800; }
    .theme-bollywood h2 { color: #ff5733; font-family: 'Marcellus', serif; }
    .theme-bollywood .scan { color: #c70039; font-family: 'DM Serif Display', serif; text-transform: uppercase; }
    .theme-bollywood .qr-container { border: 5px solid #ffc300; animation: float 6.5s ease-in-out infinite; }
    .theme-bollywood p { color: #581845; font-family: 'Lora', serif; font-weight: 600; }
    .theme-bollywood .url { color: #900c3f; }
    .theme-bollywood .deco-sparkle-1 { display: block; opacity: 0.6; left: 12%; top: 15%; color: #ff9100; font-size: 1.4rem; animation: float 5s infinite; }
    .theme-bollywood .deco-sparkle-2 { display: block; opacity: 0.6; right: 12%; bottom: 15%; color: #ffc300; font-size: 1.4rem; animation: float 6s infinite; }

    /* Theme 10: Modern Indigo (Deep Blue & Silver) */
    .poster.theme-indigo {
      background: radial-gradient(circle at top left, #e0e7ff, transparent 55%),
                  radial-gradient(circle at bottom right, #e0f2fe, transparent 50%),
                  #e0e7ff;
      border-color: #3b82f6;
      box-shadow: 0 25px 70px rgba(59, 130, 246, 0.15);
      font-family: 'Montserrat', sans-serif;
    }
    .theme-indigo h1 { color: #1e3a8a; font-family: 'Montserrat', sans-serif; font-weight: 900; text-transform: uppercase; }
    .theme-indigo h2 { color: #2563eb; font-family: 'Montserrat', sans-serif; font-weight: 700; }
    .theme-indigo .scan { color: #1d4ed8; font-family: 'Montserrat', sans-serif; font-weight: 700; text-transform: uppercase; }
    .theme-indigo .qr-container { border: 4px solid #93c5fd; }
    .theme-indigo p { color: #1e3a8a; }
    .theme-indigo .url { color: #3b82f6; }
    .theme-indigo .deco-sparkle-1 { display: block; opacity: 0.4; left: 10%; top: 12%; color: #3b82f6; font-size: 1.3rem; animation: float 6s infinite; }

    /* Theme 11: Boho Terracotta (Warm Earth & Pampas) */
    .poster.theme-boho {
      background: radial-gradient(circle at top left, #fff7ed, transparent 60%),
                  radial-gradient(circle at bottom right, #ffedd5, transparent 50%),
                  #fafaf9;
      border-color: #c27d58;
      box-shadow: 0 25px 60px rgba(194, 125, 88, 0.15);
      font-family: 'Lora', Georgia, serif;
      animation: boho-sway 9s infinite ease-in-out;
    }
    .theme-boho h1 { color: #7c2d12; font-family: 'Lora', serif; font-weight: 800; }
    .theme-boho h2 { color: #c27d58; font-family: 'Lora', serif; font-style: italic; }
    .theme-boho .scan { color: #7c2d12; font-family: 'Lora', serif; font-weight: bold; }
    .theme-boho .qr-container { border: 4px solid #fed7aa; animation: float 5.8s ease-in-out infinite; }
    .theme-boho p { color: #9a3412; font-family: 'Plus Jakarta Sans', sans-serif; }
    .theme-boho .url { color: #7c2d12; }
    .theme-boho .deco-leaf-1 { display: block; opacity: 0.5; left: 12%; top: 15%; font-size: 1.4rem; filter: sepia(0.5) hue-rotate(-15deg); animation: float 6s infinite; }

    /* Theme 12: Ocean Breeze (Teal & Foam White) */
    .poster.theme-ocean {
      background: linear-gradient(135deg, #e0f7fa 0%, #b2ebf2 100%);
      border-color: #00796b;
      box-shadow: 0 25px 70px rgba(0, 121, 107, 0.15);
      font-family: 'Plus Jakarta Sans', sans-serif;
      animation: ocean-wave 12s infinite ease-in-out;
    }
    .theme-ocean h1 { color: #004d40; font-weight: 900; text-transform: uppercase; letter-spacing: -0.02em; }
    .theme-ocean h2 { color: #00796b; font-weight: 700; }
    .theme-ocean .scan { color: #004d40; font-weight: 800; }
    .theme-ocean .qr-container { border: 4px solid #80deea; }
    .theme-ocean p { color: #004d40; }
    .theme-ocean .url { color: #00796b; }
    .theme-ocean .deco-sparkle-1 { display: block; opacity: 0.4; left: 10%; top: 12%; color: #00796b; font-size: 1.3rem; animation: float 5s infinite; }


    /* ==========================================================================
       THEMES 13 TO 24 (12 Additional Themes)
       ========================================================================== */

    /* Theme 13: Midnight Forest (Deep Emerald & Gold) */
    .poster.theme-midnight-forest {
      background: linear-gradient(135deg, #051d11 0%, #0d3b24 50%, #061d11 100%);
      border-color: #d4af37;
      box-shadow: 0 25px 70px rgba(13, 59, 36, 0.4);
      color: #faf5e8;
      font-family: 'Cinzel', serif;
      animation: gentle-sway 9s ease-in-out infinite;
    }
    .theme-midnight-forest h1 { color: #d4af37; font-family: 'Cinzel', serif; font-weight: 700; text-shadow: 0 2px 10px rgba(212,175,55,0.3); }
    .theme-midnight-forest h2 { color: #ffffff; font-family: 'Marcellus', serif; text-transform: uppercase; letter-spacing: 0.05em; }
    .theme-midnight-forest .scan { color: #d4af37; font-family: 'Cinzel', serif; letter-spacing: 0.05em; }
    .theme-midnight-forest .qr-container { border: 4px solid #d4af37; background: #051d11; }
