<section class="between">
  <div>
    <span class="badge">Media moderation</span>
    <h1 style="margin:10px 0 4px; letter-spacing:-.04em;"><%= event.title %></h1>
    <p class="muted">Approve, reject or delete guest uploads. Only approved media appears in public gallery.</p>
  </div>
  <div class="row">
    <a class="btn secondary" href="/dashboard/events/<%= event.id %>">Event settings</a>
    <a class="btn" href="/dashboard/events/<%= event.id %>/download.zip?status=approved">Download approved ZIP</a>
  </div>
</section>

<section class="grid grid-4" style="margin-top:22px;">
  <a class="metric" href="/dashboard/events/<%= event.id %>/media?status=pending"><div class="num"><%= stats.counts.pending %></div><div class="muted">Pending</div></a>
  <a class="metric" href="/dashboard/events/<%= event.id %>/media?status=approved"><div class="num"><%= stats.counts.approved %></div><div class="muted">Approved</div></a>
  <a class="metric" href="/dashboard/events/<%= event.id %>/media?status=rejected"><div class="num"><%= stats.counts.rejected %></div><div class="muted">Rejected</div></a>
  <a class="metric" href="/dashboard/events/<%= event.id %>/media?status=all"><div class="num"><%= stats.counts.total %></div><div class="muted">All</div></a>
</section>

<div class="card" style="margin-top:22px;">
  <form class="between" method="get" action="/dashboard/events/<%= event.id %>/media">
    <div class="row" style="flex:1;">
      <label style="min-width:160px;">Status
        <select name="status">
          <% ['pending','approved','rejected','all'].forEach((s) => { %>
            <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </label>
      <label style="min-width:180px;">Folder
        <select name="folder">
          <option value="">All folders</option>
          <% folders.forEach((folder) => { %>
            <option value="<%= folder.id %>" <%= Number(folderId) === folder.id ? 'selected' : '' %>><%= folder.name %></option>
          <% }) %>
        </select>
      </label>
      <button class="btn secondary" type="submit">Filter</button>
    </div>
  </form>
</div>

<% if (!media.length) { %>
  <div class="empty" style="margin-top:22px;">
    <h2>No media found</h2>
    <p class="muted">Selected filter me abhi koi upload nahi hai.</p>
  </div>
<% } else { %>
  <form method="post" action="/dashboard/events/<%= event.id %>/media/bulk" style="margin-top:22px;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="between card" style="margin-bottom:18px;">
      <div class="row">
        <button class="btn small secondary" type="button" onclick="document.querySelectorAll('.media-check').forEach(c => c.checked = true)">Select all</button>
        <button class="btn small secondary" type="button" onclick="document.querySelectorAll('.media-check').forEach(c => c.checked = false)">Clear</button>
      </div>
      <div class="row">
        <select name="action" style="min-width:150px;">
          <option value="approve">Approve</option>
          <option value="reject">Reject</option>
          <option value="delete">Delete</option>
        </select>
        <button class="btn" type="submit" onclick="return confirm('Apply bulk action to selected media?')">Apply</button>
      </div>
    </div>

    <div class="media-grid">
      <% media.forEach((item) => { %>
        <article class="media-card">
          <div class="thumb">
            <% if (item.media_type === 'image') { %>
              <a href="/dashboard/media/<%= item.id %>/file" target="_blank"><img loading="lazy" src="/dashboard/media/<%= item.id %>/thumbnail" alt="<%= item.original_name %>"></a>
            <% } else { %>
              <video src="/dashboard/media/<%= item.id %>/file" controls preload="metadata"></video>
            <% } %>
          </div>
          <div class="body">
            <div class="between">
              <label class="row" style="font-weight:800;"><input class="media-check" style="width:auto" type="checkbox" name="media_ids" value="<%= item.id %>"> Select</label>
              <span class="badge <%= item.status %>"><%= item.status %></span>
            </div>
            <strong title="<%= item.original_name %>" style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= item.original_name %></strong>
            <span class="hint"><%= item.folder_name %> · <%= helpers.formatBytes(item.size_bytes) %></span>
            <span class="hint">By: <%= item.uploader_name || 'Guest' %> <%= item.uploader_side ? `· ${item.uploader_side}` : '' %></span>
            <div class="row">
              <% if (item.status !== 'approved') { %>
                <button formaction="/dashboard/events/<%= event.id %>/media/<%= item.id %>/approve" formmethod="post" class="btn small green" type="submit">Approve</button>
              <% } %>
              <% if (item.status !== 'rejected') { %>
                <button formaction="/dashboard/events/<%= event.id %>/media/<%= item.id %>/reject" formmethod="post" class="btn small secondary" type="submit">Reject</button>
              <% } %>
              <button formaction="/dashboard/events/<%= event.id %>/media/<%= item.id %>/delete" formmethod="post" class="btn small danger" type="submit" onclick="return confirm('Delete this media permanently?')">Delete</button>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </form>
<% } %>
