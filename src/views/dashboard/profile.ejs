<div class="admin-toolbar">
  <div>
    <span class="eyebrow">Account Settings</span>
    <h1 style="font-size: clamp(1.6rem, 4vw, 3.65rem);">Manage Profile</h1>
    <p>Apna name, email aur verify kiya hua WhatsApp phone number update karein, aur subscription payment invoices access karein.</p>
  </div>
</div>
<% if (currentUser.email.endsWith('@shaadishots.local') || currentUser.name.startsWith('User +')) { %>
  <div class="alert warning" style="margin-top: 16px; margin-bottom: 8px;">
    <strong>⚠️ Complete Your Profile:</strong> Aapka signup OTP ke through hua hai. Invoices download karne aur account security alerts receive karne ke liye apna actual <strong>Full Name</strong> aur <strong>Email Address</strong> update karein.
  </div>
<% } %>

<section class="grid grid-2" style="margin-top: 24px; align-items: flex-start; gap: 24px;">
  <!-- Profile Update Form -->
  <form class="panel grid" method="post" action="/dashboard/profile" novalidate style="gap: 16px;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    
    <div class="panel-head" style="margin-bottom: 8px;">
      <div>
        <h2>Profile Details</h2>
        <p>Secure details management.</p>
      </div>
    </div>

    <label>Full Name
      <input type="text" name="name" value="<%= values.name || currentUser.name %>" required maxlength="80">
      <% if (errors.name) { %><span class="error-text"><%= errors.name[0] %></span><% } %>
    </label>

    <label>Email Address
      <input type="email" name="email" value="<%= values.email || currentUser.email %>" required placeholder="name@domain.com">
      <% if (errors.email) { %><span class="error-text"><%= errors.email[0] %></span><% } %>
      <span class="hint">Warning: Email change validation will check for duplicate accounts.</span>
    </label>

    <label>WhatsApp Phone Number
      <input type="tel" name="phone_number" value="<%= values.phone_number || (currentUser.phone_number ? '+' + currentUser.phone_number : '') %>" placeholder="E.g. +91 98765 43210">
      <% if (errors.phone_number) { %><span class="error-text"><%= errors.phone_number[0] %></span><% } %>
      <span class="hint">Apna linked phone number manage karein. Must include country code.</span>
    </label>

    <div style="margin-top: 8px;">
      <button class="btn" type="submit" style="width: 100%;">Save Changes</button>
    </div>
  </form>

  <!-- Payment & Invoice History Panel -->
  <div class="panel">
    <div class="panel-head" style="margin-bottom: 12px;">
      <div>
        <h2>Billing & Invoices</h2>
        <p>Album upgrade transactions history.</p>
      </div>
    </div>

    <% if (payments && payments.length > 0) { %>
      <div class="table-wrap">
        <table class="table-like pro-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Plan</th>
              <th>Amount</th>
              <th>Status</th>
              <th style="text-align: right;">Invoice</th>
            </tr>
          </thead>
          <tbody>
            <% payments.forEach(p => { %>
              <tr>
                <td><%= helpers.formatDate(p.created_at) %></td>
                <td>
                  <strong><%= p.plan_name %></strong>
                  <div class="hint" style="font-size: 0.8rem; font-weight: normal;"><%= p.event_title || 'General Account' %></div>
                </td>
                <td class="mono" style="font-weight: 850;"><%= p.currency %> <%= p.amount %></td>
                <td>
                  <% if (p.payment_status === 'paid') { %>
                    <span class="badge approved">Paid</span>
                  <% } else if (p.payment_status === 'pending') { %>
                    <span class="badge pending">Pending</span>
                  <% } else { %>
                    <span class="badge rejected"><%= p.payment_status %></span>
                  <% } %>
                </td>
                <td style="text-align: right;">
                  <% if (p.payment_status === 'paid') { %>
                    <a href="/dashboard/payments/<%= p.id %>/invoice" target="_blank" class="btn secondary small" style="padding: 4px 10px; min-height: 28px; font-size: 0.78rem;">
                      📄 View Invoice
                    </a>
                  <% } else { %>
                    <span class="muted">—</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty" style="padding: 30px 14px;">
        <div style="font-size: 2.2rem; margin-bottom: 8px; opacity: 0.6;">🧾</div>
        <p style="margin: 0; font-weight: 800;">No payment records found.</p>
        <span class="hint">Upgrade an event plan to start billing details records.</span>
      </div>
    <% } %>
  </div>
</section>
