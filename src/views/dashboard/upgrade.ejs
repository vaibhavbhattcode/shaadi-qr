<!-- Modernized Upgrade Storage & Pricing Panel -->
<section class="glass-card p-6 rounded-2xl flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8 bg-white/70 backdrop-blur-xl border border-primary/10">
  <div class="space-y-1">
    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary/10 rounded-full text-primary text-xs font-bold shadow-sm border border-primary/15">
      👑 Premium Features
    </span>
    <h1 class="font-headline text-3xl font-bold text-primary tracking-tight mt-2">Upgrade Album Storage</h1>
    <p class="text-slate-500 text-xs font-medium">Increase your upload space and unlock exclusive features like original ZIP downloads, PIN lock, and custom themes.</p>
  </div>
  <div class="flex flex-wrap gap-2.5 pt-2 sm:pt-0">
    <a class="border border-primary/20 bg-white hover:bg-slate-50 text-primary px-5 py-2.5 rounded-full font-bold text-xs shadow-sm transition-all" href="/dashboard/events/<%= event.id %>">
      Back to Album
    </a>
  </div>
</section>

<!-- Pricing Columns -->
<section class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch mb-8">
  <% plans.forEach((p) => { %>
    <% const isCurrent = event.plan === p.slug; %>
    <div class="glass-card p-8 rounded-3xl flex flex-col justify-between h-full hover-up border-2 <%= isCurrent ? 'border-primary/40 bg-white/95 ring-4 ring-primary/5' : 'border-primary/10 bg-white/60' %> relative">
      
      <% if (isCurrent) { %>
        <span class="absolute top-4 right-4 bg-gradient-wedding text-white text-[9px] uppercase font-extrabold tracking-widest px-3 py-1 rounded-full shadow-sm">
          Active Plan
        </span>
      <% } %>

      <div class="space-y-6">
        <div>
          <span class="text-[10px] uppercase font-bold text-primary tracking-widest block">Package Tier</span>
          <h3 class="font-headline text-2xl font-bold text-slate-800 mt-1"><%= p.name %></h3>
        </div>

        <div class="py-2">
          <span class="text-4xl font-black text-slate-900">₹<%= p.price %></span>
          <span class="text-xs font-bold text-slate-400">/ event</span>
        </div>

        <div class="divider border-b border-primary/5"></div>

        <ul class="space-y-3.5 text-xs text-slate-600 font-semibold">
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-green-600 font-bold">check</span>
            <span><strong><%= p.storageLimitHuman %></strong> total storage quota</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="material-symbols-outlined text-sm text-green-600 font-bold">check</span>
            <span>Photos: up to <strong><%= (p.photoMaxBytes / (1024*1024)).toFixed(0) %> MB</strong> per file</span>
          </li>
          <li class="flex items-center gap-2">
            <% if (p.videoEnabled) { %>
              <span class="material-symbols-outlined text-sm text-green-600 font-bold">check</span>
              <span>Videos: up to <strong><%= (p.videoMaxBytes / (1024*1024)).toFixed(0) %> MB</strong> per file</span>
            <% } else { %>
              <span class="material-symbols-outlined text-sm text-red-600 font-bold">close</span>
              <span class="text-slate-400 font-normal">Video uploads disabled</span>
            <% } %>
          </li>
          <li class="flex items-center gap-2">
            <% if (p.zipDownloadEnabled) { %>
              <span class="material-symbols-outlined text-sm text-green-600 font-bold">check</span>
              <span>Album ZIP download enabled</span>
            <% } else { %>
              <span class="material-symbols-outlined text-sm text-red-600 font-bold">close</span>
              <span class="text-slate-400 font-normal">Album ZIP download disabled</span>
            <% } %>
          </li>
          <li class="flex items-center gap-2">
            <% if (p.pinGalleryEnabled) { %>
              <span class="material-symbols-outlined text-sm text-green-600 font-bold">check</span>
              <span>Gallery PIN protection enabled</span>
            <% } else { %>
              <span class="material-symbols-outlined text-sm text-red-600 font-bold">close</span>
              <span class="text-slate-400 font-normal">Gallery PIN security disabled</span>
            <% } %>
          </li>
          <li class="flex items-center gap-2">
            <% if (p.customBrandingEnabled) { %>
              <span class="material-symbols-outlined text-sm text-green-600 font-bold">check</span>
              <span>Premium theme & branding</span>
            <% } else { %>
              <span class="material-symbols-outlined text-sm text-red-600 font-bold">close</span>
              <span class="text-slate-400 font-normal">Standard branding theme only</span>
            <% } %>
          </li>
        </ul>
      </div>

      <div class="pt-6">
        <% if (isCurrent) { %>
          <button class="w-full bg-slate-100 text-slate-400 border border-slate-200 py-3 rounded-full font-bold text-xs cursor-not-allowed" disabled>Current active plan</button>
        <% } else { %>
          <button class="w-full bg-gradient-wedding text-white py-3 rounded-full font-bold text-xs shadow-md hover:shadow-xl transition-all upgrade-plan-btn active:scale-95" id="btn-<%= p.slug %>" data-plan="<%= p.slug %>">
            Upgrade to <%= p.name %>
          </button>
        <% } %>
      </div>

    </div>
  <% }) %>
</section>

<!-- Sandbox alerts -->
<% if (!razorpayKeyId) { %>
  <div class="alert warning shadow-sm flex items-start gap-3 bg-amber-50/50 border border-amber-200 text-amber-800 p-5 rounded-2xl">
    <span class="material-symbols-outlined text-xl pt-0.5">lightbulb</span>
    <div>
      <h4 class="font-headline font-bold text-sm text-amber-900">Sandbox Mock Payment Mode Active</h4>
      <p class="text-xs text-amber-700 leading-relaxed font-semibold mt-1">The platform is currently operating without live Razorpay keys. Upgrades can be tested instantly and are simulated for free.</p>
    </div>
  </div>
<% } %>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  async function startPayment(planSlug) {
    const btn = document.getElementById(`btn-${planSlug}`);
    const originalText = btn.innerText;
    btn.disabled = true;
    btn.innerText = 'Creating order...';

    try {
      const response = await fetch(`/dashboard/events/<%= event.id %>/upgrade/order`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
        },
        body: JSON.stringify({ planSlug, _csrf: '<%= csrfToken %>' })
      });

      const data = await response.json();
      if (!response.ok || !data.ok) {
        throw new Error(data.error || 'Failed to initialize order');
      }

      if (data.mock) {
        btn.innerText = 'Simulating payment...';
        const verifyRes = await fetch(`/dashboard/events/<%= event.id %>/upgrade/verify`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
          },
          body: JSON.stringify({ 
            mock: true, 
            planSlug: data.planSlug,
            _csrf: '<%= csrfToken %>' 
          })
        });

        const verifyData = await verifyRes.json();
        if (!verifyRes.ok || !verifyData.ok) {
          throw new Error(verifyData.error || 'Mock verification failed');
        }

        alert('Sandbox simulated payment successful! Your plan has been upgraded.');
        window.location.href = `/dashboard/events/<%= event.id %>`;
        return;
      }

      const options = {
        key: data.keyId,
        amount: data.amount,
        currency: data.currency,
        name: 'ShaadiShots',
        description: `Upgrade to ${data.planName}`,
        order_id: data.orderId,
        prefill: {
          name: data.user.name,
          email: data.user.email,
        },
        theme: {
          color: '#b83280',
        },
        handler: async function (paymentResponse) {
          btn.innerText = 'Verifying signature...';
          try {
            const verifyRes = await fetch(`/dashboard/events/<%= event.id %>/upgrade/verify`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json',
              },
              body: JSON.stringify({
                razorpay_payment_id: paymentResponse.razorpay_payment_id,
                razorpay_order_id: paymentResponse.razorpay_order_id,
                razorpay_signature: paymentResponse.razorpay_signature,
                _csrf: '<%= csrfToken %>'
              })
            });

            const verifyData = await verifyRes.json();
            if (!verifyRes.ok || !verifyData.ok) {
              throw new Error(verifyData.error || 'Payment verification failed.');
            }

            window.location.href = `/dashboard/events/<%= event.id %>`;
          } catch (err) {
            alert(`Error: ${err.message}`);
            btn.disabled = false;
            btn.innerText = originalText;
          }
        },
        modal: {
          ondismiss: function () {
            btn.disabled = false;
            btn.innerText = originalText;
          }
        }
      };

      const rzp = new Razorpay(options);
      rzp.open();

    } catch (err) {
      alert(`Payment failed: ${err.message}`);
      btn.disabled = false;
      btn.innerText = originalText;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.upgrade-plan-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const planSlug = btn.getAttribute('data-plan');
        startPayment(planSlug);
      });
    });
  });
</script>
