<nav class="nav">
  <div class="nav-inner">
    <a class="brand" href="/">
      <span class="brand-mark">💍</span>
      <span><%= appName %></span>
    </a>
    <div class="nav-links">
      <% if (currentUser) { %>
        <% if (isSuperAdmin) { %>
          <a class="btn ghost" href="/admin">Super Admin</a>
          <a class="btn ghost" href="/admin/users">Users</a>
          <a class="btn ghost" href="/admin/events">Events</a>
        <% } %>
        <a class="btn ghost" href="/dashboard">Owner Dashboard</a>
        <a class="btn ghost" href="/dashboard/security">Security Settings</a>
        <a class="btn secondary" href="/dashboard/events/new">New event</a>
        <form action="/logout" method="post" style="margin:0">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn ghost" type="submit">Logout</button>
        </form>
      <% } else { %>
        <a class="btn ghost" href="/login">Login</a>
        <a class="btn secondary" href="/register">Create account</a>
      <% } %>
    </div>
  </div>
</nav>
