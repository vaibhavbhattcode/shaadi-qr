<%- include('partials/admin-nav', {
  heading: 'Security Center',
  subheading: 'Monitor logs, manage IP blocks, and protect the ShaadiShots platform.',
  actions: ''
}) %>

<section class="grid grid-2" style="margin-top:24px; align-items:start;">
  <div class="panel">
    <h2>Block an IP Address</h2>
    <p class="muted">Suspicious traffic block karne ke liye IP address ban karein.</p>
    
    <form class="grid" method="post" action="/admin/security/block" style="margin-top: 14px;" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      
      <label>IP Address
        <input name="ip" placeholder="e.g. 192.168.1.1" required>
      </label>
      
      <label>Reason
        <input name="reason" placeholder="e.g. Repeated failed logins" required>
      </label>
      
      <button class="btn danger" type="submit">Block IP Address</button>
    </form>
  </div>

  <div class="panel">
    <h2>Currently Blocked IPs</h2>
    <p class="muted">In IP addresses se server access block kiya gaya hai.</p>
    
    <div class="table-wrap" style="margin-top:14px;">
      <table class="table-like pro-table">
        <thead>
          <tr>
            <th>IP Address</th>
            <th>Reason</th>
            <th>Blocked At</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% blockedIps.forEach((b) => { %>
            <tr>
              <td><strong><%= b.ip %></strong></td>
              <td><%= b.reason || 'No reason specified' %></td>
              <td><%= helpers.formatDate(b.blocked_at) %></td>
              <td>
                <form method="post" action="/admin/security/unblock" style="margin: 0;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="ip" value="<%= b.ip %>">
                  <button class="btn small" type="submit">Unblock</button>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if (!blockedIps.length) { %>
            <tr>
              <td colspan="4" class="empty" style="text-align: center; padding: 20px;">No IP addresses are currently blocked.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="panel" style="margin-top:24px;">
  <div class="panel-head">
    <div>
      <h2>Flagged NSFW Content Quarantine</h2>
      <p>Media flagged by the automated content filter. Hover over an image to unblur.</p>
    </div>
  </div>

  <% if (flaggedMedia && flaggedMedia.length > 0) { %>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin-top: 14px;">
      <% flaggedMedia.forEach((m) => { %>
        <div class="card" style="display: flex; flex-direction: column; justify-content: space-between; padding: 14px; gap: 10px; border-color: var(--red);">
          <div>
            <div style="width: 100%; height: 180px; background: #eee; border-radius: 8px; overflow: hidden; position: relative;">
              <img src="/admin/media/<%= m.id %>/file" alt="Quarantined Media" class="nsfw-img" style="width: 100%; height: 100%; object-fit: cover; filter: blur(12px); transition: filter 0.3s;" onmouseenter="this.style.filter='none'" onmouseleave="this.style.filter='blur(12px)'">
              <span class="badge rejected" style="position: absolute; top: 8px; left: 8px; font-weight: bold;">NSFW Flagged</span>
            </div>
            <div style="margin-top: 10px;">
              <strong style="word-break: break-all; font-size: 0.95rem; display: block;"><%= m.original_name %></strong>
              <p class="hint" style="margin: 4px 0 0; line-height: 1.4;">
                Event: <strong><%= m.event_title %></strong> (Owner: <%= m.owner_name %>)<br>
                Uploader: <%= m.uploader_name || 'Guest' %> <%= m.uploader_side ? `(${m.uploader_side})` : '' %><br>
                Uploaded: <%= helpers.formatDate(m.created_at) %>
              </p>
            </div>
          </div>
          <div style="display: flex; gap: 10px; margin-top: 8px;">
            <form method="post" action="/admin/media/<%= m.id %>/approve-flagged" style="flex: 1; margin: 0;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn green small" type="submit" style="width: 100%; padding: 6px 12px; min-height: 32px;">Approve</button>
            </form>
            <form method="post" action="/admin/media/<%= m.id %>/delete-flagged" style="flex: 1; margin: 0;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn danger small" type="submit" style="width: 100%; padding: 6px 12px; min-height: 32px;">Delete</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="empty" style="padding: 40px 14px; text-align: center;">
      <div style="font-size: 2.5rem; margin-bottom: 8px;">🛡️</div>
      <p style="margin: 0; font-weight: bold; color: var(--green);">No flagged files in quarantine.</p>
      <span class="hint">Automated filter detects and logs nudity/NSFW uploads here.</span>
    </div>
  <% } %>
</section>

<section class="panel" style="margin-top:24px;">
  <div class="panel-head">
    <div>
      <h2>Security Event Logs</h2>
      <p>Latest security-related actions and events.</p>
    </div>
  </div>
  <div class="audit-list">
    <% securityLogs.forEach((log) => { %>
      <div class="audit-item" style="border-left: 4px solid <%= log.action.includes('failed') || log.action.includes('blocked') ? 'var(--red)' : 'var(--green)' %>; padding-left: 14px;">
        <div>
          <strong><%= log.action %></strong>
          <p>
            Actor: <strong><%= log.actor_name || 'System / Guest' %></strong> 
            <%= log.ip_address ? `· IP: ${log.ip_address}` : '' %>
            <%= log.metadata ? `· Details: ${log.metadata}` : '' %>
          </p>
        </div>
        <span class="hint"><%= helpers.formatDate(log.created_at) %></span>
      </div>
    <% }) %>
    <% if (!securityLogs.length) { %>
      <div class="empty">No security events found.</div>
    <% } %>
  </div>
</section>
