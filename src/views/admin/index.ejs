<!-- Business Header Actions Toolbar -->
<section class="glass-card p-6 rounded-2xl flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6 bg-white/70 backdrop-blur-xl border border-primary/10">
  <div class="space-y-1">
    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary/10 rounded-full text-primary text-xs font-bold shadow-sm border border-primary/15">
      💼 Administrator Area
    </span>
    <h2 class="font-headline text-3xl font-bold text-primary tracking-tight mt-2">Business Overview</h2>
    <p class="text-slate-500 text-xs font-medium"> weddings, storage, and platform revenue stats in real-time.</p>
  </div>
  <div class="flex flex-wrap gap-2.5 pt-2 sm:pt-0">
    <a class="border border-primary/20 bg-white hover:bg-slate-50 text-primary px-5 py-2.5 rounded-full font-bold text-xs shadow-sm transition-all" href="/admin/events">
      Review Weddings
    </a>
    <a class="bg-gradient-wedding text-white px-5 py-2.5 rounded-full font-bold text-xs shadow-md hover:shadow-xl transition-all" href="/admin/payments">
      Add Payment
    </a>
  </div>
</section>

<!-- SaaS Hero stats panel -->
<section class="p-8 rounded-2xl bg-gradient-to-r from-[#3b143c] via-[#8d2363] to-[#ff7a59] text-white shadow-xl grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-center mb-8 relative overflow-hidden">
  <div class="lg:col-span-2 space-y-3 relative z-10">
    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/20 rounded-full text-white text-xs font-bold shadow-sm border border-white/10 uppercase tracking-widest font-display">
      SaaS Control Center
    </span>
    <h2 class="font-headline text-3xl font-bold leading-tight">Run the media platform professionally.</h2>
    <p class="text-xs text-slate-200 mt-1 max-w-md">Monitor active weddings, control accounts, moderate uploads, track revenues, and review audit trails.</p>
  </div>
  
  <div class="glass-card p-4 rounded-xl bg-white/10 border-white/10 text-center flex flex-col justify-between h-24 relative z-10">
    <div class="text-2xl font-black text-white mt-2"><%= helpers.formatBytes(stats.storageUsed) %></div>
    <div class="text-[9px] text-slate-200 font-bold uppercase tracking-widest mb-1 font-display">Total Storage</div>
  </div>
  
  <div class="glass-card p-4 rounded-xl bg-white/10 border-white/10 text-center flex flex-col justify-between h-24 relative z-10">
    <div class="text-2xl font-black text-white mt-2">₹<%= Number(stats.paymentRevenue || 0).toLocaleString('en-IN') %></div>
    <div class="text-[9px] text-slate-200 font-bold uppercase tracking-widest mb-1 font-display">Total Revenue</div>
  </div>
</section>

<!-- Bento Grid Metrics -->
<section class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <div class="glass-card p-6 rounded-xl hover:shadow-md transition-all border-l-4 border-l-primary bg-white/60">
    <div class="text-3xl font-black text-primary leading-none"><%= stats.userCount %></div>
    <div class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mt-2">Total Users</div>
    <div class="text-[9px] text-slate-400 mt-1 font-semibold"><%= stats.ownerCount %> owners · <%= stats.superAdminCount %> admins</div>
  </div>
  
  <div class="glass-card p-6 rounded-xl hover:shadow-md transition-all border-l-4 border-l-secondary bg-white/60">
    <div class="text-3xl font-black text-secondary leading-none"><%= stats.eventCount %></div>
    <div class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mt-2">Weddings</div>
    <div class="text-[9px] text-slate-400 mt-1 font-semibold"><%= stats.openUploads %> active links</div>
  </div>
  
  <div class="glass-card p-6 rounded-xl hover:shadow-md transition-all border-l-4 border-l-slate-800 bg-white/60">
    <div class="text-3xl font-black text-slate-800 leading-none"><%= stats.media.total %></div>
    <div class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mt-2">Uploads</div>
    <div class="text-[9px] text-slate-400 mt-1 font-semibold"><%= stats.media.approved %> approved · <%= stats.media.pending %> pending</div>
  </div>
  
  <div class="glass-card p-6 rounded-xl hover:shadow-md transition-all border-l-4 border-l-red-500 bg-white/60">
    <div class="text-3xl font-black text-red-500 leading-none"><%= stats.suspendedUsers %></div>
    <div class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mt-2">Blocked Users</div>
    <div class="text-[9px] text-slate-400 mt-1 font-semibold">Suspended from logging in</div>
  </div>
</section>

<!-- Revenue by Plan & Subscription Plan Distribution -->
<section class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
  <div class="glass-card p-6 rounded-2xl border border-primary/10 bg-white/70 backdrop-blur-xl space-y-4">
    <h2 class="font-headline text-xl font-bold text-slate-800">Revenue by Plan</h2>
    <div class="space-y-4 pt-2">
      <% ['Basic', 'Premium', 'Royal'].forEach(planName => { %>
        <% const record = stats.plansBreakdown.find(p => p.plan_name.toLowerCase() === planName.toLowerCase()) || { count: 0, revenue: 0 }; %>
        <% const pct = stats.paymentRevenue > 0 ? Math.round((record.revenue / stats.paymentRevenue) * 100) : 0; %>
        <div>
          <div class="flex justify-between text-xs font-semibold text-slate-600 mb-1.5">
            <span><%= planName %> Plan (<%= record.count %> Sales)</span>
            <span class="text-primary">₹<%= record.revenue.toLocaleString('en-IN') %> (<%= pct %>%)</span>
          </div>
          <div class="w-full bg-primary/10 h-2 rounded-full overflow-hidden">
            <div class="bg-gradient-wedding h-full rounded-full" style="width: <%= pct %>%"></div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="glass-card p-6 rounded-2xl border border-primary/10 bg-white/70 backdrop-blur-xl space-y-4">
    <h2 class="font-headline text-xl font-bold text-slate-800">Active Subscriptions</h2>
    <div class="space-y-4 pt-2">
      <% ['basic', 'premium', 'royal'].forEach(planSlug => { %>
        <% const record = stats.eventPlansBreakdown.find(p => p.plan === planSlug) || { count: 0 }; %>
        <% const pct = stats.eventCount > 0 ? Math.round((record.count / stats.eventCount) * 100) : 0; %>
        <div>
          <div class="flex justify-between text-xs font-semibold text-slate-600 mb-1.5">
            <span class="capitalize"><%= planSlug %> Package</span>
            <span class="text-primary"><%= record.count %> Events (<%= pct %>%)</span>
          </div>
          <div class="w-full bg-primary/10 h-2 rounded-full overflow-hidden">
            <div class="bg-gradient-wedding h-full rounded-full" style="width: <%= pct %>%"></div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- Recent lists -->
<section class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
  <div class="glass-card p-6 rounded-2xl border border-primary/10 bg-white/70 backdrop-blur-xl space-y-4">
    <div class="flex items-center justify-between">
      <h2 class="font-headline text-xl font-bold text-slate-800">Recent Users</h2>
      <a class="border border-primary/15 bg-white hover:bg-slate-50 text-slate-700 text-xs font-bold px-3 py-1.5 rounded-full shadow-sm" href="/admin/users">View All</a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-left text-xs border-collapse">
        <thead>
          <tr class="border-b border-primary/10 text-[10px] uppercase font-bold text-slate-400 tracking-wider">
            <th class="py-2.5">User</th>
            <th class="py-2.5">Role</th>
            <th class="py-2.5">Status</th>
            <th class="py-2.5">Joined</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-primary/5">
          <% recentUsers.forEach((user) => { %>
            <tr class="hover:bg-primary/5 transition-colors">
              <td class="py-3">
                <a class="font-bold text-slate-800 hover:text-primary transition-colors block" href="/admin/users/<%= user.id %>"><%= user.name %></a>
                <span class="text-[10px] text-slate-400 font-semibold"><%= user.email %></span>
              </td>
              <td class="py-3">
                <span class="px-2 py-0.5 text-[9px] font-extrabold bg-slate-100 text-slate-600 rounded-full border border-slate-200 uppercase"><%= user.role === 'super_admin' ? 'Super Admin' : 'Owner' %></span>
              </td>
              <td class="py-3">
                <span class="px-2 py-0.5 text-[9px] font-extrabold rounded-full border uppercase <%= user.status === 'active' ? 'bg-green-50 text-green-700 border-green-200' : 'bg-red-50 text-red-700 border-red-200' %>"><%= user.status %></span>
              </td>
              <td class="py-3 text-slate-400 font-semibold"><%= helpers.formatDate(user.created_at) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="glass-card p-6 rounded-2xl border border-primary/10 bg-white/70 backdrop-blur-xl space-y-4">
    <div class="flex items-center justify-between">
      <h2 class="font-headline text-xl font-bold text-slate-800">Recent Weddings</h2>
      <a class="border border-primary/15 bg-white hover:bg-slate-50 text-slate-700 text-xs font-bold px-3 py-1.5 rounded-full shadow-sm" href="/admin/events">View All</a>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-left text-xs border-collapse">
        <thead>
          <tr class="border-b border-primary/10 text-[10px] uppercase font-bold text-slate-400 tracking-wider">
            <th class="py-2.5">Wedding</th>
            <th class="py-2.5">Owner</th>
            <th class="py-2.5">Media</th>
            <th class="py-2.5">Storage</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-primary/5">
          <% recentEvents.forEach((event) => { %>
            <tr class="hover:bg-primary/5 transition-colors">
              <td class="py-3">
                <a class="font-bold text-slate-800 hover:text-primary transition-colors block" href="/admin/events/<%= event.id %>"><%= event.title %></a>
                <span class="text-[10px] text-slate-400 font-semibold"><%= event.slug %></span>
              </td>
              <td class="py-3">
                <span class="font-semibold text-slate-700"><%= event.owner_name %></span>
                <div class="text-[10px] text-slate-400 font-semibold"><%= event.owner_email %></div>
              </td>
              <td class="py-3 font-bold text-slate-800"><%= event.media_count || 0 %></td>
              <td class="py-3 text-slate-400 font-semibold uppercase tracking-wider"><%= helpers.formatBytes(event.storage_used || 0) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- Audit Logs -->
<section class="glass-card p-6 rounded-2xl border border-primary/10 bg-white/70 backdrop-blur-xl space-y-4">
  <div class="flex items-center justify-between">
    <div>
      <h2 class="font-headline text-xl font-bold text-slate-800">Latest Audit Activity</h2>
      <p class="text-xs text-slate-500 mt-1">Platform-wide events and administrative actions.</p>
    </div>
    <a class="border border-primary/15 bg-white hover:bg-slate-50 text-slate-700 text-xs font-bold px-3 py-1.5 rounded-full shadow-sm" href="/admin/audit">Full Audit Logs</a>
  </div>
  
  <div class="space-y-3 pt-2">
    <% recentAudit.forEach((log) => { %>
      <div class="flex justify-between items-center bg-white/50 border border-primary/5 rounded-xl p-3.5 shadow-sm">
        <div>
          <strong class="text-sm font-bold text-slate-800"><%= log.action %></strong>
          <p class="text-[10px] text-slate-400 font-semibold mt-0.5">
            <%= log.actor_name || 'System/Guest' %> <%= log.event_title ? `· ${log.event_title}` : '' %>
          </p>
        </div>
        <span class="text-[10px] text-slate-400 font-bold"><%= helpers.formatDate(log.created_at) %></span>
      </div>
    <% }) %>
    <% if (!recentAudit.length) { %>
      <div class="text-center text-slate-400 text-xs py-8">No audit logs found.</div>
    <% } %>
  </div>
</section>
