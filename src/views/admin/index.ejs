<%- include('partials/admin-nav', {
  heading: 'Business Overview',
  subheading: 'Users, weddings, uploads, storage and revenue — one control room.',
  actions: '<a class="btn" href="/admin/events">Review weddings</a><a class="btn secondary" href="/admin/payments">Add payment</a>'
}) %>

<section class="admin-hero">
  <div class="admin-hero-copy">
    <span class="eyebrow light">SaaS Control Center</span>
    <h2>Run the complete wedding media platform professionally.</h2>
    <p>Monitor active weddings, control customers, moderate uploads, track revenue and audit every important action.</p>
  </div>
  <div class="admin-hero-panel">
    <div class="mini-stat"><strong><%= helpers.formatBytes(stats.storageUsed) %></strong><span>Total storage used</span></div>
    <div class="mini-stat"><strong><%= stats.media.pending %></strong><span>Pending approvals</span></div>
    <div class="mini-stat"><strong>₹<%= Number(stats.paymentRevenue || 0).toLocaleString('en-IN') %></strong><span>Recorded paid revenue</span></div>
  </div>
</section>

<section class="stat-grid">
  <article class="stat-card gradient-pink"><span>Total Users</span><strong><%= stats.userCount %></strong><small><%= stats.ownerCount %> owners · <%= stats.superAdminCount %> admins</small></article>
  <article class="stat-card"><span>Wedding Events</span><strong><%= stats.eventCount %></strong><small><%= stats.openUploads %> upload links open</small></article>
  <article class="stat-card"><span>Media Uploads</span><strong><%= stats.media.total %></strong><small><%= stats.media.approved %> approved · <%= stats.media.rejected %> rejected</small></article>
  <article class="stat-card"><span>Suspended Users</span><strong><%= stats.suspendedUsers %></strong><small>Blocked from login/uploads</small></article>
</section>

<section class="grid grid-2" style="margin-top: 24px; gap: 24px; align-items: stretch;">
  <!-- Financial Breakdown -->
  <div class="panel">
    <div class="panel-head">
      <div>
        <h2>Revenue by Plan</h2>
        <p>Earnings breakdown by plan type.</p>
      </div>
    </div>
    <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 12px;">
      <% ['Basic', 'Premium', 'Royal'].forEach(planName => { %>
        <% const record = stats.plansBreakdown.find(p => p.plan_name.toLowerCase() === planName.toLowerCase()) || { count: 0, revenue: 0 }; %>
        <% const pct = stats.paymentRevenue > 0 ? Math.round((record.revenue / stats.paymentRevenue) * 100) : 0; %>
        <div>
          <div style="display: flex; justify-content: space-between; font-size: 0.9rem; font-weight: bold; margin-bottom: 6px;">
            <span><%= planName %> Plan (<%= record.count %> Sales)</span>
            <span class="mono">₹<%= record.revenue.toLocaleString('en-IN') %> (<%= pct %>%)</span>
          </div>
          <div style="background: var(--border); height: 10px; border-radius: 99px; overflow: hidden;">
            <div style="background: linear-gradient(90deg, #b83280, #ff7a59); width: <%= pct %>%; height: 100%; border-radius: 99px;"></div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Subscription Plan Distribution -->
  <div class="panel">
    <div class="panel-head">
      <div>
        <h2>Active Subscriptions</h2>
        <p>Wedding events distribution across plans.</p>
      </div>
    </div>
    <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 12px;">
      <% ['basic', 'premium', 'royal'].forEach(planSlug => { %>
        <% const record = stats.eventPlansBreakdown.find(p => p.plan === planSlug) || { count: 0 }; %>
        <% const pct = stats.eventCount > 0 ? Math.round((record.count / stats.eventCount) * 100) : 0; %>
        <div>
          <div style="display: flex; justify-content: space-between; font-size: 0.9rem; font-weight: bold; margin-bottom: 6px;">
            <span style="text-transform: capitalize;"><%= planSlug %> Package</span>
            <span class="mono"><%= record.count %> Events (<%= pct %>%)</span>
          </div>
          <div style="background: var(--border); height: 10px; border-radius: 99px; overflow: hidden;">
            <div style="background: linear-gradient(90deg, #319795, #4fd1c5); width: <%= pct %>%; height: 100%; border-radius: 99px;"></div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="grid grid-2" style="margin-top:24px; align-items:start;">
  <div class="panel">
    <div class="panel-head">
      <div><h2>Recent users</h2><p>Newest customers and admins.</p></div>
      <a class="btn small secondary" href="/admin/users">View all</a>
    </div>
    <div class="table-wrap">
      <table class="table-like pro-table">
        <thead><tr><th>User</th><th>Role</th><th>Status</th><th>Joined</th></tr></thead>
        <tbody>
          <% recentUsers.forEach((user) => { %>
            <tr>
              <td><a class="strong-link" href="/admin/users/<%= user.id %>"><%= user.name %></a><div class="hint"><%= user.email %></div></td>
              <td><span class="badge"><%= user.role === 'super_admin' ? 'Super Admin' : 'Owner' %></span></td>
              <td><span class="badge <%= user.status === 'active' ? 'approved' : 'rejected' %>"><%= user.status %></span></td>
              <td><%= helpers.formatDate(user.created_at) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="panel">
    <div class="panel-head">
      <div><h2>Recent weddings</h2><p>Latest events created by customers.</p></div>
      <a class="btn small secondary" href="/admin/events">View all</a>
    </div>
    <div class="table-wrap">
      <table class="table-like pro-table">
        <thead><tr><th>Wedding</th><th>Owner</th><th>Media</th><th>Storage</th></tr></thead>
        <tbody>
          <% recentEvents.forEach((event) => { %>
            <tr>
              <td><a class="strong-link" href="/admin/events/<%= event.id %>"><%= event.title %></a><div class="hint"><%= event.slug %></div></td>
              <td><%= event.owner_name %><div class="hint"><%= event.owner_email %></div></td>
              <td><%= event.media_count || 0 %></td>
              <td><%= helpers.formatBytes(event.storage_used || 0) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="panel" style="margin-top:24px;">
  <div class="panel-head">
    <div><h2>Latest audit activity</h2><p>Security and operational actions across the platform.</p></div>
    <a class="btn small secondary" href="/admin/audit">Full audit log</a>
  </div>
  <div class="audit-list">
    <% recentAudit.forEach((log) => { %>
      <div class="audit-item">
        <div><strong><%= log.action %></strong><p><%= log.actor_name || 'System/Guest' %> <%= log.event_title ? `· ${log.event_title}` : '' %></p></div>
        <span class="hint"><%= helpers.formatDate(log.created_at) %></span>
      </div>
    <% }) %>
    <% if (!recentAudit.length) { %><div class="empty">No audit activity yet.</div><% } %>
  </div>
</section>
