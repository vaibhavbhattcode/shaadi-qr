<section class="grid grid-2" style="align-items:center; max-width: 980px; margin: 20px auto;">
  <div>
    <span class="badge">Security verification</span>
    <h1 style="font-size:clamp(2rem,5vw,3.6rem); line-height:1; letter-spacing:-.05em; margin:14px 0;">Two-Factor Auth</h1>
    <p class="muted">Apne authenticator app se 6-digit verification code enter karein login complete karne ke liye.</p>
  </div>
  <form class="card" method="post" action="/login/2fa" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="next" value="<%= next || '' %>">
    <div class="grid">
      <label>Verification Code
        <input name="code" type="text" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" style="text-align: center; font-size: 1.4rem; letter-spacing: 6px;" placeholder="000000" required autocomplete="off" autofocus>
        <% if (errors.code) { %><span class="error-text"><%= errors.code[0] %></span><% } %>
      </label>
      <button class="btn" type="submit">Verify & Log In</button>
      <p class="hint"><a href="/login">Back to Login</a>.</p>
    </div>
  </form>
</section>
