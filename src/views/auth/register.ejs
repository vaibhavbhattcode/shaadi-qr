<section class="grid grid-2" style="align-items:center; max-width: 980px; margin: 40px auto; gap: 32px; padding: 0 16px; min-height: calc(100vh - 200px);">
  <div class="animate-fadein" style="animation-delay: 100ms;">
    <span class="badge" style="background: rgba(184, 50, 128, 0.08); border-color: rgba(184, 50, 128, 0.2); color: var(--brand); font-weight: 800;">📸 Start Your Album</span>
    <h1 style="font-size:clamp(2rem,5vw,3.6rem); line-height:1.05; letter-spacing:-.05em; margin:18px 0; font-family:'Playfair Display', serif; font-weight: 800;">
      Create Owner Account
    </h1>
    <p class="muted" style="font-size: clamp(.95rem, 2.5vw, 1.1rem); line-height: 1.6;">
      Create an account to generate custom QR codes, manage guest media folders, customize your live slideshow gallery, and download high-resolution albums in one click.
    </p>
  </div>
  
  <div class="card animate-fadein" style="padding: 32px; border-radius: 24px; background: rgba(255, 255, 255, 0.9); box-shadow: var(--shadow); border: 1px solid rgba(184, 50, 128, 0.08); animation-delay: 200ms;">
    <!-- Dynamic Error Alert Box -->
    <div id="register-error-alert" class="alert error" style="display: none; padding: 12px 16px; margin-bottom: 20px; font-weight: 700; border-radius: 12px; font-size: 0.92rem;"></div>

    <div class="grid" style="gap: 20px;">
      
      <!-- 1. Email OTP Registration Form -->
      <div class="grid" style="gap: 16px;">
        <div id="register-fields-wrapper">
          <label style="font-weight: 700; color: #3b2435; font-size: 0.9rem; margin-bottom: 12px;">Full Name
            <input type="text" id="reg-name-input" required placeholder="E.g., Ananya & Rahul" style="margin-top: 4px;">
          </label>
          
          <label style="font-weight: 700; color: #3b2435; font-size: 0.9rem; margin-bottom: 12px; margin-top: 12px;">Email Address
            <input type="email" id="reg-email-input" required placeholder="name@example.com" style="margin-top: 4px;">
            <span class="hint" style="margin-top: 4px; display: block;">We will send a 6-digit verification code to this email address.</span>
          </label>
          
          <label style="font-weight: 700; color: #3b2435; font-size: 0.9rem; margin-bottom: 12px; margin-top: 12px;">Password
            <input type="password" id="reg-password-input" required placeholder="Minimum 8 characters" style="margin-top: 4px;">
          </label>
        </div>

        <div id="otp-info-msg" class="alert success" style="display: none; padding: 12px; font-size: 0.9rem; margin: 10px 0; border-radius: 12px;"></div>

        <button id="send-otp-btn" class="btn bg-gradient-wedding" style="width: 100%; margin-top: 8px;">Register & Send Verification OTP</button>

        <!-- 2. OTP Verification Input -->
        <div id="otp-verify-section" class="grid" style="display: none; gap: 16px; margin-top: 16px;">
          <label style="font-weight: 700; color: #3b2435; font-size: 0.9rem;">Enter 6-Digit Code
            <input type="text" id="otp-code-input" placeholder="••••••" maxlength="6" style="text-align: center; letter-spacing: 0.3em; font-weight: 900; font-size: 1.4rem; margin-top: 4px; border-radius: 12px;">
          </label>
          <button id="verify-otp-btn" class="btn green" style="width: 100%;">Verify & Complete Sign Up</button>
          
          <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px; flex-wrap: wrap; gap: 10px;">
            <span class="hint" style="color: var(--muted); font-weight: 700;">
              Expires in: <strong id="otp-countdown" style="color: var(--brand);">10:00</strong>
            </span>
            <button id="resend-otp-btn" class="btn secondary small" style="padding: 4px 12px; min-height: 30px; font-size: 0.8rem;" disabled>Resend OTP</button>
          </div>
        </div>
      </div>

      <!-- Google SSO Section / Divider -->
      <% if (googleClientId) { %>
        <div style="display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 14px; margin-bottom: 6px;">
          <div style="flex: 1; height: 1px; background: var(--border);"></div>
          <span class="hint" style="font-weight: 700;">or continue with</span>
          <div style="flex: 1; height: 1px; background: var(--border);"></div>
        </div>
        
        <div id="g_id_onload"
             data-client_id="<%= googleClientId %>"
             data-context="signup"
             data-ux_mode="popup"
             data-callback="handleCredentialResponse"
             data-auto_prompt="false">
        </div>
        <div class="g_id_signin"
             data-type="standard"
             data-shape="pill"
             data-theme="outline"
             data-text="signup_with"
             data-size="large"
             data-logo_alignment="center"
             style="display: flex; justify-content: center;">
        </div>
      <% } else { %>
        <div style="display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 14px; margin-bottom: 6px;">
          <div style="flex: 1; height: 1px; background: var(--border);"></div>
          <span class="hint" style="font-weight: 700;">or continue with</span>
          <div style="flex: 1; height: 1px; background: var(--border);"></div>
        </div>
        
        <button id="mock-google-btn" class="btn secondary" style="width: 100%; gap: 10px; border-radius: 999px; font-weight: 800; font-size: 0.92rem; border: 1px solid var(--border);">
          <svg style="width: 18px; height: 18px; fill: currentColor;" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.24 10.285V14.4h6.887c-.648 2.41-2.519 4.114-5.136 4.114-3.51 0-6.357-2.827-6.357-6.314 0-3.487 2.848-6.314 6.357-6.314 1.474 0 2.85.5 3.945 1.427l3.125-3.125C18.91 2.057 15.74.8 12.24.8 6.068.8 1.07 5.798 1.07 12s4.997 11.2 11.17 11.2c5.8 0 10.22-3.99 10.22-10.2 0-.61-.065-1.185-.18-1.715H12.24z"/>
          </svg>
          Google Sign-Up (Mock)
        </button>
      <% } %>
      
      <div class="divider" style="margin: 14px 0;"></div>
      
      <p class="hint" style="text-align: center; font-weight: 750;">Already have an account? <a class="strong-link" href="/login" style="color: var(--brand);">Log In</a></p>
    </div>
  </div>
</section>

<script>
  let countdownInterval = null;
  let cooldownInterval = null;

  function showRegisterError(msg) {
    const errorAlert = document.getElementById('register-error-alert');
    if (errorAlert) {
      errorAlert.innerText = msg;
      errorAlert.style.display = 'block';
      errorAlert.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    } else {
      alert(msg);
    }
  }

  function startTimers() {
    clearInterval(countdownInterval);
    clearInterval(cooldownInterval);

    // 1. Expiry Countdown (10 minutes)
    let totalSeconds = 10 * 60;
    const countdownEl = document.getElementById('otp-countdown');
    const verifyBtn = document.getElementById('verify-otp-btn');
    if (verifyBtn) verifyBtn.disabled = false;
    if (countdownEl) {
      countdownEl.style.color = 'var(--brand)';
      countdownEl.innerText = '10:00';
    }

    countdownInterval = setInterval(() => {
      totalSeconds--;
      if (totalSeconds <= 0) {
        clearInterval(countdownInterval);
        if (countdownEl) {
          countdownEl.innerText = 'Expired';
          countdownEl.style.color = 'var(--red)';
        }
        if (verifyBtn) verifyBtn.disabled = true;
      } else {
        const mins = String(Math.floor(totalSeconds / 60)).padStart(2, '0');
        const secs = String(totalSeconds % 60).padStart(2, '0');
        if (countdownEl) countdownEl.innerText = `${mins}:${secs}`;
      }
    }, 1000);

    // 2. Cooldown for Resend (60 seconds)
    let cooldownSeconds = 60;
    const resendBtn = document.getElementById('resend-otp-btn');
    if (resendBtn) {
      resendBtn.disabled = true;
      resendBtn.innerText = `Resend OTP (${cooldownSeconds}s)`;
    }

    cooldownInterval = setInterval(() => {
      cooldownSeconds--;
      if (cooldownSeconds <= 0) {
        clearInterval(cooldownInterval);
        if (resendBtn) {
          resendBtn.disabled = false;
          resendBtn.innerText = 'Resend OTP';
        }
      } else {
        if (resendBtn) resendBtn.innerText = `Resend OTP (${cooldownSeconds}s)`;
      }
    }, 1000);
  }

  function handleCredentialResponse(response) {
    const errorAlert = document.getElementById('register-error-alert');
    if (errorAlert) errorAlert.style.display = 'none';

    fetch('/auth/google', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      },
      body: JSON.stringify({ credential: response.credential })
    })
    .then(res => res.json())
    .then(data => {
      if (data.ok) {
        window.location.href = data.redirectUrl || '/dashboard';
      } else {
        showRegisterError(data.error || 'Google Registration failed');
      }
    })
    .catch(err => {
      console.error(err);
      showRegisterError('Google verification request failed.');
    });
  }

  function mockGoogleLogin() {
    const errorAlert = document.getElementById('register-error-alert');
    if (errorAlert) errorAlert.style.display = 'none';

    fetch('/auth/google/mock', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      }
    })
    .then(res => res.json())
    .then(data => {
      if (data.ok) {
        window.location.href = data.redirectUrl || '/dashboard';
      } else {
        showRegisterError(data.error || 'Mock Sign Up failed');
      }
    });
  }

  function sendEmailOtp() {
    const errorAlert = document.getElementById('register-error-alert');
    if (errorAlert) errorAlert.style.display = 'none';

    const name = document.getElementById('reg-name-input').value.trim();
    const email = document.getElementById('reg-email-input').value.trim();
    const password = document.getElementById('reg-password-input').value;

    if (!name || !email || !password) {
      showRegisterError('Please fill in all fields (Name, Email, and Password).');
      return;
    }
    if (password.length < 8) {
      showRegisterError('Password must be at least 8 characters.');
      return;
    }
    
    const sendBtn = document.getElementById('send-otp-btn');
    const resendBtn = document.getElementById('resend-otp-btn');
    sendBtn.disabled = true;
    sendBtn.innerText = 'Sending Code...';
    if (resendBtn) resendBtn.disabled = true;

    fetch('/auth/email/send-otp', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      },
      body: JSON.stringify({ email, action: 'register' })
    })
    .then(res => res.json())
    .then(data => {
      if (data.ok) {
        document.getElementById('otp-verify-section').style.display = 'grid';
        document.getElementById('register-fields-wrapper').style.opacity = '0.5';
        document.getElementById('reg-name-input').disabled = true;
        document.getElementById('reg-email-input').disabled = true;
        document.getElementById('reg-password-input').disabled = true;
        sendBtn.style.display = 'none';
        
        const otpInfo = document.getElementById('otp-info-msg');
        otpInfo.style.display = 'block';
        if (data.mockOtp) {
          otpInfo.innerHTML = `Code sent! <strong style="color:var(--brand)">Demo Fallback: OTP is ${data.mockOtp}</strong>`;
        } else {
          otpInfo.innerText = 'Verification code has been sent successfully to your email.';
        }

        startTimers();
      } else {
        showRegisterError(data.error || 'Failed to send OTP. Please try again.');
        sendBtn.disabled = false;
        sendBtn.innerText = 'Register & Send Verification OTP';
        if (resendBtn) resendBtn.disabled = false;
      }
    })
    .catch(err => {
      console.error(err);
      showRegisterError('Error requesting verification OTP.');
      sendBtn.disabled = false;
      sendBtn.innerText = 'Register & Send Verification OTP';
      if (resendBtn) resendBtn.disabled = false;
    });
  }

  function verifyEmailOtpAndRegister() {
    const errorAlert = document.getElementById('register-error-alert');
    if (errorAlert) errorAlert.style.display = 'none';

    const name = document.getElementById('reg-name-input').value.trim();
    const email = document.getElementById('reg-email-input').value.trim();
    const password = document.getElementById('reg-password-input').value;
    const code = document.getElementById('otp-code-input').value.trim();

    if (!code || code.length !== 6) {
      showRegisterError('Please enter a valid 6-digit OTP code.');
      return;
    }

    const verifyBtn = document.getElementById('verify-otp-btn');
    verifyBtn.disabled = true;
    verifyBtn.innerText = 'Creating Account...';

    fetch('/auth/email/register-verify', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      },
      body: JSON.stringify({ name, email, password, code })
    })
    .then(res => res.json())
    .then(data => {
      if (data.ok) {
        window.location.href = data.redirectUrl || '/dashboard';
      } else {
        showRegisterError(data.error || 'Incorrect code or registration failed.');
        verifyBtn.disabled = false;
        verifyBtn.innerText = 'Verify & Complete Sign Up';
      }
    })
    .catch(err => {
      console.error(err);
      showRegisterError('Registration verification request failed.');
      verifyBtn.disabled = false;
      verifyBtn.innerText = 'Verify & Complete Sign Up';
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const sendOtpBtn = document.getElementById('send-otp-btn');
    const verifyOtpBtn = document.getElementById('verify-otp-btn');
    const resendOtpBtn = document.getElementById('resend-otp-btn');
    const mockGoogleBtn = document.getElementById('mock-google-btn');
    const regPasswordInput = document.getElementById('reg-password-input');
    const otpCodeInput = document.getElementById('otp-code-input');

    if (sendOtpBtn) {
      sendOtpBtn.addEventListener('click', sendEmailOtp);
    }
    if (verifyOtpBtn) {
      verifyOtpBtn.addEventListener('click', verifyEmailOtpAndRegister);
    }
    if (resendOtpBtn) {
      resendOtpBtn.addEventListener('click', sendEmailOtp);
    }
    if (mockGoogleBtn) {
      mockGoogleBtn.addEventListener('click', mockGoogleLogin);
    }

    if (regPasswordInput) {
      regPasswordInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          sendEmailOtp();
        }
      });
    }
    if (otpCodeInput) {
      otpCodeInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          verifyEmailOtpAndRegister();
        }
      });
    }
  });
</script>
