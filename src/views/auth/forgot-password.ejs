<section class="grid grid-2" style="align-items:center; max-width: 980px; margin: 20px auto;">
  <div>
    <span class="badge">Password recovery</span>
    <h1 style="font-size:clamp(2rem,5vw,3.6rem); line-height:1; letter-spacing:-.05em; margin:14px 0;">Forgot Password</h1>
    <p class="muted">Apna email address enter karein. Agar aapka account hoga, to recovery link generate ho jayegi.</p>
  </div>
  <form class="card" method="post" action="/forgot-password" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="grid">
      <label>Email Address
        <input type="email" name="email" value="<%= email || '' %>" required autocomplete="email" placeholder="name@example.com">
        <% if (errors.email) { %><span class="error-text"><%= errors.email[0] %></span><% } %>
      </label>
      <button class="btn" type="submit">Send Reset Link</button>
      <p class="hint">Remembered? <a href="/login">Back to Login</a>.</p>
    </div>
  </form>
</section>
