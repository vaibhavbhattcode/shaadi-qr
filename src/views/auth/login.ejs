<!-- Modern Premium Auth Login View -->
<section class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center max-w-5xl mx-auto py-12 px-4 sm:px-6 min-h-[calc(100vh-220px)] relative">
  <!-- Dynamic blurred background decoration -->
  <div class="absolute -top-40 -left-40 w-96 h-96 bg-primary/10 rounded-full blur-3xl -z-10 animate-glow"></div>
  
  <div class="lg:col-span-6 space-y-6 text-left animate-fadein">
    <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary/10 rounded-full text-primary text-xs font-bold shadow-sm border border-primary/15">
      <%= isAdminMode ? '🔒 Staff Portal' : '✨ Secure Login' %>
    </span>
    <h1 class="font-headline text-4xl sm:text-5xl md:text-6xl font-black text-slate-900 leading-tight">
      <%= isAdminMode ? 'Super Admin Console' : 'Welcome to ShaadiShots' %>
    </h1>
    <p class="text-slate-600 text-sm sm:text-base leading-relaxed">
      <%= isAdminMode ? 'Authorized staff credentials required to access the central administration and monitoring tools.' : 'Log in to manage your wedding events, customize QR codes, moderate guest uploads, and download professional photo ZIPs.' %>
    </p>
  </div>
  
  <div class="lg:col-span-6 animate-fadein" style="animation-delay: 150ms;">
    <div class="glass-card p-6 sm:p-8 rounded-3xl border border-primary/10 bg-white/70 backdrop-blur-xl shadow-lg space-y-6">
      
      <!-- Dynamic Error Alert Box -->
      <div id="login-error-alert" class="alert error hidden p-3.5 mb-4 text-xs font-bold rounded-xl bg-red-50 text-red-700 border border-red-200 shadow-sm"></div>

      <% if (isAdminMode) { %>
        <!-- Admin Email Login Form -->
        <form class="space-y-4" method="post" action="/login" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="next" value="<%= values.next || '/admin' %>">
          <input type="hidden" name="admin" value="1">
          
          <div class="space-y-1.5">
            <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Admin Email</label>
            <input type="email" name="email" autocomplete="email" value="<%= values.email || '' %>" required placeholder="admin@shaadishots.com" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-2.5 focus:ring-primary focus:border-primary text-sm">
            <% if (errors.email) { %><span class="text-xs text-red-600 font-semibold mt-1 block"><%= errors.email[0] %></span><% } %>
          </div>
          
          <div class="space-y-1.5">
            <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Password</label>
            <input type="password" name="password" autocomplete="current-password" required placeholder="••••••••" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-2.5 focus:ring-primary focus:border-primary text-sm">
            <% if (errors.password) { %><span class="text-xs text-red-600 font-semibold mt-1 block"><%= errors.password[0] %></span><% } %>
          </div>
          
          <button class="w-full bg-gradient-wedding text-white px-5 py-3.5 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all" type="submit">Verify Admin Access</button>
          <p class="text-center text-xs font-bold pt-2"><a href="/login" class="text-primary hover:underline">← Back to Regular Login</a></p>
        </form>
      <% } else { %>
        <!-- Public Login Form Container -->
        <div class="space-y-6">
          
          <!-- Tab Swapper -->
          <div class="login-tabs flex border-b border-primary/10 gap-4 mb-2">
            <button type="button" class="tab-btn active flex-1 text-center py-2.5 font-extrabold text-xs uppercase tracking-wider text-primary border-b-2 border-primary focus:outline-none transition-all" id="tab-otp-btn" onclick="switchLoginTab('otp')">
              ✉️ Passwordless OTP
            </button>
            <button type="button" class="tab-btn flex-1 text-center py-2.5 font-extrabold text-xs uppercase tracking-wider text-slate-400 border-b-2 border-transparent focus:outline-none transition-all" id="tab-email-btn" onclick="switchLoginTab('email')">
              🔑 Password Login
            </button>
          </div>

          <!-- 1. Email OTP Login Content -->
          <div id="tab-otp-content" class="space-y-4">
            <div id="email-field-wrapper" class="space-y-1.5">
              <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Email Address</label>
              <input type="email" id="email-otp-input" placeholder="name@example.com" required class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-2.5 focus:ring-primary focus:border-primary text-sm">
              <span class="hint block text-[10px] text-slate-400 font-medium">We will send a 6-digit OTP to this email for passwordless verification.</span>
            </div>

            <div id="otp-info-msg" class="alert success hidden p-3.5 text-xs font-bold rounded-xl bg-green-50 text-green-700 border border-green-200 shadow-sm"></div>

            <button id="send-otp-btn" class="w-full bg-gradient-wedding text-white px-5 py-3.5 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all">Send Verification OTP</button>

            <!-- OTP input verify -->
            <div id="otp-verify-section" class="hidden space-y-4 pt-4 border-t border-primary/5">
              <div class="space-y-1.5">
                <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Enter 6-Digit Code</label>
                <input type="text" id="otp-code-input" placeholder="••••••" maxlength="6" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-3 font-mono text-lg tracking-widest text-center focus:ring-primary focus:border-primary">
              </div>
              <button id="verify-otp-btn" class="w-full bg-green-500 hover:bg-green-600 text-white px-5 py-3.5 rounded-full font-bold text-sm shadow-md transition-all">Verify & Log In</button>
              
              <div class="flex justify-between items-center flex-wrap gap-2 text-xs font-bold">
                <span class="text-slate-500">
                  Expires in: <strong id="otp-countdown" class="text-primary">10:00</strong>
                </span>
                <button id="resend-otp-btn" class="border border-primary/15 bg-white text-slate-600 hover:bg-slate-50 px-3 py-1.5 rounded-full text-[10px] font-bold shadow-sm transition-all" disabled>Resend OTP</button>
              </div>
            </div>
          </div>

          <!-- 2. Email & Password Login Content -->
          <div id="tab-email-content" class="hidden space-y-4">
            <form class="space-y-4" method="post" action="/login" novalidate>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="next" value="<%= values.next || '' %>">
              
              <div class="space-y-1.5">
                <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Email Address</label>
                <input type="email" name="email" autocomplete="email" value="<%= values.email || '' %>" required placeholder="name@example.com" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-2.5 focus:ring-primary focus:border-primary text-sm">
                <% if (errors.email) { %><span class="text-xs text-red-600 font-semibold mt-1 block"><%= errors.email[0] %></span><% } %>
              </div>
              
              <div class="space-y-1.5">
                <label class="text-[10px] uppercase font-bold text-primary tracking-widest ml-1">Password</label>
                <input type="password" name="password" autocomplete="current-password" required placeholder="••••••••" class="w-full bg-white/50 border border-primary/15 rounded-lg px-4 py-2.5 focus:ring-primary focus:border-primary text-sm">
                <% if (errors.password) { %><span class="text-xs text-red-600 font-semibold mt-1 block"><%= errors.password[0] %></span><% } %>
              </div>
              
              <div class="flex justify-end pt-1">
                <a class="text-xs font-bold text-primary hover:underline" href="/forgot-password">Forgot password?</a>
              </div>
              
              <button class="w-full bg-gradient-wedding text-white px-5 py-3.5 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all" type="submit">Verify & Log In</button>
            </form>
          </div>

          <!-- Google SSO Section / Divider -->
          <div class="space-y-4">
            <div class="flex items-center gap-3 py-2 text-xs font-bold text-slate-400">
              <div class="flex-1 h-px bg-primary/10"></div>
              <span>or continue with</span>
              <div class="flex-1 h-px bg-primary/10"></div>
            </div>
            
            <% if (googleClientId) { %>
              <div id="g_id_onload"
                   data-client_id="<%= googleClientId %>"
                   data-context="signin"
                   data-ux_mode="popup"
                   data-callback="handleCredentialResponse"
                   data-auto_prompt="false">
              </div>
              <div class="g_id_signin flex justify-center"
                   data-type="standard"
                   data-shape="pill"
                   data-theme="outline"
                   data-text="signin_with"
                   data-size="large"
                   data-logo_alignment="center">
              </div>
            <% } else { %>
              <button id="mock-google-btn" class="w-full flex items-center justify-center gap-2 border border-primary/15 bg-white hover:bg-slate-50 text-slate-700 py-3 rounded-full font-extrabold text-xs shadow-sm transition-all">
                <svg class="w-4.5 h-4.5 fill-current text-slate-600" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12.24 10.285V14.4h6.887c-.648 2.41-2.519 4.114-5.136 4.114-3.51 0-6.357-2.827-6.357-6.314 0-3.487 2.848-6.314 6.357-6.314 1.474 0 2.85.5 3.945 1.427l3.125-3.125C18.91 2.057 15.74.8 12.24.8 6.068.8 1.07 5.798 1.07 12s4.997 11.2 11.17 11.2c5.8 0 10.22-3.99 10.22-10.2 0-.61-.065-1.185-.18-1.715H12.24z"/>
                </svg>
                Google Single Sign-On (Mock)
              </button>
            <% } %>
          </div>
          
          <div class="divider border-b border-primary/5 pt-2"></div>
          
          <div class="flex justify-between items-center text-xs font-bold flex-wrap gap-3">
            <% if (registrationEnabled) { %>
              <span class="text-slate-500">New to ShaadiShots? <a class="text-primary hover:underline" href="/register">Create Album</a></span>
            <% } %>
            <a class="text-slate-400 hover:text-primary transition-colors" href="/login?admin=1">Staff Portal Login</a>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<script>
  function switchLoginTab(tab) {
    const otpContent = document.getElementById('tab-otp-content');
    const emailContent = document.getElementById('tab-email-content');
    const otpBtn = document.getElementById('tab-otp-btn');
    const emailBtn = document.getElementById('tab-email-btn');
    
    if (tab === 'otp') {
      if (otpContent) otpContent.style.display = 'block';
      if (emailContent) emailContent.style.display = 'none';
      if (otpBtn) {
        otpBtn.style.color = 'var(--brand)';
        otpBtn.style.borderBottomColor = 'var(--brand)';
        otpBtn.classList.add('active');
      }
      if (emailBtn) {
        emailBtn.style.color = 'var(--muted)';
        emailBtn.style.borderBottomColor = 'transparent';
        emailBtn.classList.remove('active');
      }
    } else {
      if (otpContent) otpContent.style.display = 'none';
      if (emailContent) emailContent.style.display = 'block';
      if (otpBtn) {
        otpBtn.style.color = 'var(--muted)';
        otpBtn.style.borderBottomColor = 'transparent';
        otpBtn.classList.remove('active');
      }
      if (emailBtn) {
        emailBtn.style.color = 'var(--brand)';
        emailBtn.style.borderBottomColor = 'var(--brand)';
        emailBtn.classList.add('active');
      }
    }
  }

  let countdownInterval = null;
  let cooldownInterval = null;

  function showLoginError(msg) {
    const errorAlert = document.getElementById('login-error-alert');
    if (errorAlert) {
      errorAlert.innerText = msg;
      errorAlert.style.display = 'block';
      errorAlert.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    } else {
      alert(msg);
    }
  }

  function startTimers() {
    clearInterval(countdownInterval);
    clearInterval(cooldownInterval);

    // 1. Expiry Countdown (10 minutes)
    let totalSeconds = 10 * 60;
    const countdownEl = document.getElementById('otp-countdown');
    const verifyBtn = document.getElementById('verify-otp-btn');
    if (verifyBtn) verifyBtn.disabled = false;
    if (countdownEl) {
      countdownEl.style.color = 'var(--brand)';
      countdownEl.innerText = '10:00';
    }

    countdownInterval = setInterval(() => {
      totalSeconds--;
      if (totalSeconds <= 0) {
        clearInterval(countdownInterval);
        if (countdownEl) {
          countdownEl.innerText = 'Expired';
          countdownEl.style.color = 'var(--red)';
        }
        if (verifyBtn) verifyBtn.disabled = true;
      } else {
        const mins = String(Math.floor(totalSeconds / 60)).padStart(2, '0');
        const secs = String(totalSeconds % 60).padStart(2, '0');
        if (countdownEl) countdownEl.innerText = `${mins}:${secs}`;
      }
    }, 1000);

    // 2. Cooldown for Resend (60 seconds)
    let cooldownSeconds = 60;
    const resendBtn = document.getElementById('resend-otp-btn');
    if (resendBtn) {
      resendBtn.disabled = true;
      resendBtn.innerText = `Resend OTP (${cooldownSeconds}s)`;
    }

    cooldownInterval = setInterval(() => {
      cooldownSeconds--;
      if (cooldownSeconds <= 0) {
        clearInterval(cooldownInterval);
        if (resendBtn) {
          resendBtn.disabled = false;
          resendBtn.innerText = 'Resend OTP';
        }
      } else {
        if (resendBtn) resendBtn.innerText = `Resend OTP (${cooldownSeconds}s)`;
      }
    }, 1000);
  }

  function handleCredentialResponse(response) {
    const errorAlert = document.getElementById('login-error-alert');
    if (errorAlert) errorAlert.style.display = 'none';

    fetch('/auth/google', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      },
      body: JSON.stringify({ credential: response.credential })
    })
    .then(res => res.json())
    .then(data => {
      if (data.ok) {
        window.location.href = data.redirectUrl || '/dashboard';
      } else {
        showLoginError(data.error || 'Google Login failed');
      }
    })
    .catch(err => {
      console.error(err);
      showLoginError('Google validation request failed.');
    });
  }

  function mockGoogleLogin() {
    const errorAlert = document.getElementById('login-error-alert');
    if (errorAlert) errorAlert.style.display = 'none';

    fetch('/auth/google/mock', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      }
    })
    .then(res => res.json())
    .then(data => {
      if (data.ok) {
        window.location.href = data.redirectUrl || '/dashboard';
      } else {
        showLoginError(data.error || 'Mock Login failed');
      }
    });
  }

  function sendEmailOtp() {
    const errorAlert = document.getElementById('login-error-alert');
    if (errorAlert) errorAlert.style.display = 'none';

    const email = document.getElementById('email-otp-input').value.trim();
    if (!email) {
      showLoginError('Please enter your email address.');
      return;
    }
    
    const sendBtn = document.getElementById('send-otp-btn');
    const resendBtn = document.getElementById('resend-otp-btn');
    sendBtn.disabled = true;
    sendBtn.innerText = 'Sending Code...';
    if (resendBtn) resendBtn.disabled = true;

    fetch('/auth/email/send-otp', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      },
      body: JSON.stringify({ email, action: 'login' })
    })
    .then(res => res.json())
    .then(data => {
      if (data.ok) {
        document.getElementById('otp-verify-section').style.display = 'grid';
        document.getElementById('email-field-wrapper').style.opacity = '0.5';
        document.getElementById('email-otp-input').disabled = true;
        sendBtn.style.display = 'none';
        
        const otpInfo = document.getElementById('otp-info-msg');
        otpInfo.style.display = 'block';
        if (data.mockOtp) {
          otpInfo.innerHTML = `Code sent! <strong style="color:var(--brand)">Demo Fallback: OTP is ${data.mockOtp}</strong>`;
        } else {
          otpInfo.innerText = 'Verification code has been sent successfully to your email.';
        }

        startTimers();
      } else {
        showLoginError(data.error || 'Failed to send OTP. Please try again.');
        sendBtn.disabled = false;
        sendBtn.innerText = 'Send Verification OTP';
        if (resendBtn) resendBtn.disabled = false;
      }
    })
    .catch(err => {
      console.error(err);
      showLoginError('Error requesting verification OTP.');
      sendBtn.disabled = false;
      sendBtn.innerText = 'Send Verification OTP';
      if (resendBtn) resendBtn.disabled = false;
    });
  }

  function verifyEmailOtp() {
    const errorAlert = document.getElementById('login-error-alert');
    if (errorAlert) errorAlert.style.display = 'none';

    const email = document.getElementById('email-otp-input').value.trim();
    const code = document.getElementById('otp-code-input').value.trim();
    if (!code || code.length !== 6) {
      showLoginError('Please enter a valid 6-digit OTP code.');
      return;
    }

    const verifyBtn = document.getElementById('verify-otp-btn');
    verifyBtn.disabled = true;
    verifyBtn.innerText = 'Verifying...';

    fetch('/auth/email/verify-otp', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
      },
      body: JSON.stringify({ email, code, next: '<%= values.next || "" %>' })
    })
    .then(res => res.json())
    .then(data => {
      if (data.ok) {
        window.location.href = data.redirectUrl || '/dashboard';
      } else {
        showLoginError(data.error || 'Incorrect code. Please check and try again.');
        verifyBtn.disabled = false;
        verifyBtn.innerText = 'Verify & Log In';
      }
    })
    .catch(err => {
      console.error(err);
      showLoginError('Verification request failed.');
      verifyBtn.disabled = false;
      verifyBtn.innerText = 'Verify & Log In';
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const sendOtpBtn = document.getElementById('send-otp-btn');
    const verifyOtpBtn = document.getElementById('verify-otp-btn');
    const resendOtpBtn = document.getElementById('resend-otp-btn');
    const mockGoogleBtn = document.getElementById('mock-google-btn');
    const emailOtpInput = document.getElementById('email-otp-input');
    const otpCodeInput = document.getElementById('otp-code-input');

    if (sendOtpBtn) {
      sendOtpBtn.addEventListener('click', sendEmailOtp);
    }
    if (verifyOtpBtn) {
      verifyOtpBtn.addEventListener('click', verifyEmailOtp);
    }
    if (resendOtpBtn) {
      resendOtpBtn.addEventListener('click', sendEmailOtp);
    }
    if (mockGoogleBtn) {
      mockGoogleBtn.addEventListener('click', mockGoogleLogin);
    }

    if (emailOtpInput) {
      emailOtpInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          sendEmailOtp();
        }
      });
    }
    if (otpCodeInput) {
      otpCodeInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          verifyEmailOtp();
        }
      });
    }
  });
</script>
