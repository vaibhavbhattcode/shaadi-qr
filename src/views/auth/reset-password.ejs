<section class="grid grid-2" style="align-items:center; max-width: 980px; margin: 20px auto;">
  <div>
    <span class="badge">Create new password</span>
    <h1 style="font-size:clamp(2rem,5vw,3.6rem); line-height:1; letter-spacing:-.05em; margin:14px 0;">Reset Password</h1>
    <p class="muted">Naya strong password select karein security aur login restore karne ke liye.</p>
  </div>
  <form class="card" method="post" action="/reset-password" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="token" value="<%= token %>">
    <div class="grid">
      <label>New Password
        <input type="password" name="password" required autocomplete="new-password" placeholder="Min 8 characters">
        <% if (errors.password) { %><span class="error-text"><%= errors.password[0] %></span><% } %>
      </label>
      <button class="btn" type="submit">Update Password</button>
      <p class="hint"><a href="/login">Back to Login</a>.</p>
    </div>
  </form>
</section>
