<!doctype html>
<html lang="en" class="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <title><%= locals.title ? `${title} · ${appName}` : appName %></title>
  <script src="https://accounts.google.com/gsi/client" async defer></script>
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#b83280",
            secondary: "#ff7a59",
            gold: "#c58a13",
            surface: "#ffffff",
            "on-surface-variant": "#4a4a4a",
          },
          borderRadius: {
            "DEFAULT": "0.5rem",
            "lg": "12px",
            "xl": "1.5rem",
            "full": "9999px"
          },
          fontFamily: {
            headline: ["Playfair Display", "serif"],
            display: ["Public Sans", "sans-serif"],
            body: ["Plus Jakarta Sans", "sans-serif"],
            label: ["Public Sans", "sans-serif"]
          },
          boxShadow: {
            'rose': '0 10px 30px -10px rgba(184, 50, 128, 0.15)',
          }
        },
      },
    }
  </script>

  <style>
    /* Premium aesthetics CSS variables */
    :root {
      --bg: #fdf8f9;
      --bg-deep: #201021;
      --surface: rgba(255,255,255,.86);
      --surface-solid: #ffffff;
      --text: #24111f;
      --muted: #7c6578;
      --brand: #b83280;
      --brand-dark: #8d2363;
      --brand2: #ff7a59;
      --gold: #c58a13;
      --green: #12805c;
      --red: #b42318;
      --blue: #1d4ed8;
      --border: rgba(184, 50, 128, 0.15);
      --border-strong: rgba(184, 50, 128, 0.25);
      --shadow: 0 24px 70px rgba(78, 30, 62, .13);
      --shadow-soft: 0 14px 34px rgba(78, 30, 62, .08);
      --radius: 12px;
      --radius-sm: 8px;
    }

    body::before {
      content: ""; 
      position: fixed; 
      inset: 0; 
      pointer-events: none; 
      opacity: .35;
      background-image: radial-gradient(rgba(184,50,128,.08) 1px, transparent 1px);
      background-size: 24px 24px; 
      mask-image: linear-gradient(to bottom, #000, transparent 70%);
      z-index: 1;
    }

    body {
      margin: 0;
      font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, -apple-system, sans-serif !important;
      color: var(--text);
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: 'Playfair Display', serif !important;
      font-weight: 700;
    }

    /* Premium utility classes */
    .glass-card {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(184, 50, 128, 0.12);
    }
    .bg-gradient-wedding {
      background: linear-gradient(135deg, #b83280 0%, #ff7a59 100%);
    }
    .text-gradient-wedding {
      background: linear-gradient(135deg, #b83280 0%, #ff7a59 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .container { position: relative; max-width: 1240px; margin: 0 auto; padding: 30px 20px 60px; }
    .card, .panel { background: var(--surface); border: 1px solid rgba(239, 214, 230, .92); border-radius: var(--radius); box-shadow: var(--shadow-soft); padding: 22px; backdrop-filter: blur(18px); }
    .panel { box-shadow: var(--shadow); }
    .card.soft { box-shadow: none; background: rgba(255,255,255,.62); }
    
    /* Responsive grid system */
    .grid { display: grid; gap: 18px; }
    .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    
    @media (max-width: 1023px) {
      .grid-4 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 767px) {
      .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
    }
    
    .row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .between { display: flex; align-items: center; justify-content: space-between; gap: 14px; flex-wrap: wrap; }
    
    /* Premium buttons */
    .btn, button.btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      border: 0; border-radius: 999px; padding: 11px 17px;
      background: linear-gradient(135deg, var(--brand), var(--brand2)); color: #fff;
      font-weight: 900; cursor: pointer; box-shadow: 0 12px 30px rgba(184, 50, 128, .22);
      min-height: 42px; transition: all .2s ease; white-space: nowrap; font: inherit;
      text-decoration: none; font-size: .95rem;
    }
    .btn:hover { text-decoration: none; transform: translateY(-1px); color: #fff; box-shadow: 0 16px 36px rgba(184, 50, 128, .28); }
    .btn:active { transform: translateY(0); }
    .btn.secondary { color: var(--brand-dark); background: #fff; border: 1px solid var(--border); box-shadow: none; }
    .btn.secondary:hover { color: var(--brand); background: #fff8fc; }
    .btn.ghost { color: var(--text); background: transparent; box-shadow: none; border: 1px solid transparent; }
    .btn.ghost:hover { color: var(--brand); background: rgba(255,255,255,.7); }
    .btn.danger { background: #fff; color: var(--red); border: 1px solid #ffd0cc; box-shadow: none; }
    .btn.danger:hover { color: #fff; background: var(--red); }
    .btn.small { padding: 7px 11px; min-height: 34px; font-size: .9rem; }
    .btn.green { background: var(--green); box-shadow: none; }

    /* Forms — responsive with !important for Tailwind override */
    input:not([type="checkbox"]):not([type="radio"]), select, textarea {
      width: 100%; border: 1px solid var(--border) !important; border-radius: 16px !important; padding: 12px 14px !important; font: inherit; background: rgba(255,255,255,.94) !important; color: var(--text) !important; outline: none; transition: .16s ease;
    }
    textarea { resize: vertical; }
    input:not([type="checkbox"]):not([type="radio"]):focus, select:focus, textarea:focus { border-color: var(--brand) !important; box-shadow: 0 0 0 4px rgba(184, 50, 128, .10) !important; }
    
    /* Styled custom checkbox */
    input[type="checkbox"] {
      width: 20px !important;
      height: 20px !important;
      border: 2px solid var(--brand) !important;
      border-radius: 6px !important;
      background: rgba(255,255,255,.94) !important;
      cursor: pointer;
      appearance: none;
      -webkit-appearance: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      position: relative;
      transition: all 0.16s ease;
      vertical-align: middle;
      flex-shrink: 0;
      margin: 0 !important;
      padding: 0 !important;
    }
    input[type="checkbox"]:checked {
      background: var(--brand) !important;
      border-color: var(--brand) !important;
    }
    input[type="checkbox"]:checked::after {
      content: "";
      width: 6px;
      height: 11px;
      border: solid #ffffff;
      border-width: 0 3px 3px 0;
      transform: rotate(45deg);
      position: absolute;
      top: 1px;
    }
    input[type="checkbox"]:focus {
      box-shadow: 0 0 0 3px rgba(184, 50, 128, .2) !important;
      outline: none;
    }

    label { display: grid; gap: 7px; font-weight: 850; color: #3b2435; }
    label.row { display: flex; align-items: center; gap: 10px; }
    
    .hint { color: var(--muted); font-size: .92rem; line-height: 1.5; font-weight: 500; }
    .error-text { color: var(--red); font-weight: 800; font-size: .9rem; }
    
    /* Alerts */
    .alert { border-radius: 18px; padding: 13px 15px; margin-bottom: 18px; border: 1px solid; font-weight: 800; }
    .alert.success { background: #ecfdf5; color: #065f46; border-color: #bbf7d0; }
    .alert.error { background: #fff1f2; color: #9f1239; border-color: #fecdd3; }
    .alert.warning { background: #fffbeb; color: #78350f; border-color: #fef3c7; }
    
    /* Badges */
    .badge { display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; padding: 6px 10px; font-size: .82rem; font-weight: 900; background: #fff; border: 1px solid var(--border); color: var(--muted); text-transform: capitalize; width: fit-content; }
    .badge.pending { color: var(--gold); border-color: #f7df9e; background: #fffbeb; }
    .badge.approved { color: var(--green); border-color: #bbf7d0; background: #ecfdf5; }
    .badge.rejected { color: var(--red); border-color: #fecdd3; background: #fff1f2; }
    
    /* Metrics */
    .metric { padding: 18px; background: #fff; border: 1px solid var(--border); border-radius: 18px; transition: transform .15s ease, box-shadow .15s ease; }
    .metric:hover { transform: translateY(-2px); box-shadow: var(--shadow-soft); }
    .metric .num { font-size: 1.65rem; font-weight: 950; letter-spacing: -.04em; }
    .muted { color: var(--muted); }
    .divider { height: 1px; background: var(--border); margin: 18px 0; }
    
    /* Progress bars */
    .progress { width: 100%; height: 10px; background: #f7e8f0; border-radius: 999px; overflow: hidden; }
    .progress.compact { height: 7px; min-width: 80px; margin-top: 6px; }
    .progress > span { display: block; height: 100%; background: linear-gradient(90deg, var(--brand), var(--brand2)); border-radius: 999px; transition: width .8s ease; }
    
    /* Media grid — responsive */
    .media-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 16px; }
    @media (max-width: 500px) {
      .media-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; }
    }
    .media-card { overflow: hidden; border-radius: 20px; border: 1px solid var(--border); background: #fff; box-shadow: 0 10px 24px rgba(78,30,62,.06); transition: transform .15s ease; }
    .media-card:hover { transform: translateY(-3px); }
    .media-card .thumb { aspect-ratio: 1 / 1; width: 100%; background: #f7edf3; display: grid; place-items: center; overflow: hidden; }
    .media-card img, .media-card video { width: 100%; height: 100%; object-fit: cover; display: block; }
    .media-card .body { padding: 12px; display: grid; gap: 8px; }
    
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; word-break: break-all; }
    .copy-box { display: flex; gap: 8px; align-items: center; }
    .copy-box input { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
    .empty { text-align: center; padding: 44px 18px; border: 1px dashed var(--border-strong); border-radius: var(--radius); background: rgba(255,255,255,.58); color: var(--muted); }
    
    /* Tables — responsive */
    .table-wrap { overflow-x: auto; width: 100%; -webkit-overflow-scrolling: touch; }
    .table-like { width: 100%; border-collapse: collapse; min-width: 600px; }
    .table-like th, .table-like td { padding: 13px 12px; border-bottom: 1px solid var(--border); text-align: left; vertical-align: middle; }
    .table-like th { color: var(--muted); font-size: .78rem; text-transform: uppercase; letter-spacing: .07em; font-weight: 950; }
    .pro-table tbody tr { transition: .15s ease; }
    .pro-table tbody tr:hover { background: rgba(255, 246, 251, .9); }
    
    .strong-link { color: var(--text); font-weight: 950; text-decoration: none; }
    .strong-link:hover { color: var(--brand); }
    .upload-drop { border: 2px dashed #e3b7d4; border-radius: 24px; padding: 26px; text-align: center; background: linear-gradient(180deg, rgba(255,255,255,.86), rgba(255,255,255,.58)); transition: border-color .2s ease; }
    .upload-drop.dragover { border-color: var(--brand); background: #fff; }
    
    /* Eyebrow labels */
    .eyebrow { display:inline-flex; align-items:center; gap:8px; text-transform:uppercase; letter-spacing:.12em; font-size:.76rem; font-weight:950; color: var(--brand); }
    .eyebrow.light { color: #ffe0ef; }

    /* Admin toolbar — responsive */
    .admin-toolbar { display:flex; justify-content:space-between; align-items:flex-end; gap:18px; margin-bottom:14px; flex-wrap: wrap; }
    .admin-toolbar h1 { margin:8px 0 4px; font-size: clamp(1.8rem, 5vw, 3.65rem); line-height:1; letter-spacing:-.06em; }
    .admin-toolbar p { color: var(--muted); margin:0; max-width:720px; line-height:1.6; }
    .admin-actions { display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end; }
    @media (max-width: 639px) {
      .admin-toolbar { flex-direction: column; align-items: stretch; }
      .admin-actions { justify-content: flex-start; }
    }
    
    /* Tabs — responsive with scroll */
    .tabs { display:flex; gap:8px; overflow-x:auto; padding: 8px; border:1px solid var(--border); background: rgba(255,255,255,.66); border-radius: 999px; margin-bottom:22px; box-shadow: var(--shadow-soft); -webkit-overflow-scrolling: touch; }
    .tab { padding:10px 14px; border-radius:999px; color: var(--muted); font-weight:900; white-space:nowrap; text-decoration: none; transition: all .15s ease; font-size: .9rem; }
    .tab.active, .tab:hover { color:#fff; background: linear-gradient(135deg, var(--brand), var(--brand2)); }
    
    .panel-head { display:flex; justify-content:space-between; align-items:flex-start; gap:14px; flex-wrap:wrap; margin-bottom:14px; }
    .panel-head h2 { margin:0; letter-spacing:-.035em; }
    .panel-head p { margin:4px 0 0; color:var(--muted); }

    /* Filter bar — responsive */
    .filter-bar { display:grid; grid-template-columns: minmax(220px, 1fr) 180px 180px auto; gap:14px; align-items:end; }
    @media (max-width: 767px) {
      .filter-bar { grid-template-columns: 1fr; }
    }
    @media (min-width: 768px) and (max-width: 1023px) {
      .filter-bar { grid-template-columns: 1fr 1fr; }
    }
    
    .info-list { display:grid; gap:10px; }
    .info-list > div { display:flex; justify-content:space-between; align-items:center; gap:12px; border-bottom:1px solid var(--border); padding:10px 0; flex-wrap: wrap; }
    .info-list span { color:var(--muted); font-weight:800; }
    .info-list strong { text-align:right; word-break: break-all; }
    
    .pill-grid { display:flex; flex-wrap:wrap; gap:10px; }
    .folder-pill { padding:10px 13px; border-radius:999px; background:#fff; border:1px solid var(--border); font-weight:900; transition: all .15s ease; }
    .folder-pill:hover { border-color: var(--brand); background: #fff8fc; }
    
    .audit-list { display:grid; gap:10px; }
    .audit-item { display:flex; justify-content:space-between; gap:14px; padding:14px; background:#fff; border:1px solid var(--border); border-radius:18px; flex-wrap: wrap; }
    .audit-item p { margin:4px 0 0; color:var(--muted); }
    .danger-zone { border-color:#fecdd3; background:rgba(255,241,242,.78); }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(184, 50, 128, 0.15); border-radius: 10px; }

    /* Mobile sidebar overlay */
    .sidebar-overlay {
      position: fixed; inset: 0; background: rgba(32,16,33,.5); z-index: 99; opacity: 0; pointer-events: none;
      transition: opacity .25s ease; backdrop-filter: blur(4px);
    }
    .sidebar-overlay.active { opacity: 1; pointer-events: auto; }

    .mobile-sidebar {
      position: fixed; top: 0; left: 0; bottom: 0; width: 280px; max-width: 85vw; background: #fff; z-index: 100;
      transform: translateX(-100%); transition: transform .3s cubic-bezier(.4,0,.2,1);
      box-shadow: 20px 0 60px rgba(78,30,62,.2); overflow-y: auto;
    }
    .mobile-sidebar.active { transform: translateX(0); }

    /* Hamburger animation */
    .hamburger { display: flex; flex-direction: column; gap: 5px; cursor: pointer; padding: 6px; border-radius: 8px; transition: background .15s; }
    .hamburger:hover { background: rgba(184,50,128,.06); }
    .hamburger span { display: block; width: 22px; height: 2px; background: var(--brand); border-radius: 2px; transition: .3s ease; }

    /* Smooth animations */
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fadein { animation: fadeInUp .4s ease forwards; }

    /* Responsive card and panel padding */
    @media (max-width: 639px) {
      .card, .panel { padding: 16px; }
      .metric { padding: 14px; }
      .metric .num { font-size: 1.35rem; }
      .between { gap: 10px; }
      .btn, button.btn { padding: 10px 14px; font-size: .88rem; min-height: 38px; }
    }
  </style>
</head>
<body class="bg-[#fdf8f9] text-slate-800 font-body antialiased min-h-screen relative">
  <% 
    const currentPath = locals.path || '';
    const isAdminRoute = currentPath.startsWith('/admin');
    const isDashboardRoute = currentPath.startsWith('/dashboard');
    const isLayoutSidebar = (isAdminRoute || isDashboardRoute) && locals.currentUser;
  %>
  
  <% if (isLayoutSidebar) { %>
    <!-- Layout with Sidebar for Admin/Dashboard -->
    <div class="flex overflow-hidden min-h-screen relative z-10">
      
      <!-- Mobile Sidebar Overlay -->
      <div class="sidebar-overlay lg:hidden" id="sidebarOverlay" onclick="closeMobileSidebar()"></div>

      <!-- Mobile Sidebar (slide-out) -->
      <aside class="mobile-sidebar lg:hidden" id="mobileSidebar">
        <div class="p-5 flex flex-col items-start gap-3 min-h-full">
          <div class="flex items-center justify-between w-full mb-4">
            <a class="flex items-center gap-3" href="/">
              <svg class="w-9 h-9 p-1 rounded-lg bg-white border border-primary/15" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <defs><linearGradient id="rGM" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" style="stop-color:#b83280;stop-opacity:1" /><stop offset="100%" style="stop-color:#ff7a59;stop-opacity:1" /></linearGradient></defs>
                <path d="M50 15 C30 15 15 30 15 50 C15 70 30 85 50 85 C70 85 85 70 85 50 C85 30 70 15 50 15" fill="none" stroke="url(#rGM)" stroke-width="3"/>
                <circle cx="50" cy="50" r="12" fill="url(#rGM)"/>
                <path d="M45 40 Q50 30 55 40 T65 50 Q60 60 55 50 T45 40" fill="#b83280" opacity="0.6"/>
              </svg>
              <span class="font-headline text-lg font-bold text-primary">ShaadiShots</span>
            </a>
            <button onclick="closeMobileSidebar()" class="p-2 rounded-lg hover:bg-primary/5 transition-colors">
              <span class="material-symbols-outlined text-primary">close</span>
            </button>
          </div>
          
          <nav class="flex-1 w-full space-y-1">
            <% if (locals.isSuperAdmin) { %>
              <div class="px-3 mb-2 text-[10px] font-bold text-primary/60 tracking-wider uppercase font-display">Super Admin Console</div>
              <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all <%= currentPath === '/admin' ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/admin" onclick="closeMobileSidebar()">
                <span class="material-symbols-outlined">dashboard</span><span>Console Overview</span>
              </a>
              <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all <%= currentPath.startsWith('/admin/users') ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/admin/users" onclick="closeMobileSidebar()">
                <span class="material-symbols-outlined">group</span><span>Users</span>
              </a>
              <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all <%= currentPath.startsWith('/admin/events') ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/admin/events" onclick="closeMobileSidebar()">
                <span class="material-symbols-outlined">celebration</span><span>Weddings</span>
              </a>
              <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all <%= currentPath.startsWith('/admin/whatsapp') ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/admin/whatsapp" onclick="closeMobileSidebar()">
                <span class="material-symbols-outlined">chat</span><span>WhatsApp</span>
              </a>
              <div class="h-px bg-primary/10 my-3"></div>
            <% } %>
            <div class="px-3 mb-2 text-[10px] font-bold text-primary/60 tracking-wider uppercase font-display">Album Manager</div>
            <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all <%= currentPath === '/dashboard' ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/dashboard" onclick="closeMobileSidebar()">
              <span class="material-symbols-outlined">photo_album</span><span>My Albums</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all <%= currentPath.startsWith('/dashboard/profile') ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/dashboard/profile" onclick="closeMobileSidebar()">
              <span class="material-symbols-outlined">person</span><span>My Profile</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all <%= currentPath.startsWith('/dashboard/security') ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/dashboard/security" onclick="closeMobileSidebar()">
              <span class="material-symbols-outlined">shield</span><span>Security Settings</span>
            </a>
            <div class="pt-2">
              <a class="flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-full text-sm font-bold text-white bg-gradient-wedding shadow-lg hover:shadow-xl transition-all" href="/dashboard/events/new" onclick="closeMobileSidebar()">
                <span class="material-symbols-outlined">add</span><span>New Album</span>
              </a>
            </div>
          </nav>
          
          <div class="w-full pt-3 border-t border-primary/10 mt-auto">
            <form action="/logout" method="post" style="margin:0">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="w-full flex items-center gap-3 px-4 py-2.5 text-red-600 hover:bg-red-50 rounded-lg transition-colors font-bold text-sm" type="submit">
                <span class="material-symbols-outlined">logout</span><span>Logout</span>
              </button>
            </form>
          </div>
        </div>
      </aside>

      <!-- Desktop Navigation Sidebar -->
      <aside class="hidden lg:flex flex-col h-screen sticky left-0 top-0 bg-white border-r border-primary/10 shadow-xl w-72 z-40">
        <div class="p-6 flex flex-col items-start gap-4 flex-1 overflow-y-auto custom-scrollbar">
          <a class="flex items-center gap-3 mb-6" href="/">
            <svg class="w-10 h-10 p-1 rounded-lg bg-white border border-primary/15" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="roseGradientNavAside" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:#b83280;stop-opacity:1" />
                  <stop offset="100%" style="stop-color:#ff7a59;stop-opacity:1" />
                </linearGradient>
              </defs>
              <path d="M50 15 C30 15 15 30 15 50 C15 70 30 85 50 85 C70 85 85 70 85 50 C85 30 70 15 50 15" fill="none" stroke="url(#roseGradientNavAside)" stroke-width="3"/>
              <circle cx="50" cy="50" r="12" fill="url(#roseGradientNavAside)"/>
              <path d="M45 40 Q50 30 55 40 T65 50 Q60 60 55 50 T45 40" fill="#b83280" opacity="0.6"/>
            </svg>
            <span class="font-headline text-xl font-bold text-primary">ShaadiShots</span>
          </a>
          
          <!-- Navigation Links -->
          <nav class="flex-1 w-full space-y-1.5">
            <% if (locals.isSuperAdmin) { %>
              <div class="px-3 mb-2 text-[10px] font-bold text-primary/60 tracking-wider uppercase font-display">Super Admin Console</div>
              <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all <%= currentPath === '/admin' ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/admin">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Console Overview</span>
              </a>
              <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all <%= currentPath.startsWith('/admin/users') ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/admin/users">
                <span class="material-symbols-outlined">group</span>
                <span>Users</span>
              </a>
              <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all <%= currentPath.startsWith('/admin/events') ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/admin/events">
                <span class="material-symbols-outlined">celebration</span>
                <span>Weddings</span>
              </a>
              <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all <%= currentPath.startsWith('/admin/whatsapp') ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/admin/whatsapp">
                <span class="material-symbols-outlined">chat</span>
                <span>WhatsApp</span>
              </a>
              <div class="h-px bg-primary/10 my-4"></div>
            <% } %>
            
            <div class="px-3 mb-2 text-[10px] font-bold text-primary/60 tracking-wider uppercase font-display">Album Manager</div>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all <%= currentPath === '/dashboard' ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/dashboard">
              <span class="material-symbols-outlined">photo_album</span>
              <span>My Albums</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all <%= currentPath.startsWith('/dashboard/profile') ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/dashboard/profile">
              <span class="material-symbols-outlined">person</span>
              <span>My Profile</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold transition-all <%= currentPath.startsWith('/dashboard/security') ? 'bg-gradient-wedding text-white shadow-md' : 'text-slate-600 hover:bg-primary/5 hover:text-primary' %>" href="/dashboard/security">
              <span class="material-symbols-outlined">shield</span>
              <span>Security Settings</span>
            </a>
            
            <div class="pt-2">
              <a class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-full text-sm font-bold text-white bg-gradient-wedding shadow-lg hover:shadow-xl transition-all" href="/dashboard/events/new">
                <span class="material-symbols-outlined">add</span>
                <span>New Album</span>
              </a>
            </div>
          </nav>
          
          <!-- Profile Bottom Sidebar Info -->
          <div class="w-full pt-4 border-t border-primary/10">
            <form action="/logout" method="post" style="margin:0">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="w-full flex items-center gap-3 px-4 py-3 text-red-600 hover:bg-red-50 rounded-lg transition-colors font-bold text-sm" type="submit">
                <span class="material-symbols-outlined">logout</span>
                <span>Logout</span>
              </button>
            </form>
          </div>
        </div>
      </aside>
      
      <!-- Main Content Canvas -->
      <main class="flex-1 flex flex-col min-w-0 h-screen overflow-y-auto relative custom-scrollbar bg-[#fdf8f9]">
        
        <!-- Sticky Top bar for dashboard/admin -->
        <header class="fixed top-0 right-0 left-0 lg:left-72 z-30 bg-white/80 backdrop-blur-xl border-b border-primary/10 shadow-sm px-4 sm:px-6 py-3 sm:py-4 flex justify-between items-center h-16 sm:h-20">
          <div class="flex items-center gap-3 sm:gap-4">
            <!-- Mobile hamburger -->
            <button class="lg:hidden hamburger" onclick="openMobileSidebar()" aria-label="Open menu">
              <span></span><span></span><span></span>
            </button>
            <h1 class="font-headline text-lg sm:text-2xl font-bold text-primary truncate"><%= locals.title || 'Dashboard' %></h1>
          </div>
          <div class="flex items-center gap-3 sm:gap-4">
            <div class="flex flex-col items-end">
              <span class="text-xs sm:text-sm font-bold text-slate-800 truncate max-w-[120px] sm:max-w-none"><%= currentUser.name %></span>
              <span class="text-[8px] sm:text-[9px] text-green-600 flex items-center gap-1 font-bold uppercase tracking-widest mt-0.5">
                <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span> <%= isSuperAdmin ? 'Super Admin' : 'Event Owner' %>
              </span>
            </div>
          </div>
        </header>
        
        <!-- Body Panel -->
        <div class="mt-20 sm:mt-24 p-4 sm:p-6 lg:p-10 space-y-6 sm:space-y-8 pb-24 sm:pb-32 max-w-7xl w-full mx-auto relative z-10">
          <%- include('partials/flash') %>
          <%- body %>
        </div>
      </main>
    </div>

    <script>
      function openMobileSidebar() {
        document.getElementById('mobileSidebar').classList.add('active');
        document.getElementById('sidebarOverlay').classList.add('active');
        document.body.style.overflow = 'hidden';
      }
      function closeMobileSidebar() {
        document.getElementById('mobileSidebar').classList.remove('active');
        document.getElementById('sidebarOverlay').classList.remove('active');
        document.body.style.overflow = '';
      }
    </script>
    
  <% } else { %>
    <!-- Public/Guest Layout -->
    <div class="relative z-10">
      <%- include('partials/nav') %>
      <main class="max-w-7xl mx-auto px-4 py-4 sm:py-6 sm:px-6 lg:px-8 mt-4 sm:mt-6">
        <%- include('partials/flash') %>
        <%- body %>
      </main>
      
      <footer class="text-slate-400 text-center py-8 sm:py-12 text-sm max-w-7xl mx-auto px-4 mt-8 sm:mt-12 border-t border-primary/10">
        <div class="mb-4 font-semibold space-x-4">
          <a href="/privacy" class="hover:text-primary transition-colors">Privacy Policy</a>
          <span>·</span>
          <a href="/contact" class="hover:text-primary transition-colors">Contact & Support</a>
        </div>
        <div>Secure wedding memory collection SaaS · <%= appName %></div>
      </footer>
    </div>
  <% } %>
</body>
</html>
