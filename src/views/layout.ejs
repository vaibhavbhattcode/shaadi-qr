<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <title><%= title ? `${title} · ${appName}` : appName %></title>
  <style>
    :root {
      --bg: #fff7f2;
      --bg-deep: #201021;
      --surface: rgba(255,255,255,.86);
      --surface-solid: #ffffff;
      --text: #24111f;
      --muted: #7c6578;
      --brand: #b83280;
      --brand-dark: #8d2363;
      --brand2: #ff7a59;
      --gold: #c58a13;
      --green: #12805c;
      --red: #b42318;
      --blue: #1d4ed8;
      --border: #efd6e6;
      --border-strong: #e7bdd7;
      --shadow: 0 24px 70px rgba(78, 30, 62, .13);
      --shadow-soft: 0 14px 34px rgba(78, 30, 62, .08);
      --radius: 24px;
      --radius-sm: 16px;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 8% -10%, rgba(255, 122, 89, .22), transparent 34rem),
        radial-gradient(circle at 90% 0%, rgba(184, 50, 128, .18), transparent 30rem),
        linear-gradient(180deg, #fff9f5 0%, #fff2f7 46%, #fff8f3 100%);
      min-height: 100vh;
    }
    body::before {
      content: ""; position: fixed; inset: 0; pointer-events: none; opacity: .45;
      background-image: radial-gradient(rgba(184,50,128,.10) 1px, transparent 1px);
      background-size: 24px 24px; mask-image: linear-gradient(to bottom, #000, transparent 70%);
    }
    a { color: var(--brand); text-decoration: none; }
    a:hover { text-decoration: none; color: var(--brand-dark); }
    .nav { position: sticky; top: 0; z-index: 50; backdrop-filter: blur(20px); background: rgba(255, 249, 246, .82); border-bottom: 1px solid rgba(239, 214, 230, .8); }
    .nav-inner { max-width: 1240px; margin: 0 auto; padding: 14px 20px; display: flex; align-items: center; justify-content: space-between; gap: 14px; }
    .brand { display: flex; align-items: center; gap: 10px; color: var(--text); font-weight: 950; letter-spacing: -.04em; font-size: 1.22rem; }
    .brand-mark { width: 42px; height: 42px; border-radius: 16px; display: grid; place-items: center; color: white; background: linear-gradient(135deg, var(--brand), var(--brand2)); box-shadow: 0 14px 34px rgba(184, 50, 128, .25); }
    .nav-links { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
    .container { position: relative; max-width: 1240px; margin: 0 auto; padding: 30px 20px 60px; }
    .hero { display: grid; grid-template-columns: 1.12fr .88fr; gap: 28px; align-items: center; padding: 36px 0; }
    .hero h1 { font-size: clamp(2.45rem, 6.6vw, 5.4rem); line-height: .93; margin: 0 0 18px; letter-spacing: -.08em; }
    .hero p { font-size: 1.13rem; color: var(--muted); line-height: 1.75; }
    .card, .panel { background: var(--surface); border: 1px solid rgba(239, 214, 230, .92); border-radius: var(--radius); box-shadow: var(--shadow-soft); padding: 22px; backdrop-filter: blur(18px); }
    .panel { box-shadow: var(--shadow); }
    .card.soft { box-shadow: none; background: rgba(255,255,255,.62); }
    .grid { display: grid; gap: 18px; }
    .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .between { display: flex; align-items: center; justify-content: space-between; gap: 14px; flex-wrap: wrap; }
    .btn, button.btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      border: 0; border-radius: 999px; padding: 11px 17px;
      background: linear-gradient(135deg, var(--brand), var(--brand2)); color: #fff;
      font-weight: 900; cursor: pointer; box-shadow: 0 12px 30px rgba(184, 50, 128, .22);
      min-height: 42px; transition: .18s ease; white-space: nowrap; font: inherit;
    }
    .btn:hover { text-decoration: none; transform: translateY(-1px); color: #fff; box-shadow: 0 16px 36px rgba(184, 50, 128, .28); }
    .btn.secondary { color: var(--brand-dark); background: #fff; border: 1px solid var(--border); box-shadow: none; }
    .btn.secondary:hover { color: var(--brand); background: #fff8fc; }
    .btn.ghost { color: var(--text); background: transparent; box-shadow: none; border: 1px solid transparent; }
    .btn.ghost:hover { color: var(--brand); background: rgba(255,255,255,.7); }
    .btn.danger { background: #fff; color: var(--red); border: 1px solid #ffd0cc; box-shadow: none; }
    .btn.danger:hover { color: #fff; background: var(--red); }
    .btn.small { padding: 7px 11px; min-height: 34px; font-size: .9rem; }
    .btn.green { background: var(--green); box-shadow: none; }
    input, select, textarea {
      width: 100%; border: 1px solid var(--border); border-radius: 16px; padding: 12px 14px; font: inherit; background: rgba(255,255,255,.94); color: var(--text); outline: none; transition: .16s ease;
    }
    textarea { resize: vertical; }
    input:focus, select:focus, textarea:focus { border-color: var(--brand); box-shadow: 0 0 0 4px rgba(184, 50, 128, .10); }
    label { display: grid; gap: 7px; font-weight: 850; color: #3b2435; }
    label.row { display: flex; }
    .hint { color: var(--muted); font-size: .92rem; line-height: 1.5; font-weight: 500; }
    .error-text { color: var(--red); font-weight: 800; font-size: .9rem; }
    .alert { border-radius: 18px; padding: 13px 15px; margin-bottom: 18px; border: 1px solid; font-weight: 800; }
    .alert.success { background: #ecfdf5; color: #065f46; border-color: #bbf7d0; }
    .alert.error { background: #fff1f2; color: #9f1239; border-color: #fecdd3; }
    .badge { display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; padding: 6px 10px; font-size: .82rem; font-weight: 900; background: #fff; border: 1px solid var(--border); color: var(--muted); text-transform: capitalize; width: fit-content; }
    .badge.pending { color: var(--gold); border-color: #f7df9e; background: #fffbeb; }
    .badge.approved { color: var(--green); border-color: #bbf7d0; background: #ecfdf5; }
    .badge.rejected { color: var(--red); border-color: #fecdd3; background: #fff1f2; }
    .metric { padding: 18px; background: #fff; border: 1px solid var(--border); border-radius: 18px; }
    .metric .num { font-size: 1.65rem; font-weight: 950; letter-spacing: -.04em; }
    .muted { color: var(--muted); }
    .divider { height: 1px; background: var(--border); margin: 18px 0; }
    .progress { width: 100%; height: 10px; background: #f7e8f0; border-radius: 999px; overflow: hidden; }
    .progress.compact { height: 7px; min-width: 110px; margin-top: 6px; }
    .progress > span { display: block; height: 100%; background: linear-gradient(90deg, var(--brand), var(--brand2)); border-radius: 999px; }
    .media-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 16px; }
    .media-card { overflow: hidden; border-radius: 20px; border: 1px solid var(--border); background: #fff; box-shadow: 0 10px 24px rgba(78,30,62,.06); }
    .media-card .thumb { aspect-ratio: 1 / 1; width: 100%; background: #f7edf3; display: grid; place-items: center; overflow: hidden; }
    .media-card img, .media-card video { width: 100%; height: 100%; object-fit: cover; display: block; }
    .media-card .body { padding: 12px; display: grid; gap: 8px; }
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; word-break: break-all; }
    .copy-box { display: flex; gap: 8px; align-items: center; }
    .copy-box input { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }
    .empty { text-align: center; padding: 44px 18px; border: 1px dashed var(--border-strong); border-radius: var(--radius); background: rgba(255,255,255,.58); color: var(--muted); }
    .table-wrap { overflow-x: auto; width: 100%; }
    .table-like { width: 100%; border-collapse: collapse; }
    .table-like th, .table-like td { padding: 13px 12px; border-bottom: 1px solid var(--border); text-align: left; vertical-align: middle; }
    .table-like th { color: var(--muted); font-size: .78rem; text-transform: uppercase; letter-spacing: .07em; font-weight: 950; }
    .pro-table tbody tr { transition: .15s ease; }
    .pro-table tbody tr:hover { background: rgba(255, 246, 251, .9); }
    .strong-link { color: var(--text); font-weight: 950; }
    .strong-link:hover { color: var(--brand); }
    .upload-drop { border: 2px dashed #e3b7d4; border-radius: 24px; padding: 26px; text-align: center; background: linear-gradient(180deg, rgba(255,255,255,.86), rgba(255,255,255,.58)); }
    .upload-drop.dragover { border-color: var(--brand); background: #fff; }
    .footer { color: var(--muted); text-align: center; padding: 20px; font-size: .9rem; }

    .eyebrow { display:inline-flex; align-items:center; gap:8px; text-transform:uppercase; letter-spacing:.12em; font-size:.76rem; font-weight:950; color: var(--brand); }
    .eyebrow.light { color: #ffe0ef; }
    .admin-toolbar { display:flex; justify-content:space-between; align-items:flex-end; gap:18px; margin-bottom:14px; }
    .admin-toolbar h1 { margin:8px 0 4px; font-size: clamp(2rem, 5vw, 3.65rem); line-height:1; letter-spacing:-.06em; }
    .admin-toolbar p { color: var(--muted); margin:0; max-width:720px; line-height:1.6; }
    .admin-actions { display:flex; gap:10px; flex-wrap:wrap; justify-content:flex-end; }
    .tabs { display:flex; gap:8px; overflow-x:auto; padding: 8px; border:1px solid var(--border); background: rgba(255,255,255,.66); border-radius: 999px; margin-bottom:22px; box-shadow: var(--shadow-soft); }
    .tab { padding:10px 14px; border-radius:999px; color: var(--muted); font-weight:900; white-space:nowrap; }
    .tab.active, .tab:hover { color:#fff; background: linear-gradient(135deg, var(--brand), var(--brand2)); }
    .admin-hero { display:grid; grid-template-columns:1.3fr .7fr; gap:20px; align-items:stretch; padding:26px; border-radius:32px; background: radial-gradient(circle at top left, rgba(255,255,255,.22), transparent 24rem), linear-gradient(135deg, #3b143c 0%, #8d2363 45%, #ff7a59 120%); color:#fff; box-shadow: var(--shadow); margin-bottom:22px; overflow:hidden; }
    .admin-hero-copy h2 { font-size: clamp(2rem, 4.8vw, 4.3rem); line-height:.95; letter-spacing:-.07em; margin:12px 0; }
    .admin-hero-copy p { color:#ffe8f2; max-width:760px; font-size:1.08rem; line-height:1.7; }
    .admin-hero-panel { display:grid; gap:12px; }
    .mini-stat { background: rgba(255,255,255,.14); border:1px solid rgba(255,255,255,.24); border-radius:22px; padding:18px; backdrop-filter: blur(12px); }
    .mini-stat strong { display:block; font-size:1.7rem; letter-spacing:-.04em; }
    .mini-stat span { color:#ffe7f1; }
    .stat-grid { display:grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap:16px; }
    .stat-card { padding:20px; border-radius:24px; background: rgba(255,255,255,.88); border:1px solid var(--border); box-shadow: var(--shadow-soft); display:grid; gap:6px; min-height:142px; }
    .stat-card span { color: var(--muted); font-weight:900; text-transform:uppercase; letter-spacing:.08em; font-size:.77rem; }
    .stat-card strong { font-size: clamp(2rem, 4vw, 3.1rem); letter-spacing:-.06em; line-height:1; }
    .stat-card small { color: var(--muted); font-weight:700; }
    .stat-card.gradient-pink { color:#fff; background: linear-gradient(135deg, var(--brand), var(--brand2)); border:0; }
    .stat-card.gradient-pink span, .stat-card.gradient-pink small { color:#ffe6f1; }
    .panel-head { display:flex; justify-content:space-between; align-items:flex-start; gap:14px; flex-wrap:wrap; margin-bottom:14px; }
    .panel-head h2 { margin:0; letter-spacing:-.035em; }
    .panel-head p { margin:4px 0 0; color:var(--muted); }
    .filter-bar { display:grid; grid-template-columns: minmax(220px, 1fr) 180px 180px auto; gap:14px; align-items:end; }
    .control-card { display:grid; gap:12px; padding:16px; border:1px solid var(--border); border-radius:20px; background:#fff; }
    .info-list { display:grid; gap:10px; }
    .info-list > div { display:flex; justify-content:space-between; align-items:center; gap:12px; border-bottom:1px solid var(--border); padding:10px 0; }
    .info-list span { color:var(--muted); font-weight:800; }
    .info-list strong { text-align:right; }
    .pill-grid { display:flex; flex-wrap:wrap; gap:10px; }
    .folder-pill { padding:10px 13px; border-radius:999px; background:#fff; border:1px solid var(--border); font-weight:900; }
    .audit-list { display:grid; gap:10px; }
    .audit-item { display:flex; justify-content:space-between; gap:14px; padding:14px; background:#fff; border:1px solid var(--border); border-radius:18px; }
    .audit-item p { margin:4px 0 0; color:var(--muted); }
    .danger-zone { border-color:#fecdd3; background:rgba(255,241,242,.78); }

    @media (max-width: 980px) {
      .hero, .admin-hero, .grid-4, .stat-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
      .filter-bar { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 720px) {
      .container { padding: 22px 14px 46px; }
      .nav-inner { align-items:flex-start; padding:12px 14px; }
      .nav-links { gap:6px; }
      .hero, .admin-hero, .grid-2, .grid-3, .grid-4, .stat-grid, .filter-bar { grid-template-columns: 1fr; }
      .hero h1 { font-size: 3rem; }
      .card, .panel { padding: 17px; border-radius: 20px; }
      .copy-box { flex-direction: column; align-items: stretch; }
      .admin-toolbar { align-items:flex-start; flex-direction:column; }
      .admin-actions { justify-content:flex-start; }
      .tabs { border-radius: 18px; }
      .tab { padding:9px 12px; }
      .table-like th, .table-like td { padding:11px 10px; }
      .info-list > div { align-items:flex-start; flex-direction:column; }
      .info-list strong { text-align:left; }
    }
    @media print {
      .nav, .footer, .no-print, .tabs { display: none !important; }
      body { background: #fff; }
      body::before { display:none; }
      .container { max-width: none; padding: 0; }
      .card, .panel { box-shadow: none; border: 0; }
    }
  </style>
</head>
<body>
  <%- include('partials/nav') %>
  <main class="container">
    <%- include('partials/flash') %>
    <%- body %>
  </main>
  <footer class="footer">Secure wedding memory collection SaaS · <%= appName %></footer>
</body>
</html>
