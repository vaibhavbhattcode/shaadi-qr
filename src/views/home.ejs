<section class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center py-12 lg:py-20 relative">
  <div class="space-y-6">
    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-primary/10 rounded-full text-primary text-xs font-bold shadow-sm border border-primary/20">
      ✨ QR-Based Wedding Media Collection
    </span>
    <h1 class="font-headline text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-slate-900 leading-none tracking-tight">
      Guests scan QR. <br>
      <span class="text-gradient-wedding">Memories upload</span> <br>
      automatically.
    </h1>
    <p class="text-slate-600 text-lg leading-relaxed max-w-xl">
      In every wedding, guests capture beautiful candid photos and videos on their phones, but the couple rarely receives them. 
      <strong><%= appName %></strong> provides a secure upload QR, admin moderation, elegant galleries, and high-quality ZIP downloads.
    </p>
    <div class="flex flex-wrap gap-4 pt-4">
      <% if (currentUser) { %>
        <a class="bg-gradient-wedding text-white px-8 py-3.5 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all" href="/dashboard/events/new">Create Wedding QR</a>
        <a class="border border-primary/20 bg-white hover:bg-slate-50 text-primary px-8 py-3.5 rounded-full font-bold text-sm shadow-md transition-all" href="/dashboard">Open Dashboard</a>
      <% } else { %>
        <a class="bg-gradient-wedding text-white px-8 py-3.5 rounded-full font-bold text-sm shadow-md hover:shadow-xl transition-all" href="/register">Start Free Demo</a>
        <a class="border border-primary/20 bg-white hover:bg-slate-50 text-primary px-8 py-3.5 rounded-full font-bold text-sm shadow-md transition-all" href="/login">Login</a>
      <% } %>
    </div>
  </div>
  
  <div class="glass-card p-8 rounded-2xl shadow-xl space-y-6 border border-primary/10 bg-white/70 backdrop-blur-xl">
    <div class="space-y-4">
      <div class="flex items-start gap-4 p-4 bg-white/50 rounded-xl border border-primary/5 hover:border-primary/10 transition-colors shadow-sm">
        <div class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center font-bold text-lg">1</div>
        <div>
          <h4 class="font-bold text-slate-800">Couple Creates Event</h4>
          <p class="text-xs text-slate-500 mt-0.5">Generate a unique QR code and printing poster in seconds.</p>
        </div>
      </div>
      
      <div class="flex items-start gap-4 p-4 bg-white/50 rounded-xl border border-primary/5 hover:border-primary/10 transition-colors shadow-sm">
        <div class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center font-bold text-lg">2</div>
        <div>
          <h4 class="font-bold text-slate-800">Guests Upload Instantly</h4>
          <p class="text-xs text-slate-500 mt-0.5">No login or app install needed. Just scan, pick, and upload.</p>
        </div>
      </div>
      
      <div class="flex items-start gap-4 p-4 bg-white/50 rounded-xl border border-primary/5 hover:border-primary/10 transition-colors shadow-sm">
        <div class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center font-bold text-lg">3</div>
        <div>
          <h4 class="font-bold text-slate-800">Moderated Live Gallery</h4>
          <p class="text-xs text-slate-500 mt-0.5">Approve photos/videos before they go live in the public gallery.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12 py-8">
  <div class="glass-card p-6 rounded-2xl bg-white/60 space-y-3">
    <div class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center">
      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">security</span>
    </div>
    <h3 class="font-headline text-xl font-bold text-slate-800">Secure by Default</h3>
    <p class="text-slate-600 text-sm leading-relaxed">
      HTTP-only auth cookies, CSRF tokens, rate limits, server-side validation, magic-byte file checks, and owner-only dashboards keep your media safe.
    </p>
  </div>
  
  <div class="glass-card p-6 rounded-2xl bg-white/60 space-y-3">
    <div class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center">
      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">cloud</span>
    </div>
    <h3 class="font-headline text-xl font-bold text-slate-800">Storage Control</h3>
    <p class="text-slate-600 text-sm leading-relaxed">
      Track storage usage in real-time. Link your own Google Drive storage for free, unlimited hosting space directly.
    </p>
  </div>
  
  <div class="glass-card p-6 rounded-2xl bg-white/60 space-y-3">
    <div class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center">
      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">photo_library</span>
    </div>
    <h3 class="font-headline text-xl font-bold text-slate-800">Private Gallery</h3>
    <p class="text-slate-600 text-sm leading-relaxed">
      Control public access with optionally password/PIN-protected galleries. Download all approved media files in one click.
    </p>
  </div>
</section>
