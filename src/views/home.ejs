<!-- JavaScript to run the active hero slideshow and mock uploader console -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Slideshow cycle
    const slides = document.querySelectorAll('.js-slide');
    let currentSlide = 0;
    
    setInterval(() => {
      // Fade out current slide
      if (slides[currentSlide]) {
        slides[currentSlide].classList.remove('opacity-100');
        slides[currentSlide].classList.add('opacity-0');
      }
      
      // Select next slide
      currentSlide = (currentSlide + 1) % slides.length;
      
      // Fade in next slide
      if (slides[currentSlide]) {
        slides[currentSlide].classList.remove('opacity-0');
        slides[currentSlide].classList.add('opacity-100');
      }
    }, 4000);

    // 2. Notification rotation
    const wrapper = document.getElementById('heroNotificationsWrapper');
    if (!wrapper) return;
    const count = wrapper.children.length;
    let index = 0;

    setInterval(() => {
      index = (index + 1) % count;
      // Scroll vertically by the height of one child notification block
      wrapper.style.transform = `translateY(-${index * 42}px)`;
    }, 3000);
  });
</script>
